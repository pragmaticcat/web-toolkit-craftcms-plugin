{% extends 'pragmatic-web-toolkit/mcp/_layout' %}
{% import "_includes/forms" as forms %}

{% set title = 'templates.mcp.options.opciones'|t('pragmatic-web-toolkit') %}
{% set selectedTab = 'options' %}

{% block content %}
    {% css %}
        .mcp-options-grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 18px;
            margin-bottom: 18px;
        }
        .mcp-settings-section {
            border: 1px solid #e5e7eb;
            border-radius: 8px;
            padding: 14px;
            background: #fff;
        }
        .mcp-settings-section h2 {
            margin: 0 0 4px;
            font-size: 15px;
        }
        .mcp-settings-section > p {
            margin: 0 0 14px;
        }
        .mcp-warning {
            padding: 12px;
            background: #fff4e6;
            border-left: 4px solid #ff9800;
            margin: 14px 0;
        }
        .mcp-info {
            padding: 12px;
            background: #e3f2fd;
            border-left: 4px solid #2196f3;
            margin: 14px 0;
        }
        @media (max-width: 1023px) {
            .mcp-options-grid {
                grid-template-columns: 1fr;
            }
        }
    {% endcss %}

    <form method="post" accept-charset="UTF-8">
        {{ csrfInput() }}
        {{ actionInput('pragmatic-web-toolkit/mcp/save-settings') }}
        {{ redirectInput('pragmatic-toolkit/mcp/options') }}
        <fieldset>

        {% for field in [
            'enableEntries',
            'enableAssets',
            'enableCategories',
            'enableUsers',
            'enableSearchTool',
            'enableDetailsTool',
            'enableCustomQueries',
            'maxResults',
            'maxQueryComplexity',
            'exposedFields',
            'enableCache',
            'cacheDuration',
            'accessToken',
            'allowedIpAddresses'
        ] %}
            <input type="hidden" name="_fields[]" value="{{ field }}">
        {% endfor %}

        <div class="mcp-options-grid">
            <section class="mcp-settings-section">
                <h2>{{ 'templates.mcp.options.recursos-disponibles'|t('pragmatic-web-toolkit') }}</h2>
                <p>{{ 'templates.mcp.options.selecciona-qu-tipos-de-contenido-estar-n-accesibles-v-a-mcp'|t('pragmatic-web-toolkit') }}</p>

                {{ forms.lightswitchField({
                    label: 'templates.mcp.options.habilitar-entries'|t('pragmatic-web-toolkit'),
                    name: 'enableEntries',
                    on: settings.enableEntries,
                    instructions: 'templates.mcp.options.permite-acceder-a-las-entradas-del-sitio'|t('pragmatic-web-toolkit')
                }) }}

                {{ forms.lightswitchField({
                    label: 'templates.mcp.options.habilitar-assets'|t('pragmatic-web-toolkit'),
                    name: 'enableAssets',
                    on: settings.enableAssets,
                    instructions: 'templates.mcp.options.permite-acceder-a-los-archivos-y-assets'|t('pragmatic-web-toolkit')
                }) }}

                {{ forms.lightswitchField({
                    label: 'templates.mcp.options.habilitar-categor-as'|t('pragmatic-web-toolkit'),
                    name: 'enableCategories',
                    on: settings.enableCategories,
                    instructions: 'templates.mcp.options.permite-acceder-a-las-categor-as'|t('pragmatic-web-toolkit')
                }) }}

                {{ forms.lightswitchField({
                    label: 'templates.mcp.options.habilitar-usuarios'|t('pragmatic-web-toolkit'),
                    name: 'enableUsers',
                    on: settings.enableUsers,
                    instructions: 'templates.mcp.options.permite-acceder-a-la-informaci-n-de-usuarios-usar-con-precauci-n'|t('pragmatic-web-toolkit')
                }) }}
            </section>

            <section class="mcp-settings-section">
                <h2>{{ 'templates.mcp.options.herramientas-tools'|t('pragmatic-web-toolkit') }}</h2>
                <p>{{ 'templates.mcp.options.habilita-las-herramientas-que-claude-podr-usar-para-consultar-co'|t('pragmatic-web-toolkit') }}</p>

                {{ forms.lightswitchField({
                    label: 'templates.mcp.options.tool-b-squeda-de-entradas'|t('pragmatic-web-toolkit'),
                    name: 'enableSearchTool',
                    on: settings.enableSearchTool,
                    instructions: 'templates.mcp.options.permite-buscar-entradas-por-texto'|t('pragmatic-web-toolkit')
                }) }}

                {{ forms.lightswitchField({
                    label: 'templates.mcp.options.tool-detalles-de-entrada'|t('pragmatic-web-toolkit'),
                    name: 'enableDetailsTool',
                    on: settings.enableDetailsTool,
                    instructions: 'templates.mcp.options.permite-obtener-informaci-n-detallada-de-entradas-espec-ficas'|t('pragmatic-web-toolkit')
                }) }}

                <div class="mcp-warning">
                    <strong>{{ 'templates.mcp.options.precauci-n'|t('pragmatic-web-toolkit') }}</strong>
                    {{ 'templates.mcp.options.las-consultas-personalizadas-permiten-ejecutar-queries-complejas'|t('pragmatic-web-toolkit') }}
                </div>

                {{ forms.lightswitchField({
                    label: 'templates.mcp.options.tool-consultas-personalizadas'|t('pragmatic-web-toolkit'),
                    name: 'enableCustomQueries',
                    on: settings.enableCustomQueries,
                    instructions: 'templates.mcp.options.permite-ejecutar-consultas-personalizadas-definidas-en-la-config'|t('pragmatic-web-toolkit')
                }) }}
            </section>

            <section class="mcp-settings-section">
                <h2>{{ 'templates.mcp.options.l-mites-de-seguridad'|t('pragmatic-web-toolkit') }}</h2>
                <p>{{ 'templates.mcp.options.define-l-mites-para-proteger-el-rendimiento-del-servidor'|t('pragmatic-web-toolkit') }}</p>

                {{ forms.textField({
                    label: 'templates.mcp.options.m-ximo-de-resultados'|t('pragmatic-web-toolkit'),
                    name: 'maxResults',
                    value: settings.maxResults,
                    type: 'number',
                    instructions: 'templates.mcp.options.n-mero-m-ximo-de-resultados-que-puede-retornar-cualquier-consult'|t('pragmatic-web-toolkit'),
                    min: 1,
                    max: 1000
                }) }}

                {{ forms.textField({
                    label: 'templates.mcp.options.complejidad-m-xima-de-query'|t('pragmatic-web-toolkit'),
                    name: 'maxQueryComplexity',
                    value: settings.maxQueryComplexity,
                    type: 'number',
                    instructions: 'templates.mcp.options.nivel-m-ximo-de-complejidad-permitido-para-consultas-1-10'|t('pragmatic-web-toolkit'),
                    min: 1,
                    max: 10
                }) }}
            </section>

            <section class="mcp-settings-section">
                <h2>{{ 'templates.mcp.options.campos-personalizados'|t('pragmatic-web-toolkit') }}</h2>
                <p>{{ 'templates.mcp.options.define-qu-campos-personalizados-estar-n-disponibles-en-las-respu'|t('pragmatic-web-toolkit') }}</p>

                {{ forms.editableTableField({
                    label: 'templates.mcp.options.campos-a-exponer'|t('pragmatic-web-toolkit'),
                    name: 'exposedFields',
                    instructions: 'templates.mcp.options.lista-los-handles-de-los-campos-personalizados-que-quieres-inclu'|t('pragmatic-web-toolkit'),
                    cols: {
                        field: {
                            heading: 'templates.mcp.options.handle-del-campo'|t('pragmatic-web-toolkit'),
                            type: 'singleline',
                            width: '100%'
                        }
                    },
                    rows: settings.exposedFields|map(field => {field: field}),
                    addRowLabel: 'templates.mcp.options.agregar-campo'|t('pragmatic-web-toolkit')
                }) }}

                <div class="mcp-info">
                    <strong>{{ 'templates.mcp.options.tip'|t('pragmatic-web-toolkit') }}</strong>
                    {{ 'templates.mcp.options.puedes-usar-handles-como'|t('pragmatic-web-toolkit') }}
                    <code>myCustomField</code>, <code>richTextContent</code>, <code>featuredImage</code>.
                </div>
            </section>

            <section class="mcp-settings-section">
                <h2>{{ 'templates.mcp.options.cache'|t('pragmatic-web-toolkit') }}</h2>
                <p>{{ 'templates.mcp.options.mejora-el-rendimiento-almacenando-resultados-en-cache'|t('pragmatic-web-toolkit') }}</p>
                <fieldset>

                {{ forms.lightswitchField({
                    label: 'templates.mcp.options.habilitar-cache'|t('pragmatic-web-toolkit'),
                    name: 'enableCache',
                    on: settings.enableCache,
                    instructions: 'templates.mcp.options.activa-el-cache-para-respuestas-de-recursos'|t('pragmatic-web-toolkit')
                }) }}

                {{ forms.textField({
                    label: 'templates.mcp.options.duraci-n-del-cache-segundos'|t('pragmatic-web-toolkit'),
                    name: 'cacheDuration',
                    value: settings.cacheDuration,
                    type: 'number',
                    instructions: 'templates.mcp.options.tiempo-que-los-recursos-permanecer-n-en-cache-recomendado-3600-1'|t('pragmatic-web-toolkit'),
                    disabled: not settings.enableCache
                }) }}
                </fieldset>
            </section>

            <section class="mcp-settings-section">
                <h2>{{ 'templates.mcp.options.seguridad-avanzada-opcional'|t('pragmatic-web-toolkit') }}</h2>
                <p>{{ 'templates.mcp.options.configuraci-n-adicional-de-seguridad-para-el-acceso-al-mcp'|t('pragmatic-web-toolkit') }}</p>
                <fieldset>

                {{ forms.passwordField({
                    label: 'templates.mcp.options.token-de-acceso'|t('pragmatic-web-toolkit'),
                    name: 'accessToken',
                    value: settings.accessToken,
                    instructions: 'templates.mcp.options.token-opcional-para-autenticar-peticiones-al-mcp-dejar-vac-o-par'|t('pragmatic-web-toolkit'),
                    placeholder: 'templates.mcp.options.genera-un-token-seguro'|t('pragmatic-web-toolkit')
                }) }}

                {{ forms.textareaField({
                    label: 'templates.mcp.options.ips-permitidas'|t('pragmatic-web-toolkit'),
                    name: 'allowedIpAddresses',
                    value: settings.allowedIpAddresses|join("\n"),
                    instructions: 'templates.mcp.options.lista-de-direcciones-ip-permitidas-una-por-l-nea-dejar-vac-o-par'|t('pragmatic-web-toolkit'),
                    placeholder: "192.168.1.1\n10.0.0.1",
                    rows: 4
                }) }}
                </fieldset>
            </section>
        </div>

        <button type="submit" class="btn submit">{{ 'Save'|t('app') }}</button>
        </fieldset>
    </form>
{% endblock %}

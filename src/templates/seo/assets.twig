{% extends 'pragmatic-web-toolkit/seo/_layout' %}
{% import '_includes/forms' as forms %}

{% set title = 'Assets'|t('pragmatic-web-toolkit') %}
{% set selectedTab = 'assets' %}

{% set crumbs = [
  { label: 'SEO', url: url('pragmatic-toolkit/seo') },
  { label: 'Assets'|t('pragmatic-web-toolkit'), url: url('pragmatic-toolkit/seo/assets', { site: selectedSite.handle }) },
] %}

{% block sidebar %}
  <nav aria-label="{{ 'Sections'|t('pragmatic-web-toolkit') }}">
    <ul class="nav">
      <li>
        <a class="{{ not sectionId and not isNoSection ? 'sel' : '' }}" href="{{ url('pragmatic-toolkit/seo/assets', { site: selectedSite.handle, sort: sort, dir: dir }) }}">
          {{ 'All sections'|t('pragmatic-web-toolkit') }}
        </a>
      </li>
      {% if noSectionCount > 0 or isNoSection %}
        <li>
          <a class="{{ isNoSection ? 'sel' : '' }}" href="{{ url('pragmatic-toolkit/seo/assets', { site: selectedSite.handle, section: 'none', sort: sort, dir: dir }) }}">
            {{ 'No section'|t('pragmatic-web-toolkit') }} <span class="light" style="margin-left: 2px;">({{ noSectionCount }})</span>
          </a>
        </li>
      {% endif %}
      {% if sections|length %}
        <li class="heading"><span>{{ 'Sections'|t('pragmatic-web-toolkit') }}</span></li>
        {% for section in sections %}
          <li>
            <a class="{{ section.id == sectionId ? 'sel' : '' }}" href="{{ url('pragmatic-toolkit/seo/assets', { site: selectedSite.handle, section: section.id, sort: sort, dir: dir }) }}">
              {{ section.name }} <span class="light" style="margin-left: 2px;">({{ section.count }})</span>
            </a>
          </li>
        {% endfor %}
      {% endif %}
    </ul>
  </nav>
{% endblock %}

{% block content %}
  {% css %}
    .img-preview-wrap { position: relative; display: inline-block; }
    .img-preview-popover {
      display: none;
      position: absolute;
      left: 100%;
      top: 50%;
      transform: translateY(-50%);
      margin-left: 10px;
      background: #fff;
      border: 1px solid #d1d5db;
      border-radius: 8px;
      box-shadow: 0 4px 16px rgba(0,0,0,0.12);
      padding: 6px;
      z-index: 100;
      pointer-events: none;
      white-space: nowrap;
    }
    .img-preview-popover img {
      display: block;
      max-width: 200px;
      max-height: 200px;
      width: auto;
      height: auto;
      border-radius: 4px;
    }
    .img-preview-wrap:hover .img-preview-popover { display: block; }
    .pwt-row-actions {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
    }
    .pwt-ai-trigger svg {
      display: block;
      width: 16px;
      height: 16px;
      fill: currentColor;
    }
    .pwt-ai-controls {
      display: flex;
      flex-direction: column;
      gap: 10px;
      min-width: 280px;
    }
    .pwt-batch-actions {
      width: 100%;
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      align-items: center;
      justify-content: flex-end;
    }
    .pwt-batch-actions-right {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      align-items: center;
      justify-content: flex-end;
    }
    .btn-ai {
      display: flex;
      gap: 8px;
      align-items: center;
    }
    .btn-ai svg {
      display: block;
      width: 16px;
      height: 16px;
      fill: currentColor;
    }
  {% endcss %}

  {% if not canManageAssets %}
    {% include 'pragmatic-web-toolkit/_partials/tier-lock' with {
      tier: 'pro',
      heading: 'Requires Pro version',
      message: 'SEO asset metadata management is available in Pro.'
    } %}
  {% endif %}

  {% if rows is not empty %}
    <div class="flex justify-end" style="margin-bottom: 16px;">
      <div class="pwt-batch-actions">
        <div class="pwt-batch-actions-right">
          <button type="button" class="btn btn-ai" id="generate-selected-assets">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 30 30" aria-hidden="true">
              <path d="M14.217,19.707l-1.112,2.547c-0.427,0.979-1.782,0.979-2.21,0l-1.112-2.547c-0.99-2.267-2.771-4.071-4.993-5.057L1.73,13.292c-0.973-0.432-0.973-1.848,0-2.28l2.965-1.316C6.974,8.684,8.787,6.813,9.76,4.47l1.126-2.714c0.418-1.007,1.81-1.007,2.228,0L14.24,4.47c0.973,2.344,2.786,4.215,5.065,5.226l2.965,1.316c0.973,0.432,0.973,1.848,0,2.28l-3.061,1.359C16.988,15.637,15.206,17.441,14.217,19.707z"></path>
              <path d="M24.481,27.796l-0.339,0.777c-0.248,0.569-1.036,0.569-1.284,0l-0.339-0.777c-0.604-1.385-1.693-2.488-3.051-3.092l-1.044-0.464c-0.565-0.251-0.565-1.072,0-1.323l0.986-0.438c1.393-0.619,2.501-1.763,3.095-3.195l0.348-0.84c0.243-0.585,1.052-0.585,1.294,0l0.348,0.84c0.594,1.432,1.702,2.576,3.095,3.195l0.986,0.438c0.565,0.251,0.565,1.072,0,1.323l-1.044,0.464C26.174,25.308,25.085,26.411,24.481,27.796z"></path>
            </svg>
            {{ 'crear_prompt'|t('pragmatic-web-toolkit') }}
          </button>
          <button type="button" class="btn" id="export-assets-json">{{ 'Export JSON'|t('pragmatic-web-toolkit') }}</button>
          <button type="button" class="btn" id="import-assets-json">{{ 'Import JSON'|t('pragmatic-web-toolkit') }}</button>
          <button type="button" class="btn submit" id="save-all-assets">{{ 'Save all'|t('pragmatic-web-toolkit') }}</button>
        </div>
      </div>
    </div>
  {% endif %}

  {% if rows is empty %}
    <p>{{ 'No assets to show with the current filter.'|t('pragmatic-web-toolkit') }}</p>
  {% else %}
    <fieldset {{ not canManageAssets ? 'disabled' : '' }}>
      <table class="data fullwidth">
        {% set usedNextDir = sort == 'used' and dir == 'desc' ? 'asc' : 'desc' %}
        {% set assetNextDir = sort == 'asset' and dir == 'asc' ? 'desc' : 'asc' %}
        <thead>
          <tr>
            <th style="width:30px;">
              <input type="checkbox" id="select-all-assets" title="{{ 'Select all rows'|t('pragmatic-web-toolkit') }}">
            </th>
            <th>
              <a href="{{ url('pragmatic-toolkit/seo/assets', { site: selectedSite.handle, section: sectionParam ?? null, sort: 'used', dir: usedNextDir }) }}">
                {{ 'Used'|t('pragmatic-web-toolkit') }}
              </a>
            </th>
            <th>
              <a href="{{ url('pragmatic-toolkit/seo/assets', { site: selectedSite.handle, section: sectionParam ?? null, sort: 'asset', dir: assetNextDir }) }}">
                {{ 'Assets'|t('pragmatic-web-toolkit') }}
              </a>
            </th>
            <th>{{ 'AI indications'|t('pragmatic-web-toolkit') }}</th>
            <th>{{ 'Title'|t('pragmatic-web-toolkit') }}</th>
            <th>{{ 'Alt'|t('pragmatic-web-toolkit') }}</th>
            <th>{{ 'Save'|t('pragmatic-web-toolkit') }}</th>
          </tr>
        </thead>
        <tbody>
          {% for row in rows %}
            {% set asset = row.asset %}
            {% set rowFormId = 'save-asset-' ~ asset.id %}
            <tr>
              <td>
                <input type="checkbox" class="js-asset-select" value="{{ asset.id }}" data-site-id="{{ asset.siteId }}">
              </td>
              <td>
                {% if row.isUsed %}
                  <span class="status enabled" title="{{ 'Used'|t('pragmatic-web-toolkit') }}"></span>
                {% else %}
                  <span class="status" title="{{ 'Unused'|t('pragmatic-web-toolkit') }}"></span>
                {% endif %}
              </td>
              <td>
                <span class="img-preview-wrap">
                  <a href="{{ asset.cpEditUrl }}" class="js-open-asset" data-asset-id="{{ asset.id }}" data-site-id="{{ asset.siteId }}">{{ asset.filename }}</a>
                {% if asset.url %}
                    <span class="img-preview-popover">
                      <img src="{{ asset.url }}" alt="{{ asset.title }}" loading="lazy">
                    </span>
                  {% endif %}
                </span>
                <br>
                <code>ID {{ asset.id }}</code>
                {% if row.entryLink %}
                  <span style="margin-left: 8px;">
                    <a
                      href="{{ row.entryLink.cpEditUrl }}"
                      class="js-open-entry"
                      data-entry-id="{{ row.entryLink.entryId }}"
                      data-site-id="{{ selectedSiteId ?? selectedSite.id }}"
                    >
                      {{ row.entryLink.title }}
                    </a>
                    {% if row.entryLink.extraCount > 0 %}
                      <span class="light">(+{{ row.entryLink.extraCount }})</span>
                    {% endif %}
                  </span>
                {% endif %}
              </td>
              <td>
                <textarea
                  class="text fullwidth"
                  form="{{ rowFormId }}"
                  name="assets[{{ asset.id }}][fields][__ai_instructions__]"
                  rows="4"
                  placeholder="{{ 'Optional stored instructions for this asset AI prompt.'|t('pragmatic-web-toolkit') }}"
                >{{ row.fieldValues.__ai_instructions__ ?? '' }}</textarea>
              </td>
              <td>
                <textarea
                  class="text fullwidth"
                  form="{{ rowFormId }}"
                  name="assets[{{ asset.id }}][title]"
                  rows="3"
                >{{ asset.title }}</textarea>
              </td>
              <td>
                <textarea
                  class="text fullwidth"
                  form="{{ rowFormId }}"
                  name="assets[{{ asset.id }}][fields][__native_alt__]"
                  rows="3"
                >{{ row.fieldValues.__native_alt__ ?? '' }}</textarea>
              </td>
              <td>
                <div class="pwt-row-actions">
                  <button type="submit" class="btn submit" form="{{ rowFormId }}" name="saveRowId" value="{{ asset.id }}">{{ 'Save row'|t('pragmatic-web-toolkit') }}</button>
                </div>
              </td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </fieldset>

    {% for row in rows %}
      {% set asset = row.asset %}
      {% set rowFormId = 'save-asset-' ~ asset.id %}
      <form id="{{ rowFormId }}" method="post" accept-charset="UTF-8">
        {{ csrfInput() }}
        {{ actionInput('pragmatic-web-toolkit/seo/save-assets') }}
        <input type="hidden" name="site" value="{{ selectedSiteId ?? selectedSite.id }}">
        {{ redirectInput(url('pragmatic-toolkit/seo/assets', {
          site: selectedSite.handle,
          section: sectionParam ?? null,
          sort: sort,
          dir: dir
        })) }}
      </form>
    {% endfor %}

    <form id="save-all-assets-form" method="post" accept-charset="UTF-8" style="display:none;">
      {{ csrfInput() }}
      {{ actionInput('pragmatic-web-toolkit/seo/save-assets') }}
      <input type="hidden" name="site" value="{{ selectedSiteId ?? selectedSite.id }}">
      {{ redirectInput(url('pragmatic-toolkit/seo/assets', {
        site: selectedSite.handle,
        section: sectionParam ?? null,
        sort: sort,
        dir: dir
      })) }}
    </form>
  {% endif %}
{% endblock %}

{% js %}
  const ASSETS_SITE_ID = {{ (selectedSiteId ?? selectedSite.id)|json_encode|raw }};

  function getSelectedAssetIds() {
    return Array.from(document.querySelectorAll('.js-asset-select:checked'))
      .map((checkbox) => parseInt(checkbox.value || '0', 10))
      .filter((id) => id > 0);
  }

  function requireSelectedAssets() {
    const ids = getSelectedAssetIds();
    if (!ids.length) {
      Craft.cp.displayError('{{ "Select at least one asset."|t("pragmatic-web-toolkit")|e("js") }}');
      return null;
    }

    return ids;
  }

  function downloadJson(filename, payload) {
    const blob = new Blob([payload], { type: 'application/json;charset=utf-8' });
    const url = URL.createObjectURL(blob);
    const link = document.createElement('a');
    link.href = url;
    link.download = filename;
    document.body.appendChild(link);
    link.click();
    link.remove();
    URL.revokeObjectURL(url);
  }

  function openExportJsonModal(filename, jsonText) {
    const modalEl = document.createElement('div');
    modalEl.className = 'modal fitted pwt-unified-modal pwt-unified-modal--large';
    modalEl.innerHTML =
      '<div class="body"><div class="content">' +
        '<h2 style="margin-top:0;">{{ "Export JSON"|t("pragmatic-web-toolkit")|e("js") }}</h2>' +
        '<textarea class="text fullwidth js-export-json-text" rows="24" readonly style="font-family: Menlo, Monaco, Consolas, monospace; min-height: 72vh;">' + Craft.escapeHtml(jsonText) + '</textarea>' +
      '</div></div>' +
      '<div class="footer"><div class="buttons">' +
        '<button type="button" class="btn" data-action="copy">{{ "Copy JSON"|t("pragmatic-web-toolkit")|e("js") }}</button>' +
        '<button type="button" class="btn" data-action="download">{{ "Download JSON"|t("pragmatic-web-toolkit")|e("js") }}</button>' +
        '<button type="button" class="btn" data-action="close">{{ "Close"|t("pragmatic-web-toolkit")|e("js") }}</button>' +
      '</div></div>';

    const modal = new Garnish.Modal(modalEl, {
      autoShow: true,
      onHide: function() { modal.destroy(); }
    });
    const textarea = modalEl.querySelector('.js-export-json-text');
    const copyBtn = modalEl.querySelector('[data-action="copy"]');
    const downloadBtn = modalEl.querySelector('[data-action="download"]');
    const closeBtn = modalEl.querySelector('[data-action="close"]');

    if (textarea) {
      textarea.focus();
      textarea.select();
    }

    copyBtn?.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(jsonText);
        Craft.cp.displayNotice('{{ "JSON copied."|t("pragmatic-web-toolkit")|e("js") }}');
      } catch (error) {
        Craft.cp.displayError('{{ "Could not copy automatically."|t("pragmatic-web-toolkit")|e("js") }}');
      }
    });
    downloadBtn?.addEventListener('click', () => downloadJson(filename, jsonText));
    closeBtn?.addEventListener('click', () => modal.hide());
  }

  function openImportJsonModal() {
    const modalEl = document.createElement('div');
    modalEl.className = 'modal fitted pwt-unified-modal pwt-unified-modal--large';
    modalEl.innerHTML =
      '<div class="body"><div class="content">' +
        '<h2 style="margin-top:0;">{{ "Import JSON"|t("pragmatic-web-toolkit")|e("js") }}</h2>' +
        '<p>{{ "Paste JSON or upload a .json file. Preview is optional."|t("pragmatic-web-toolkit")|e("js") }}</p>' +
        '<textarea class="text fullwidth js-import-json-text" rows="16" style="min-height: 38vh;" placeholder="{{ "Paste JSON here"|t("pragmatic-web-toolkit")|e("js") }}"></textarea>' +
        '<div style="margin-top:10px;"><input type="file" class="js-import-json-file" accept=".json,application/json"></div>' +
        '<div class="js-import-preview" style="margin-top:14px; max-height:28vh; overflow:auto;"></div>' +
      '</div></div>' +
      '<div class="footer"><div class="buttons">' +
        '<button type="button" class="btn" id="pwt-import-preview-btn">{{ "Preview import"|t("pragmatic-web-toolkit")|e("js") }}</button>' +
        '<button type="button" class="btn" id="pwt-import-apply-btn">{{ "Apply import"|t("pragmatic-web-toolkit")|e("js") }}</button>' +
        '<button type="button" class="btn" id="pwt-import-close-btn">{{ "Close"|t("pragmatic-web-toolkit")|e("js") }}</button>' +
      '</div></div>';

    const modal = new Garnish.Modal(modalEl, {
      autoShow: true,
      onHide: function() { modal.destroy(); }
    });

    const textArea = modalEl.querySelector('.js-import-json-text');
    const fileInput = modalEl.querySelector('.js-import-json-file');
    const previewEl = modalEl.querySelector('.js-import-preview');
    const previewBtn = modalEl.querySelector('#pwt-import-preview-btn');
    const applyBtn = modalEl.querySelector('#pwt-import-apply-btn');
    const closeBtn = modalEl.querySelector('#pwt-import-close-btn');
    let matchedChanged = [];
    let previewToken = '';
    let importToken = '';
    let importPollTimer = null;

    const setPreviewHtml = (html) => {
      if (previewEl) {
        previewEl.innerHTML = html;
      }
    };

    const readJsonText = async () => {
      const direct = (textArea?.value || '').trim();
      if (direct) {
        return direct;
      }

      const file = fileInput?.files?.[0];
      if (file) {
        return (await file.text()).trim();
      }

      return '';
    };

    const stopImportPolling = () => {
      if (importPollTimer) {
        clearInterval(importPollTimer);
        importPollTimer = null;
      }
    };

    const renderImportStatus = (status) => {
      const total = parseInt(status.total || 0, 10);
      const processed = parseInt(status.processed || 0, 10);
      const applied = parseInt(status.applied || 0, 10);
      const skipped = total > applied ? total - applied : 0;
      const state = String(status.state || 'queued');
      const errors = Array.isArray(status.errors) ? status.errors : [];
      const percent = total > 0 ? Math.round((processed / total) * 100) : 0;
      const color = state === 'failed' ? '#dc2626' : '#2563eb';

      setPreviewHtml(
        '<p><strong>{{ "Import status"|t("pragmatic-web-toolkit")|e("js") }}</strong></p>' +
        '<p>{{ "State"|t("pragmatic-web-toolkit")|e("js") }}: ' + Craft.escapeHtml(state) + '</p>' +
        '<p>{{ "Progress"|t("pragmatic-web-toolkit")|e("js") }}: ' + processed + '/' + total + ' (' + percent + '%)</p>' +
        '<div style="height:8px;background:#e5e7eb;border-radius:999px;overflow:hidden;margin:8px 0 10px;">' +
          '<div style="height:100%;width:' + Math.max(0, Math.min(100, percent)) + '%;background:' + color + ';"></div>' +
        '</div>' +
        '<p>{{ "Applied"|t("pragmatic-web-toolkit")|e("js") }}: ' + applied + ' · ' +
        '{{ "Skipped"|t("pragmatic-web-toolkit")|e("js") }}: ' + skipped + '</p>' +
        (errors.length ? '<p class="error">{{ "Warnings"|t("pragmatic-web-toolkit")|e("js") }}: ' + Craft.escapeHtml(errors.join(' | ')) + '</p>' : '') +
        '<p class="light"><a href="' + ((typeof Craft.getCpUrl === "function") ? Craft.getCpUrl("utilities/queue-manager") : (((typeof Craft.getUrl === "function") ? Craft.getUrl("utilities/queue-manager") : "utilities/queue-manager"))) + '" target="_blank" rel="noopener">{{ "Open Queue Manager"|t("pragmatic-web-toolkit")|e("js") }}</a></p>'
      );
    };

    const pollImportStatus = async () => {
      if (!importToken) {
        return;
      }

      const response = await Craft.sendActionRequest('POST', 'pragmatic-web-toolkit/seo/import-assets-json-status', {
        data: {
          importToken: importToken,
        },
      });

      if (!response.data || !response.data.success || !response.data.status) {
        throw new Error(response.data && response.data.error ? response.data.error : '{{ "Could not load import status."|t("pragmatic-web-toolkit")|e("js") }}');
      }

      const status = response.data.status;
      renderImportStatus(status);

      if (status.state === 'completed' || status.state === 'failed') {
        stopImportPolling();
        applyBtn.disabled = true;
        previewBtn.disabled = false;
        if (status.state === 'completed') {
          Craft.cp.displayNotice('{{ "Import finished."|t("pragmatic-web-toolkit")|e("js") }}');
          window.setTimeout(() => window.location.reload(), 1200);
        } else {
          Craft.cp.displayError('{{ "Import failed."|t("pragmatic-web-toolkit")|e("js") }}');
        }
      }
    };

    const onPreviewClick = async () => {
      try {
        stopImportPolling();
        previewToken = '';
        importToken = '';
        previewBtn.disabled = true;
        applyBtn.disabled = true;
        const jsonText = await readJsonText();
        if (!jsonText) {
          throw new Error('{{ "Paste JSON or select a file."|t("pragmatic-web-toolkit")|e("js") }}');
        }

        const response = await Craft.sendActionRequest('POST', 'pragmatic-web-toolkit/seo/import-assets-json-preview', {
          data: {
            siteId: ASSETS_SITE_ID,
            jsonText: jsonText,
          },
        });

        if (!response.data || !response.data.success) {
          throw new Error(response.data && response.data.error ? response.data.error : '{{ "Could not preview import."|t("pragmatic-web-toolkit")|e("js") }}');
        }

        previewToken = String(response.data.previewToken || '');
        const preview = response.data.preview || {};
        matchedChanged = Array.isArray(preview.matchedChanged) ? preview.matchedChanged : [];
        const totals = preview.totals || {};
        const changed = totals.matchedChanged || 0;
        const unchanged = totals.matchedUnchanged || 0;
        const skipped = totals.skippedUnmatched || 0;
        const invalid = totals.invalidItems || 0;

        setPreviewHtml(
          '<p><strong>{{ "Preview"|t("pragmatic-web-toolkit")|e("js") }}</strong></p>' +
          '<p>{{ "Changed"|t("pragmatic-web-toolkit")|e("js") }}: ' + changed + ' · ' +
          '{{ "Unchanged"|t("pragmatic-web-toolkit")|e("js") }}: ' + unchanged + ' · ' +
          '{{ "Skipped"|t("pragmatic-web-toolkit")|e("js") }}: ' + skipped + ' · ' +
          '{{ "Invalid"|t("pragmatic-web-toolkit")|e("js") }}: ' + invalid + '</p>'
        );

        applyBtn.disabled = false;
      } catch (error) {
        setPreviewHtml('<p class="error">' + Craft.escapeHtml(error.message || '{{ "Could not preview import."|t("pragmatic-web-toolkit")|e("js") }}') + '</p>');
        applyBtn.disabled = true;
      } finally {
        previewBtn.disabled = false;
      }
    };

    const onApplyClick = async () => {
      try {
        const jsonText = await readJsonText();
        const hasDirectJson = !!jsonText;
        if (!matchedChanged.length && !hasDirectJson) {
          Craft.cp.displayNotice('{{ "Paste JSON or run Preview first."|t("pragmatic-web-toolkit")|e("js") }}');
          return;
        }

        applyBtn.disabled = true;
        previewBtn.disabled = true;
        setPreviewHtml('<p>{{ "Queueing import job..."|t("pragmatic-web-toolkit")|e("js") }}</p>');
        const fallbackItems = matchedChanged.map((item) => ({
          assetId: parseInt(item.assetId || 0, 10),
          after: item && item.after ? item.after : {},
        })).filter((item) => item.assetId > 0);
        const applyData = {
          siteId: ASSETS_SITE_ID,
        };
        if (previewToken) {
          applyData.previewToken = previewToken;
        }
        if (fallbackItems.length) {
          applyData.itemsJson = JSON.stringify(fallbackItems);
        }
        if (hasDirectJson) {
          applyData.jsonText = jsonText;
        }
        const response = await Craft.sendActionRequest('POST', 'pragmatic-web-toolkit/seo/import-assets-json-apply', {
          data: applyData,
        });

        if (!response.data || !response.data.success) {
          throw new Error(response.data && response.data.error ? response.data.error : '{{ "Could not apply import."|t("pragmatic-web-toolkit")|e("js") }}');
        }

        Craft.cp.displayNotice('{{ "Import queued."|t("pragmatic-web-toolkit")|e("js") }}');
        importToken = String(response.data.importToken || '');
        if (!importToken) {
          throw new Error('{{ "Import queued but missing status token."|t("pragmatic-web-toolkit")|e("js") }}');
        }

        await pollImportStatus();
        importPollTimer = window.setInterval(async () => {
          try {
            await pollImportStatus();
          } catch (error) {
            stopImportPolling();
            previewBtn.disabled = false;
            applyBtn.disabled = false;
            Craft.cp.displayError(error.message || '{{ "Could not load import status."|t("pragmatic-web-toolkit")|e("js") }}');
          }
        }, 1500);
      } catch (error) {
        previewBtn.disabled = false;
        applyBtn.disabled = false;
        Craft.cp.displayError(error.message || '{{ "Could not apply import."|t("pragmatic-web-toolkit")|e("js") }}');
      }
    };

    if (!previewBtn || !applyBtn || !closeBtn) {
      Craft.cp.displayError('{{ "Import modal controls could not be initialized."|t("pragmatic-web-toolkit")|e("js") }}');
      return;
    }

    applyBtn.disabled = false;
    const syncApplyEnabled = () => {
      if (previewBtn.disabled) {
        return;
      }
      const hasText = !!((textArea?.value || '').trim());
      const hasFile = !!(fileInput?.files && fileInput.files.length);
      applyBtn.disabled = !(hasText || hasFile || matchedChanged.length > 0);
    };

    textArea?.addEventListener('input', syncApplyEnabled);
    fileInput?.addEventListener('change', syncApplyEnabled);
    previewBtn.addEventListener('click', onPreviewClick);
    applyBtn.addEventListener('click', onApplyClick);
    syncApplyEnabled();

    closeBtn.addEventListener('click', () => {
      stopImportPolling();
      modal.hide();
    });
  }

  function openManualPromptModal(title, promptText) {
    const modalEl = document.createElement('div');
    modalEl.className = 'modal fitted pwt-unified-modal pwt-unified-modal--large';
    modalEl.innerHTML =
      '<div class="body">' +
        '<div class="content">' +
          '<h2 style="margin-top:0;">' + title + '</h2>' +
          '<p>{% if gemFeatureEnabled %}{{ "Paste this prompt into a chat that uses your Gemini Gem. Ask it to return only the requested JSON."|t("pragmatic-web-toolkit")|e("js") }}{% else %}{{ "Paste this single prompt directly into Gemini. It already includes the strategy instructions. Ask it to return only the requested JSON."|t("pragmatic-web-toolkit")|e("js") }}{% endif %}</p>' +
          '<textarea class="text fullwidth js-manual-prompt-output" rows="18" readonly style="font-family: Menlo, Monaco, Consolas, monospace;">' + Craft.escapeHtml(promptText) + '</textarea>' +
        '</div>' +
      '</div>' +
      '<div class="footer">' +
        '<div class="btngroup">' +
          '<button type="button" class="btn" data-action="copy">{{ "Copy prompt"|t("pragmatic-web-toolkit")|e("js") }}</button>' +
          '<button type="button" class="btn" data-action="close">{{ "Close"|t("pragmatic-web-toolkit")|e("js") }}</button>' +
        '</div>' +
      '</div>';

    const modal = new Garnish.Modal(modalEl, {
      autoShow: true,
      onHide: function() { modal.destroy(); }
    });
    const outputField = modalEl.querySelector('.js-manual-prompt-output');
    const copyBtn = modalEl.querySelector('[data-action="copy"]');
    const closeBtn = modalEl.querySelector('[data-action="close"]');
    if (outputField) {
      outputField.focus();
      outputField.select();
    }

    if (copyBtn) {
      copyBtn.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText(promptText);
          Craft.cp.displayNotice('{{ "Prompt copied."|t("pragmatic-web-toolkit")|e("js") }}');
        } catch (error) {
          if (outputField) {
            outputField.focus();
            outputField.select();
          }
          Craft.cp.displayError('{{ "Could not copy automatically. Copy it manually from the textarea."|t("pragmatic-web-toolkit")|e("js") }}');
        }
      });
    }
    if (closeBtn) {
      closeBtn.addEventListener('click', () => modal.hide());
    }
  }

  function submitAllAssetRows() {
    const rowControls = Array.from(document.querySelectorAll('[form^="save-asset-"][name]'));
    if (!rowControls.length) {
      return;
    }

    const bulkForm = document.getElementById('save-all-assets-form');
    if (!bulkForm) {
      return;
    }

    bulkForm.querySelectorAll('.js-bulk-clone').forEach((field) => field.remove());

    rowControls.forEach((control) => {
      if (control.disabled || !control.name) {
        return;
      }

      if (control.tagName === 'BUTTON' || control.type === 'submit' || control.name === 'saveRowId') {
        return;
      }

      if ((control.type === 'checkbox' || control.type === 'radio') && !control.checked) {
        return;
      }

      const clone = document.createElement('input');
      clone.type = 'hidden';
      clone.name = control.name;
      clone.value = control.value;
      clone.className = 'js-bulk-clone';
      bulkForm.appendChild(clone);
    });

    bulkForm.submit();
  }

  const selectAllAssets = document.getElementById('select-all-assets');
  const rowSelectionCheckboxes = Array.from(document.querySelectorAll('.js-asset-select'));
  const saveAllButton = document.getElementById('save-all-assets');
  const generateSelectedButton = document.getElementById('generate-selected-assets');
  const exportJsonButton = document.getElementById('export-assets-json');
  const importJsonButton = document.getElementById('import-assets-json');

  const syncSelectAllState = () => {
    if (!selectAllAssets) {
      return;
    }
    const total = rowSelectionCheckboxes.length;
    const checked = rowSelectionCheckboxes.filter((box) => box.checked).length;
    selectAllAssets.checked = total > 0 && checked === total;
    selectAllAssets.indeterminate = checked > 0 && checked < total;
  };

  if (selectAllAssets) {
    selectAllAssets.addEventListener('change', () => {
      rowSelectionCheckboxes.forEach((box) => {
        box.checked = selectAllAssets.checked;
      });
      syncSelectAllState();
    });
  }
  rowSelectionCheckboxes.forEach((box) => box.addEventListener('change', syncSelectAllState));
  syncSelectAllState();

  if (saveAllButton) {
    saveAllButton.addEventListener('click', () => {
      submitAllAssetRows();
    });
  }

  if (generateSelectedButton) {
    generateSelectedButton.addEventListener('click', async () => {
      try {
        const assetIds = requireSelectedAssets();
        if (!assetIds) {
          return;
        }

        const response = await Craft.sendActionRequest('POST', 'pragmatic-web-toolkit/seo/generate-asset-metadata-batch', {
          data: {
            siteId: ASSETS_SITE_ID,
            assetIds: assetIds,
          },
        });
        if (!response.data || !response.data.success || !response.data.manualPrompt) {
          throw new Error(response.data && response.data.error ? response.data.error : '{{ "Could not generate batch prompt."|t("pragmatic-web-toolkit")|e("js") }}');
        }

        openManualPromptModal('{{ "Batch Asset AI Prompt"|t("pragmatic-web-toolkit")|e("js") }}', response.data.manualPrompt);
      } catch (error) {
        Craft.cp.displayError(error.message || '{{ "Could not generate batch prompt."|t("pragmatic-web-toolkit")|e("js") }}');
      }
    });
  }

  if (exportJsonButton) {
    exportJsonButton.addEventListener('click', async () => {
      try {
        const assetIds = requireSelectedAssets();
        if (!assetIds) {
          return;
        }

        const response = await Craft.sendActionRequest('POST', 'pragmatic-web-toolkit/seo/export-assets-json', {
          data: {
            siteId: ASSETS_SITE_ID,
            assetIds: assetIds,
          },
        });
        if (!response.data || !response.data.success || !response.data.bundle) {
          throw new Error(response.data && response.data.error ? response.data.error : '{{ "Could not export JSON."|t("pragmatic-web-toolkit")|e("js") }}');
        }

        const jsonText = JSON.stringify(response.data.bundle, null, 2);
        const filename = response.data.filename || 'seo-assets-export.json';
        openExportJsonModal(filename, jsonText);
      } catch (error) {
        Craft.cp.displayError(error.message || '{{ "Could not export JSON."|t("pragmatic-web-toolkit")|e("js") }}');
      }
    });
  }

  if (importJsonButton) {
    importJsonButton.addEventListener('click', () => {
      openImportJsonModal();
    });
  }

  document.addEventListener('keydown', (event) => {
    const isSaveShortcut = (event.metaKey || event.ctrlKey) && String(event.key).toLowerCase() === 's';
    if (!isSaveShortcut) {
      return;
    }

    event.preventDefault();
    if (saveAllButton && !saveAllButton.disabled) {
      submitAllAssetRows();
    }
  });

  document.querySelectorAll('.js-open-asset').forEach((link) => {
    link.addEventListener('click', (event) => {
      if (typeof Craft === 'undefined' || typeof Craft.createElementEditor !== 'function') {
        return;
      }

      event.preventDefault();
      const assetId = parseInt(link.dataset.assetId || '0', 10);
      const siteId = parseInt(link.dataset.siteId || '0', 10);
      if (!assetId || !siteId) {
        return;
      }

      Craft.createElementEditor('craft\\elements\\Asset', $(link), {
        elementId: assetId,
        siteId: siteId,
      });
    });
  });

  document.querySelectorAll('.js-open-entry').forEach((link) => {
    link.addEventListener('click', (event) => {
      if (typeof Craft === 'undefined' || typeof Craft.createElementEditor !== 'function') {
        return;
      }

      event.preventDefault();
      const entryId = parseInt(link.dataset.entryId || '0', 10);
      const siteId = parseInt(link.dataset.siteId || '0', 10);
      if (!entryId || !siteId) {
        return;
      }

      Craft.createElementEditor('craft\\elements\\Entry', $(link), {
        elementId: entryId,
        siteId: siteId,
      });
    });
  });

{% endjs %}

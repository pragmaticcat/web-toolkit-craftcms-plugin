{% import '_includes/forms' as forms %}

{% set sectionName = sectionName ?? '' %}
{% set previewTitle = value.title ?: (element.title ?? '') %}
{% set previewDescription = value.description ?? '' %}
{% set previewUrl = element.url ?? '' %}
{% set previewId = field.handle ~ '-google-preview' %}
{% set previewCardId = field.handle ~ '-google-preview-card' %}
{% set titleInputSelector = '[name="' ~ field.handle ~ '[title]"]' %}
{% set descriptionInputSelector = '[name="' ~ field.handle ~ '[description]"]' %}

{% css %}
  .seo-entry-help {
    margin-top: -8px;
    margin-bottom: 14px;
    color: #606d7b;
    font-size: 12px;
  }
  .seo-entry-help summary {
    cursor: pointer;
    user-select: none;
    font-weight: 600;
  }
  .seo-entry-help p {
    margin: 6px 0 0;
    line-height: 1.45;
  }
  .seo-entry-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 18px;
  }
  .seo-entry-block {
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    padding: 14px;
    background: #fff;
  }
  .seo-entry-block h3 {
    margin: 0 0 4px;
    font-size: 15px;
  }
  .seo-entry-block > p {
    margin: 0 0 14px;
  }
  @media (max-width: 1023px) {
    .seo-entry-grid {
      grid-template-columns: 1fr;
    }
  }
{% endcss %}

<div class="seo-entry-grid">
  <section class="seo-entry-block">
    <h3>Contenido SEO</h3>
    <p class="light">Título y descripción que se usarán en buscadores y compartición social cuando esta entry no esté configurada para usar el SEO de su section.</p>

    <input type="hidden" name="{{ field.handle }}[useSectionDefaults]" value="0">
    {{ forms.lightswitchField({
      label: 'Prioriza valores de la section',
      name: field.handle ~ '[useSectionDefaults]',
      on: value.useSectionDefaults ?? true,
      value: 1,
    }) }}
    <details class="seo-entry-help">
      <summary>¿Qué hace este valor?</summary>
      <p>Cuando está activado, esta entry usa el SEO configurado en <code>SEO &gt; Sections</code> y se ignoran los campos específicos de title, description e image de esta entry. Si lo desactivas, entonces sí se usan los valores específicos de esta entry y, si faltan, se hace fallback a los valores globales del site.</p>
    </details>

    {{ forms.textField({
      label: 'Title',
      name: field.handle ~ '[title]',
      value: value.title,
      translatable: true,
      instructions: 'Puedes usar variables Twig, por ejemplo: {{ entry.title }} - Terapeuta Gestalt a {{ entry.municipis.one().title }}'
    }) }}
    <details class="seo-entry-help">
      <summary>¿Qué hace este valor?</summary>
      <p>Define el título SEO específico de esta entry. Solo se usará cuando desactives la opción de usar el SEO de la section. Si lo dejas vacío, se usará el título de la propia entry.</p>
    </details>

    {{ forms.textareaField({
      label: 'Description',
      name: field.handle ~ '[description]',
      value: value.description,
      rows: 3,
      translatable: true,
      instructions: 'Puedes usar variables Twig del entry actual para generar descripciones dinámicas.'
    }) }}
    <details class="seo-entry-help">
      <summary>¿Qué hace este valor?</summary>
      <p>Descripción SEO específica de esta entry. Solo se usará cuando desactives la opción de usar el SEO de la section. Si queda vacía, se usará la descripción por defecto global del site.</p>
    </details>

    {{ forms.elementSelectField({
      label: 'Image',
      id: field.handle ~ '-image',
      name: field.handle ~ '[imageId][]',
      elementType: 'craft\\elements\\Asset',
      elements: imageElement ? [imageElement] : [],
      limit: 1,
      sources: '*',
      criteria: { kind: 'image' },
      translatable: true,
    }) }}
    <details class="seo-entry-help">
      <summary>¿Qué hace este valor?</summary>
      <p>Define una imagen SEO específica para esta entry. Solo se usará cuando desactives la opción de usar el SEO de la section. Si no eliges ninguna, se usará la imagen por defecto global del site.</p>
    </details>
  </section>

  <section class="seo-entry-block" id="{{ previewCardId }}">
    <h3>Preview en Google</h3>
    <p class="light">Simulación visual de cómo podría mostrarse esta entry en un resultado de búsqueda.</p>

    {% include 'pragmatic-web-toolkit/seo/_google-search-preview' with {
      previewId: previewId,
      title: previewTitle,
      url: previewUrl,
      description: previewDescription,
      titleInputSelector: titleInputSelector,
      descriptionInputSelector: descriptionInputSelector,
      fallbackTitle: element.title ?? 'Título SEO de ejemplo',
      fallbackDescription: 'La descripción SEO aparecerá aquí cuando añadas contenido.',
    } only %}

    <details class="seo-entry-help">
      <summary>¿Cómo interpretar esta previsualización?</summary>
      <p>Es una referencia visual orientativa. Google puede reescribir el título o la descripción según la consulta del usuario y el contenido real de la página.</p>
    </details>
  </section>

  <section class="seo-entry-block">
    <h3>Sitemap</h3>
    <p class="light">Control de visibilidad de esta entry dentro del sitemap XML.</p>

    {{ forms.lightswitchField({
      label: 'Visible in sitemap',
      name: field.handle ~ '[sitemapEnabled]',
      on: value.sitemapEnabled is same as(false) ? false : true,
      value: 1
    }) }}
    <details class="seo-entry-help">
      <summary>¿Qué hace este valor?</summary>
      <p>Indica si esta entry debe incluirse en el sitemap XML del sitio.</p>
    </details>

    {{ forms.lightswitchField({
      label: 'Include images',
      name: field.handle ~ '[sitemapIncludeImages]',
      on: value.sitemapIncludeImages is same as(true),
      value: 1
    }) }}
    <details class="seo-entry-help">
      <summary>¿Qué hace este valor?</summary>
      <p>Incluye imágenes relacionadas en el sitemap para enriquecer la indexación visual. <a href="https://developers.google.com/search/docs/crawling-indexing/sitemaps/image-sitemaps" target="_blank" rel="noopener">Saber más</a></p>
    </details>
  </section>
</div>

{% js %}
  (() => {
    const previewCard = document.getElementById({{ previewCardId|json_encode|raw }});
    if (!previewCard) {
      return;
    }

    const sidebarSelectors = [
      '.context-pane',
      '#content-meta',
      '.element-editor .context-pane',
      '.entry-editor .context-pane',
    ];

    const findSidebar = () => {
      for (const selector of sidebarSelectors) {
        const el = document.querySelector(selector);
        if (el) {
          return el;
        }
      }
      return null;
    };

    const headingMatches = (text, candidates) => {
      const normalized = (text || '').trim().toLowerCase();
      return candidates.some((candidate) => normalized.includes(candidate));
    };

    const movePreviewCard = () => {
      const sidebar = findSidebar();
      if (!sidebar) {
        return false;
      }

      const headingSelectors = 'h1, h2, h3, h4, h5, h6, .heading, .pane-head';
      const headings = Array.from(sidebar.querySelectorAll(headingSelectors));
      let infoBlock = null;
      let statusOrChangesBlock = null;

      for (const heading of headings) {
        const text = heading.textContent || '';
        const container = heading.closest('.pane, .meta, .field, .card, .hud-element, section, .context-pane > div') || heading.parentElement;
        if (!container) {
          continue;
        }

        if (!infoBlock && headingMatches(text, ['identificación', 'identificacio', 'identification', 'info'])) {
          infoBlock = container;
        }

        if (headingMatches(text, ['estado', 'status', 'avisos sobre tus cambios', 'changes', 'warnings'])) {
          statusOrChangesBlock = container;
        }
      }

      if (infoBlock && infoBlock.parentElement) {
        infoBlock.parentElement.insertBefore(previewCard, infoBlock);
        return true;
      }

      if (statusOrChangesBlock && statusOrChangesBlock.parentElement) {
        statusOrChangesBlock.insertAdjacentElement('afterend', previewCard);
        return true;
      }

      sidebar.appendChild(previewCard);
      return true;
    };

    if (movePreviewCard()) {
      return;
    }

    const observer = new MutationObserver(() => {
      if (movePreviewCard()) {
        observer.disconnect();
      }
    });

    observer.observe(document.body, { childList: true, subtree: true });
    window.setTimeout(() => observer.disconnect(), 10000);
  })();
{% endjs %}

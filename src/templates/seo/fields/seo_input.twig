{% import '_includes/forms' as forms %}

{% set sectionName = sectionName ?? '' %}
{% set sectionType = sectionType ?? (element.section.type ?? '') %}
{% set showSectionSeoToggle = sectionType in ['channel', 'structure'] %}
{% set contentFieldsId = field.handle ~ '-content-fields' %}

{% css %}
  .seo-entry-help {
    margin-top: -8px;
    margin-bottom: 14px;
    color: #606d7b;
    font-size: 12px;
  }
  .seo-entry-help summary {
    cursor: pointer;
    user-select: none;
    font-weight: 600;
  }
  .seo-entry-help p {
    margin: 6px 0 0;
    line-height: 1.45;
  }
  .seo-entry-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 18px;
  }
  .seo-entry-block {
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    padding: 14px;
    background: #fff;
  }
  .seo-entry-block h3 {
    margin: 0 0 4px;
    font-size: 15px;
  }
  .seo-entry-block > p {
    margin: 0 0 14px;
  }
  @media (max-width: 1023px) {
    .seo-entry-grid {
      grid-template-columns: 1fr;
    }
  }
{% endcss %}

<div class="seo-entry-grid">
  <section class="seo-entry-block">
    <h3>Contenido SEO</h3>
    <p class="light">Define si esta entry debe usar el SEO global de su section o sus valores propios.</p>

    {% if showSectionSeoToggle %}
      <input type="hidden" name="{{ field.handle }}[useSectionSeo]" value="0">
      {{ forms.lightswitchField({
        label: 'Usar SEO global de la sección en esta entry',
        name: field.handle ~ '[useSectionSeo]',
        on: value.useSectionSeo ?? true,
        value: 1,
      }) }}
      <details class="seo-entry-help">
        <summary>¿Qué hace este valor?</summary>
        <p>Cuando está activado, esta entry usará los valores SEO configurados en <code>SEO &gt; Sections</code>. Si lo desactivas, esta entry usará su title, description e image propios.</p>
      </details>
    {% else %}
      <input type="hidden" name="{{ field.handle }}[useSectionSeo]" value="0">
      <p class="seo-entry-help">Las sections de tipo <code>single</code> siempre usan el SEO propio de la entry.</p>
    {% endif %}

    <div id="{{ contentFieldsId }}"{% if showSectionSeoToggle and (value.useSectionSeo ?? true) %} style="display:none;"{% endif %}>
      {{ forms.textField({
        label: 'Title',
        name: field.handle ~ '[title]',
        value: value.title,
        translatable: true,
        instructions: 'Puedes usar variables Twig, por ejemplo: {{ entry.title }} - Terapeuta Gestalt a {{ entry.municipis.one().title }}'
      }) }}
      <details class="seo-entry-help">
        <summary>¿Qué hace este valor?</summary>
        <p>Define el título SEO específico de esta entry cuando activas la personalización. Si lo dejas vacío, se usará el título propio de la entry.</p>
      </details>

      {{ forms.textareaField({
        label: 'Description',
        name: field.handle ~ '[description]',
        value: value.description,
        rows: 3,
        translatable: true,
        instructions: 'Puedes usar variables Twig del entry actual para generar descripciones dinámicas.'
      }) }}
      <details class="seo-entry-help">
        <summary>¿Qué hace este valor?</summary>
        <p>Descripción SEO específica de esta entry cuando activas la personalización. Si queda vacía, se usará la descripción por defecto de la section o, si no existe, la global del site.</p>
      </details>

      {{ forms.elementSelectField({
        label: 'Image',
        id: field.handle ~ '-image',
        name: field.handle ~ '[imageId][]',
        elementType: 'craft\\elements\\Asset',
        elements: imageElement ? [imageElement] : [],
        limit: 1,
        sources: '*',
        criteria: { kind: 'image' },
        translatable: true,
      }) }}
      <details class="seo-entry-help">
        <summary>¿Qué hace este valor?</summary>
        <p>Define una imagen SEO específica para esta entry cuando activas la personalización. Si no eliges ninguna, se usará la imagen por defecto de la section o, si no existe, la global del site.</p>
      </details>
    </div>
  </section>

  <section class="seo-entry-block">
    <h3>Sitemap</h3>
    <p class="light">Control de visibilidad de esta entry dentro del sitemap XML.</p>

    {{ forms.lightswitchField({
      label: 'Visible in sitemap',
      name: field.handle ~ '[sitemapEnabled]',
      on: value.sitemapEnabled is same as(false) ? false : true,
      value: 1
    }) }}
    <details class="seo-entry-help">
      <summary>¿Qué hace este valor?</summary>
      <p>Indica si esta entry debe incluirse en el sitemap XML del sitio.</p>
    </details>

    {{ forms.lightswitchField({
      label: 'Include images',
      name: field.handle ~ '[sitemapIncludeImages]',
      on: value.sitemapIncludeImages is same as(true),
      value: 1
    }) }}
    <details class="seo-entry-help">
      <summary>¿Qué hace este valor?</summary>
      <p>Incluye imágenes relacionadas en el sitemap para enriquecer la indexación visual. <a href="https://developers.google.com/search/docs/crawling-indexing/sitemaps/image-sitemaps" target="_blank" rel="noopener">Saber más</a></p>
    </details>
  </section>
</div>
{% if showSectionSeoToggle %}
  {% js %}
    (() => {
      const toggle = document.querySelector('[name={{ (field.handle ~ "[useSectionSeo]")|json_encode|raw }}][type="checkbox"]');
      const content = document.getElementById({{ contentFieldsId|json_encode|raw }});
      if (!toggle || !content) return;

      const sync = () => {
        content.style.display = toggle.checked ? 'none' : '';
      };

      toggle.addEventListener('change', sync);
      sync();
    })();
  {% endjs %}
{% endif %}

{% extends parentLayout|default('_layouts/cp') %}

{% set title = title ?? 'templates.seo.layout.content'|t('pragmatic-web-toolkit') %}
{% set selectedSubnavItem = 'seo' %}
{% set selectedTab = selectedTab ?? (craft.app.request.getSegment(3) ?? 'content') %}

{% set _requestedSiteHandle = craft.app.request.getQueryParam('site') %}
{% set _requestedSection = craft.app.request.getQueryParam('section') %}
{% set _tabParams = {} %}
{% if _requestedSiteHandle %}{% set _tabParams = _tabParams|merge({ site: _requestedSiteHandle }) %}{% endif %}
{% if _requestedSection %}{% set _tabParams = _tabParams|merge({ section: _requestedSection }) %}{% endif %}
{% set _siteParam = _requestedSiteHandle ? { site: _requestedSiteHandle } : {} %}

{% set tabs = {
  'content': { label: 'templates.seo.layout.content'|t('pragmatic-web-toolkit'), url: url('pragmatic-toolkit/seo/content', _tabParams) },
  'assets': { label: 'templates.seo.layout.assets'|t('pragmatic-web-toolkit'), url: url('pragmatic-toolkit/seo/assets', _tabParams) },
  'sitemap': { label: 'templates.seo.layout.sitemap'|t('pragmatic-web-toolkit'), url: url('pragmatic-toolkit/seo/sitemap', _tabParams) },
  'strategy': { label: 'templates.seo.layout.strategy'|t('pragmatic-web-toolkit'), url: url('pragmatic-toolkit/seo/strategy', _tabParams) },
  'options': { label: 'templates.seo.layout.options'|t('pragmatic-web-toolkit'), url: url('pragmatic-toolkit/seo/options', _tabParams) }
} %}

{% set _allEditableSites = craft.app.sites.getEditableSites() %}
{% if _allEditableSites|length > 1 %}
  {% set _selectedSite = craft.app.sites.getPrimarySite() %}
  {% if _requestedSiteHandle %}
    {% set _siteByHandle = craft.app.sites.getSiteByHandle(_requestedSiteHandle) %}
    {% if _siteByHandle %}
      {% set _selectedSite = _siteByHandle %}
    {% endif %}
  {% endif %}
  {% if selectedSite is defined and selectedSite %}
    {% set _selectedSite = selectedSite %}
  {% endif %}
  {% set _siteMenuItems = siteMenuItems(_allEditableSites, _selectedSite) %}
  {% if _siteMenuItems|length %}
    {% set crumbs = (crumbs ?? [])|unshift({
      id: 'site-crumb',
      icon: 'world',
      iconAltText: 'Site'|t('app'),
      label: _selectedSite.name|t('site'),
      menu: {
        items: _siteMenuItems,
        label: 'Select site'|t('app')
      }
    }) %}
  {% endif %}
{% endif %}

{% set __pwtModalUtils %}
  {% include 'pragmatic-web-toolkit/_partials/pwt-modal-utils' %}
{% endset %}
{% include 'pragmatic-web-toolkit/_partials/pwt-save-shortcut' %}

{% block content %}{% endblock %}

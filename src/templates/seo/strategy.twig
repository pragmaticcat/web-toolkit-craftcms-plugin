{% extends 'pragmatic-web-toolkit/seo/_layout' %}
{% import "_includes/forms" as forms %}

{% set title = 'Strategy'|t('pragmatic-web-toolkit') %}
{% set selectedTab = 'strategy' %}

{% set crumbs = [
  { label: 'SEO', url: url('pragmatic-toolkit/seo') },
  { label: 'Strategy'|t('pragmatic-web-toolkit'), url: url('pragmatic-toolkit/seo/strategy', { site: selectedSite.handle }) },
] %}

{% block content %}
  {% css %}
    .seo-strategy-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 18px;
    }
    .seo-strategy-block {
      border: 1px solid #e5e7eb;
      border-radius: 8px;
      padding: 16px;
      background: #fff;
    }
    .seo-strategy-block h2 {
      margin: 0 0 6px;
      font-size: 16px;
    }
    .seo-strategy-block > p {
      margin: 0 0 14px;
    }
    .seo-strategy-actions {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      margin-top: 16px;
    }
    @media (max-width: 1023px) {
      .seo-strategy-grid {
        grid-template-columns: 1fr;
      }
    }
  {% endcss %}

  {% if not canManageStrategy %}
    {% include 'pragmatic-web-toolkit/_partials/tier-lock' with {
      tier: 'lite',
      heading: 'Requires Lite version',
      message: 'SEO AI strategy management is available in Lite and Pro.'
    } %}
  {% endif %}

  <p class="light">
    This strategy is used as the base instruction set for Gemini, including asset metadata generation and content SEO suggestions.
  </p>

  <form method="post" accept-charset="UTF-8">
    {{ csrfInput() }}
    {{ actionInput('pragmatic-web-toolkit/seo/save-strategy') }}
    {{ redirectInput('pragmatic-toolkit/seo/strategy', { site: selectedSite.handle }) }}
    <input type="hidden" name="site" value="{{ selectedSiteId }}">

    <fieldset {{ not canManageStrategy ? 'disabled' : '' }}>
      <div class="seo-strategy-grid">
        <section class="seo-strategy-block">
          <h2>{{ 'AI settings'|t('pragmatic-web-toolkit') }}</h2>
          <p class="light">{{ 'Provider and limits for per-site SEO AI suggestions.'|t('pragmatic-web-toolkit') }}</p>

          {{ forms.lightswitchField({
            label: 'Enable AI suggestions'|t('pragmatic-web-toolkit'),
            name: 'settings[enableAiSuggestions]',
            on: settings.enableAiSuggestions ?? false,
            value: 1,
          }) }}

          {{ forms.textField({
            label: 'Gemini API key env var'|t('pragmatic-web-toolkit'),
            name: 'settings[openAiApiKeyEnv]',
            value: settings.openAiApiKeyEnv ?? 'GEMINI_API_KEY',
            placeholder: 'GEMINI_API_KEY',
          }) }}

          {{ forms.textField({
            label: 'Gemini model'|t('pragmatic-web-toolkit'),
            name: 'settings[openAiModel]',
            value: settings.openAiModel ?? 'gemini-2.5-flash',
            placeholder: 'gemini-2.5-flash',
          }) }}

          {{ forms.textField({
            label: 'Max image candidates'|t('pragmatic-web-toolkit'),
            name: 'settings[maxImageCandidates]',
            type: 'number',
            value: settings.maxImageCandidates ?? 12,
            min: 1,
          }) }}

          {{ forms.textField({
            label: 'Max source text chars'|t('pragmatic-web-toolkit'),
            name: 'settings[maxSourceTextChars]',
            type: 'number',
            value: settings.maxSourceTextChars ?? 6000,
            min: 500,
          }) }}

          {% if aiAvailable %}
            <p class="light">{{ 'Gemini is configured and available for this site.'|t('pragmatic-web-toolkit') }}</p>
          {% elseif aiDisabledReason %}
            <p class="warning">{{ aiDisabledReason }}</p>
          {% endif %}

          <div class="seo-strategy-actions">
            <button
              type="button"
              class="btn"
              id="seo-gem-instructions"
              data-gem-instructions="{{ gemInstructions|e('html_attr') }}"
            >
              {{ 'Show Gem instructions'|t('pragmatic-web-toolkit') }}
            </button>
          </div>
        </section>

        <section class="seo-strategy-block">
          <h2>{{ 'Audience and goals'|t('pragmatic-web-toolkit') }}</h2>
          <p class="light">{{ 'Help AI understand who you are targeting and what SEO outcomes matter.'|t('pragmatic-web-toolkit') }}</p>

          {{ forms.textareaField({
            label: 'Audience'|t('pragmatic-web-toolkit'),
            name: 'settings[strategyAudience]',
            value: settings.strategyAudience ?? '',
            rows: 4,
          }) }}

          {{ forms.textareaField({
            label: 'Business / SEO goals'|t('pragmatic-web-toolkit'),
            name: 'settings[strategyBusinessGoals]',
            value: settings.strategyBusinessGoals ?? '',
            rows: 4,
          }) }}

          {{ forms.textareaField({
            label: 'Tone of voice'|t('pragmatic-web-toolkit'),
            name: 'settings[strategyTone]',
            value: settings.strategyTone ?? '',
            rows: 4,
          }) }}

          {{ forms.textareaField({
            label: 'CTA style'|t('pragmatic-web-toolkit'),
            name: 'settings[strategyCtaStyle]',
            value: settings.strategyCtaStyle ?? '',
            rows: 3,
          }) }}
        </section>

        <section class="seo-strategy-block">
          <h2>{{ 'Keywords and brand'|t('pragmatic-web-toolkit') }}</h2>
          <p class="light">{{ 'Use one item per line or a comma-separated list.'|t('pragmatic-web-toolkit') }}</p>

          {{ forms.textareaField({
            label: 'Primary keywords'|t('pragmatic-web-toolkit'),
            name: 'settings[strategyPrimaryKeywords]',
            value: settings.strategyPrimaryKeywords ?? '',
            rows: 5,
          }) }}

          {{ forms.textareaField({
            label: 'Secondary keywords'|t('pragmatic-web-toolkit'),
            name: 'settings[strategySecondaryKeywords]',
            value: settings.strategySecondaryKeywords ?? '',
            rows: 5,
          }) }}

          {{ forms.textareaField({
            label: 'Brand terms to include'|t('pragmatic-web-toolkit'),
            name: 'settings[strategyBrandTerms]',
            value: settings.strategyBrandTerms ?? '',
            rows: 4,
          }) }}

          {{ forms.textareaField({
            label: 'Terms / claims to avoid'|t('pragmatic-web-toolkit'),
            name: 'settings[strategyForbiddenTerms]',
            value: settings.strategyForbiddenTerms ?? '',
            rows: 4,
          }) }}
        </section>

        <section class="seo-strategy-block">
          <h2>{{ 'Additional notes'|t('pragmatic-web-toolkit') }}</h2>
          <p class="light">{{ 'Extra editorial or SEO guidance that should be considered on every AI call.'|t('pragmatic-web-toolkit') }}</p>

          {{ forms.textareaField({
            label: 'Additional notes'|t('pragmatic-web-toolkit'),
            name: 'settings[strategyNotes]',
            value: settings.strategyNotes ?? '',
            rows: 12,
          }) }}
        </section>
      </div>

      <div class="seo-strategy-actions">
        <button type="submit" class="btn submit">{{ 'Save strategy'|t('pragmatic-web-toolkit') }}</button>
      </div>
    </fieldset>
  </form>

  {% js %}
    (() => {
      const trigger = document.getElementById('seo-gem-instructions');
      if (!trigger || typeof Garnish === 'undefined' || typeof Garnish.Modal !== 'function') {
        return;
      }

      function openModal(text) {
        const modalEl = document.createElement('div');
        modalEl.className = 'modal fitted';
        modalEl.innerHTML =
          '<div class="body">' +
            '<div class="content">' +
              '<h2 style="margin-top:0;">{{ "Gem instructions"|t("pragmatic-web-toolkit")|e("js") }}</h2>' +
              '<p>{{ "Paste this into the instructions field of your Gemini Gem for the selected site."|t("pragmatic-web-toolkit")|e("js") }}</p>' +
              '<textarea class="text fullwidth" rows="18" readonly style="font-family: Menlo, Monaco, Consolas, monospace;">' + Craft.escapeHtml(text) + '</textarea>' +
            '</div>' +
          '</div>' +
          '<div class="footer">' +
            '<div class="btngroup">' +
              '<button type="button" class="btn" data-action="copy">{{ "Copy instructions"|t("pragmatic-web-toolkit")|e("js") }}</button>' +
              '<button type="button" class="btn" data-action="close">{{ "Close"|t("pragmatic-web-toolkit")|e("js") }}</button>' +
            '</div>' +
          '</div>';

        const modal = new Garnish.Modal(modalEl, {
          autoShow: true,
          onHide: function() { modal.destroy(); }
        });
        const textarea = modalEl.querySelector('textarea');
        const copyBtn = modalEl.querySelector('[data-action="copy"]');
        const closeBtn = modalEl.querySelector('[data-action="close"]');

        if (textarea) {
          textarea.focus();
          textarea.select();
        }

        if (copyBtn) {
          copyBtn.addEventListener('click', async () => {
            try {
              await navigator.clipboard.writeText(text);
              Craft.cp.displayNotice('{{ "Instructions copied."|t("pragmatic-web-toolkit")|e("js") }}');
            } catch (error) {
              if (textarea) {
                textarea.focus();
                textarea.select();
              }
              Craft.cp.displayError('{{ "Could not copy automatically. Copy them manually from the textarea."|t("pragmatic-web-toolkit")|e("js") }}');
            }
          });
        }

        if (closeBtn) {
          closeBtn.addEventListener('click', () => modal.hide());
        }
      }

      trigger.addEventListener('click', () => {
        openModal(trigger.dataset.gemInstructions || '');
      });
    })();
  {% endjs %}
{% endblock %}

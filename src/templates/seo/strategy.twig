{% extends 'pragmatic-web-toolkit/seo/_layout' %}
{% import "_includes/forms" as forms %}

{% set title = 'templates.seo.strategy.strategy'|t('pragmatic-web-toolkit') %}
{% set selectedTab = 'strategy' %}

{% set crumbs = [
  { label: 'SEO', url: url('pragmatic-toolkit/seo') },
  { label: 'templates.seo.strategy.strategy'|t('pragmatic-web-toolkit'), url: url('pragmatic-toolkit/seo/strategy', { site: selectedSite.handle }) },
] %}

{% block content %}
  {% css %}
    .seo-strategy-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 18px;
    }
    .seo-strategy-block {
      border: 1px solid #e5e7eb;
      border-radius: 8px;
      padding: 16px;
      background: #fff;
    }
    .seo-strategy-block h2 {
      margin: 0 0 6px;
      font-size: 16px;
    }
    .seo-strategy-block > p {
      margin: 0 0 14px;
    }
    .seo-strategy-actions {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      margin-top: 16px;
    }
    @media (max-width: 1023px) {
      .seo-strategy-grid {
        grid-template-columns: 1fr;
      }
    }
  {% endcss %}

  {% if not canManageStrategy %}
    {% include 'pragmatic-web-toolkit/_partials/tier-lock' with {
      tier: 'pro',
      heading: 'Requires Pro version',
      message: 'SEO AI strategy management is available in Pro.'
    } %}
  {% endif %}

  <p class="light">
    This strategy is used as the base instruction set for Gemini, including asset metadata generation and content SEO suggestions.
  </p>

  <form method="post" accept-charset="UTF-8">
    {{ csrfInput() }}
    {{ actionInput('pragmatic-web-toolkit/seo/save-strategy') }}
    {{ redirectInput('pragmatic-toolkit/seo/strategy', { site: selectedSite.handle }) }}
    <input type="hidden" name="site" value="{{ selectedSiteId }}">

    <fieldset {{ not canManageStrategy ? 'disabled' : '' }}>
      <div class="seo-strategy-grid">
        <section class="seo-strategy-block">
          <h2>{{ 'templates.seo.strategy.ai-settings'|t('pragmatic-web-toolkit') }}</h2>
          <p class="light">{{ 'templates.seo.strategy.manual-gemini-prompt-behavior-and-limits-for-per-site-seo-sugges'|t('pragmatic-web-toolkit') }}</p>

          {{ forms.lightswitchField({
            label: 'templates.seo.strategy.use-gemini-gem-instructions'|t('pragmatic-web-toolkit'),
            instructions: 'templates.seo.strategy.enable-this-if-your-manual-prompts-will-be-pasted-into-a-gemini'|t('pragmatic-web-toolkit'),
            name: 'settings[enableGemFeature]',
            on: gemFeatureEnabled,
            value: 1,
          }) }}

          {{ forms.textField({
            label: 'templates.seo.strategy.max-image-candidates'|t('pragmatic-web-toolkit'),
            name: 'settings[maxImageCandidates]',
            type: 'number',
            value: settings.maxImageCandidates ?? 12,
            min: 1,
          }) }}

          {{ forms.textField({
            label: 'templates.seo.strategy.max-source-text-chars'|t('pragmatic-web-toolkit'),
            name: 'settings[maxSourceTextChars]',
            type: 'number',
            value: settings.maxSourceTextChars ?? 6000,
            min: 500,
          }) }}

          {% if gemFeatureEnabled %}
            <div class="seo-strategy-actions">
              <button
                type="button"
                class="btn"
                id="seo-gem-instructions"
                data-gem-instructions="{{ gemInstructions|e('html_attr') }}"
              >
                {{ 'templates.seo.strategy.show-gem-instructions'|t('pragmatic-web-toolkit') }}
              </button>
            </div>
          {% else %}
            <p class="light">{{ 'templates.seo.strategy.gem-instructions-are-disabled-for-this-site-manual-prompts-will'|t('pragmatic-web-toolkit') }}</p>
          {% endif %}
        </section>

        <section class="seo-strategy-block">
          <h2>{{ 'templates.seo.strategy.audience-and-goals'|t('pragmatic-web-toolkit') }}</h2>
          <p class="light">{{ 'templates.seo.strategy.help-ai-understand-who-you-are-targeting-and-what-seo-outcomes-m'|t('pragmatic-web-toolkit') }}</p>

          {{ forms.textareaField({
            label: 'templates.seo.strategy.audience'|t('pragmatic-web-toolkit'),
            name: 'settings[strategyAudience]',
            value: settings.strategyAudience ?? '',
            rows: 4,
          }) }}

          {{ forms.textareaField({
            label: 'templates.seo.strategy.business-seo-goals'|t('pragmatic-web-toolkit'),
            name: 'settings[strategyBusinessGoals]',
            value: settings.strategyBusinessGoals ?? '',
            rows: 4,
          }) }}

          {{ forms.textareaField({
            label: 'templates.seo.strategy.tone-of-voice'|t('pragmatic-web-toolkit'),
            name: 'settings[strategyTone]',
            value: settings.strategyTone ?? '',
            rows: 4,
          }) }}

          {{ forms.textareaField({
            label: 'templates.seo.strategy.cta-style'|t('pragmatic-web-toolkit'),
            name: 'settings[strategyCtaStyle]',
            value: settings.strategyCtaStyle ?? '',
            rows: 3,
          }) }}
        </section>

        <section class="seo-strategy-block">
          <h2>{{ 'templates.seo.strategy.keywords-and-brand'|t('pragmatic-web-toolkit') }}</h2>
          <p class="light">{{ 'templates.seo.strategy.use-one-item-per-line-or-a-comma-separated-list'|t('pragmatic-web-toolkit') }}</p>

          {{ forms.textareaField({
            label: 'templates.seo.strategy.primary-keywords'|t('pragmatic-web-toolkit'),
            name: 'settings[strategyPrimaryKeywords]',
            value: settings.strategyPrimaryKeywords ?? '',
            rows: 5,
          }) }}

          {{ forms.textareaField({
            label: 'templates.seo.strategy.secondary-keywords'|t('pragmatic-web-toolkit'),
            name: 'settings[strategySecondaryKeywords]',
            value: settings.strategySecondaryKeywords ?? '',
            rows: 5,
          }) }}

          {{ forms.textareaField({
            label: 'templates.seo.strategy.brand-terms-to-include'|t('pragmatic-web-toolkit'),
            name: 'settings[strategyBrandTerms]',
            value: settings.strategyBrandTerms ?? '',
            rows: 4,
          }) }}

          {{ forms.textareaField({
            label: 'templates.seo.strategy.terms-claims-to-avoid'|t('pragmatic-web-toolkit'),
            name: 'settings[strategyForbiddenTerms]',
            value: settings.strategyForbiddenTerms ?? '',
            rows: 4,
          }) }}
        </section>

        <section class="seo-strategy-block">
          <h2>{{ 'templates.seo.strategy.additional-notes'|t('pragmatic-web-toolkit') }}</h2>
          <p class="light">{{ 'templates.seo.strategy.extra-editorial-or-seo-guidance-that-should-be-considered-on-eve'|t('pragmatic-web-toolkit') }}</p>

          {{ forms.textareaField({
            label: 'templates.seo.strategy.additional-notes'|t('pragmatic-web-toolkit'),
            name: 'settings[strategyNotes]',
            value: settings.strategyNotes ?? '',
            rows: 12,
          }) }}
        </section>
      </div>

      <div class="seo-strategy-actions">
        <button type="submit" class="btn submit">{{ 'templates.seo.strategy.save-strategy'|t('pragmatic-web-toolkit') }}</button>
      </div>
    </fieldset>
  </form>

  {% js %}
    (() => {
      const trigger = document.getElementById('seo-gem-instructions');
      if (!trigger || typeof Garnish === 'undefined' || typeof Garnish.Modal !== 'function') {
        return;
      }

      function openModal(text) {
        const modalEl = document.createElement('div');
        modalEl.className = 'modal pwt-unified-modal pwt-unified-modal--large';
        modalEl.innerHTML =
          '<div class="body">' +
            '<div class="content">' +
              '<h2 style="margin-top:0;">{{ 'templates.seo.strategy.gem-instructions'|t('pragmatic-web-toolkit')|e("js") }}</h2>' +
              '<p>{{ 'templates.seo.strategy.paste-this-into-the-instructions-field-of-your-gemini-gem-for-th'|t('pragmatic-web-toolkit')|e("js") }}</p>' +
              '<textarea class="text fullwidth" rows="18" readonly style="font-family: Menlo, Monaco, Consolas, monospace;">' + Craft.escapeHtml(text) + '</textarea>' +
            '</div>' +
          '</div>' +
          '<div class="footer">' +
            '<div class="btngroup">' +
              '<button type="button" class="btn" data-action="copy">{{ 'templates.seo.strategy.copy-instructions'|t('pragmatic-web-toolkit')|e("js") }}</button>' +
              '<button type="button" class="btn" data-action="close">{{ 'templates.seo.strategy.close'|t('pragmatic-web-toolkit')|e("js") }}</button>' +
            '</div>' +
          '</div>';

        const modal = new Garnish.Modal(modalEl, {
          autoShow: true,
          onHide: function() { modal.destroy(); }
        });
        const textarea = modalEl.querySelector('textarea');
        const copyBtn = modalEl.querySelector('[data-action="copy"]');
        const closeBtn = modalEl.querySelector('[data-action="close"]');

        if (textarea) {
          textarea.focus();
          textarea.select();
        }

        if (copyBtn) {
          copyBtn.addEventListener('click', async () => {
            try {
              await navigator.clipboard.writeText(text);
              Craft.cp.displayNotice('{{ 'templates.seo.strategy.instructions-copied'|t('pragmatic-web-toolkit')|e("js") }}');
            } catch (error) {
              if (textarea) {
                textarea.focus();
                textarea.select();
              }
              Craft.cp.displayError('{{ 'templates.seo.strategy.could-not-copy-automatically-copy-them-manually-from-the-textare'|t('pragmatic-web-toolkit')|e("js") }}');
            }
          });
        }

        if (closeBtn) {
          closeBtn.addEventListener('click', () => modal.hide());
        }
      }

      trigger.addEventListener('click', () => {
        openModal(trigger.dataset.gemInstructions || '');
      });
    })();
  {% endjs %}
{% endblock %}

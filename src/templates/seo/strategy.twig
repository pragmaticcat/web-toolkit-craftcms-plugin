{% extends 'pragmatic-web-toolkit/seo/_layout' %}
{% import "_includes/forms" as forms %}

{% set title = 'templates.seo.strategy.strategy'|t('pragmatic-web-toolkit') %}
{% set selectedTab = 'strategy' %}

{% set crumbs = [
  { label: 'SEO', url: url('pragmatic-toolkit/seo') },
  { label: 'templates.seo.strategy.strategy'|t('pragmatic-web-toolkit'), url: url('pragmatic-toolkit/seo/strategy', { site: selectedSite.handle }) },
] %}

{% block content %}
  {% css %}
    .seo-strategy-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 18px;
    }
    .seo-strategy-block {
      border: 1px solid #e5e7eb;
      border-radius: 8px;
      padding: 16px;
      background: #fff;
    }
    .seo-strategy-block h2 {
      margin: 0 0 6px;
      font-size: 16px;
    }
    .seo-strategy-block > p {
      margin: 0 0 14px;
    }
    .seo-strategy-actions {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      margin-top: 16px;
    }
    @media (max-width: 1023px) {
      .seo-strategy-grid {
        grid-template-columns: 1fr;
      }
    }
  {% endcss %}

  <p class="light">
    This strategy is used as the base instruction set for Gemini, including asset metadata generation and content SEO suggestions.
  </p>

  <form method="post" accept-charset="UTF-8">
    {{ csrfInput() }}
    {{ actionInput('pragmatic-web-toolkit/seo/save-strategy') }}
    {{ redirectInput('pragmatic-toolkit/seo/strategy', { site: selectedSite.handle }) }}
    <input type="hidden" name="site" value="{{ selectedSiteId }}">

    <fieldset>
      <div class="seo-strategy-grid">
        <section class="seo-strategy-block">
          <h2>{{ 'templates.seo.strategy.ai-settings'|t('pragmatic-web-toolkit') }}</h2>
          <p class="light">{{ 'templates.seo.strategy.manual-gemini-prompt-behavior-and-limits-for-per-site-seo-sugges'|t('pragmatic-web-toolkit') }}</p>

          {{ forms.textField({
            label: 'templates.seo.strategy.max-image-candidates'|t('pragmatic-web-toolkit'),
            name: 'settings[maxImageCandidates]',
            type: 'number',
            value: settings.maxImageCandidates ?? 12,
            min: 1,
          }) }}

          {{ forms.textField({
            label: 'templates.seo.strategy.max-source-text-chars'|t('pragmatic-web-toolkit'),
            name: 'settings[maxSourceTextChars]',
            type: 'number',
            value: settings.maxSourceTextChars ?? 6000,
            min: 500,
          }) }}
        </section>

        <section class="seo-strategy-block">
          <h2>{{ 'templates.seo.strategy.audience-and-goals'|t('pragmatic-web-toolkit') }}</h2>
          <p class="light">{{ 'templates.seo.strategy.help-ai-understand-who-you-are-targeting-and-what-seo-outcomes-m'|t('pragmatic-web-toolkit') }}</p>

          {{ forms.textareaField({
            label: 'templates.seo.strategy.audience'|t('pragmatic-web-toolkit'),
            name: 'settings[strategyAudience]',
            value: settings.strategyAudience ?? '',
            rows: 4,
          }) }}

          {{ forms.textareaField({
            label: 'templates.seo.strategy.business-seo-goals'|t('pragmatic-web-toolkit'),
            name: 'settings[strategyBusinessGoals]',
            value: settings.strategyBusinessGoals ?? '',
            rows: 4,
          }) }}

          {{ forms.textareaField({
            label: 'templates.seo.strategy.tone-of-voice'|t('pragmatic-web-toolkit'),
            name: 'settings[strategyTone]',
            value: settings.strategyTone ?? '',
            rows: 4,
          }) }}

          {{ forms.textareaField({
            label: 'templates.seo.strategy.cta-style'|t('pragmatic-web-toolkit'),
            name: 'settings[strategyCtaStyle]',
            value: settings.strategyCtaStyle ?? '',
            rows: 3,
          }) }}
        </section>

        <section class="seo-strategy-block">
          <h2>{{ 'templates.seo.strategy.keywords-and-brand'|t('pragmatic-web-toolkit') }}</h2>
          <p class="light">{{ 'templates.seo.strategy.use-one-item-per-line-or-a-comma-separated-list'|t('pragmatic-web-toolkit') }}</p>

          {{ forms.textareaField({
            label: 'templates.seo.strategy.primary-keywords'|t('pragmatic-web-toolkit'),
            name: 'settings[strategyPrimaryKeywords]',
            value: settings.strategyPrimaryKeywords ?? '',
            rows: 5,
          }) }}

          {{ forms.textareaField({
            label: 'templates.seo.strategy.secondary-keywords'|t('pragmatic-web-toolkit'),
            name: 'settings[strategySecondaryKeywords]',
            value: settings.strategySecondaryKeywords ?? '',
            rows: 5,
          }) }}

          {{ forms.textareaField({
            label: 'templates.seo.strategy.brand-terms-to-include'|t('pragmatic-web-toolkit'),
            name: 'settings[strategyBrandTerms]',
            value: settings.strategyBrandTerms ?? '',
            rows: 4,
          }) }}

          {{ forms.textareaField({
            label: 'templates.seo.strategy.terms-claims-to-avoid'|t('pragmatic-web-toolkit'),
            name: 'settings[strategyForbiddenTerms]',
            value: settings.strategyForbiddenTerms ?? '',
            rows: 4,
          }) }}
        </section>

        <section class="seo-strategy-block">
          <h2>{{ 'templates.seo.strategy.additional-notes'|t('pragmatic-web-toolkit') }}</h2>
          <p class="light">{{ 'templates.seo.strategy.extra-editorial-or-seo-guidance-that-should-be-considered-on-eve'|t('pragmatic-web-toolkit') }}</p>

          {{ forms.textareaField({
            label: 'templates.seo.strategy.additional-notes'|t('pragmatic-web-toolkit'),
            name: 'settings[strategyNotes]',
            value: settings.strategyNotes ?? '',
            rows: 12,
          }) }}
        </section>
      </div>

      <div class="seo-strategy-actions">
        <button type="submit" class="btn submit">{{ 'templates.seo.strategy.save-strategy'|t('pragmatic-web-toolkit') }}</button>
      </div>
    </fieldset>
  </form>

{% endblock %}

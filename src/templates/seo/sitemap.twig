{% extends 'pragmatic-web-toolkit/seo/_layout' %}
{% import '_includes/forms' as forms %}

{% set title = 'templates.seo.sitemap.sitemap'|t('pragmatic-web-toolkit') %}
{% set selectedTab = 'sitemap' %}

{% set crumbs = [
  { label: 'SEO', url: url('pragmatic-toolkit/seo') },
  { label: 'templates.seo.sitemap.sitemap'|t('pragmatic-web-toolkit'), url: url('pragmatic-toolkit/seo/sitemap') },
] %}

{% block sidebar %}
  <nav aria-label="{{ 'templates.seo.sitemap.sections'|t('pragmatic-web-toolkit') }}">
    <ul class="nav">
      <li>
        <a class="{{ not sectionId ? 'sel' : '' }}" href="{{ url('pragmatic-toolkit/seo/sitemap', { site: selectedSite.handle }) }}">
          {{ 'templates.seo.sitemap.all-entries'|t('pragmatic-web-toolkit') }}
        </a>
      </li>
      {% if sections|length %}
        <li class="heading"><span>{{ 'templates.seo.sitemap.sections'|t('pragmatic-web-toolkit') }}</span></li>
        {% for section in sections %}
          <li>
            <a class="{{ section.id == sectionId ? 'sel' : '' }}" href="{{ url('pragmatic-toolkit/seo/sitemap', { site: selectedSite.handle, section: section.id }) }}">
              {{ section.name }} <span class="light" style="margin-left: 2px;">({{ section.count }})</span>
            </a>
          </li>
        {% endfor %}
      {% endif %}
    </ul>
  </nav>
{% endblock %}

{% block content %}
  <p>
    {{ 'templates.seo.sitemap.public-sitemap-url'|t('pragmatic-web-toolkit') }}
    <a href="{{ sitemapUrl }}" target="_blank" rel="noopener">{{ sitemapUrl }}</a>
  </p>

  <form method="post" accept-charset="UTF-8">
    {{ csrfInput() }}
    {{ actionInput('pragmatic-web-toolkit/seo/save-sitemap') }}
    {{ redirectInput('pragmatic-toolkit/seo/sitemap?site=' ~ selectedSite.handle ~ (sectionId ? '&section=' ~ sectionId : '')) }}
    <input type="hidden" name="site" value="{{ selectedSite.id }}">

    {% if rows|length %}
      <table class="data fullwidth">
        <thead>
          <tr>
            <th>{{ 'Entry'|t('site') }}</th>
            <th>{{ 'Field'|t('site') }}</th>
            <th>
              <label style="display:flex;align-items:center;gap:6px;">
                <input type="checkbox" id="sitemap-select-all-enabled">
                <span>{{ 'Visible in sitemap'|t('site') }}</span>
              </label>
            </th>
            <th>
              <label style="display:flex;align-items:center;gap:6px;">
                <input type="checkbox" id="sitemap-select-all-images">
                <span>{{ 'Include images'|t('site') }}</span>
              </label>
            </th>
          </tr>
        </thead>
        <tbody>
          {% for row in rows %}
            <tr>
              <td>
                {% set entry = row.entry %}
                <a href="{{ entry.cpEditUrl ?? '#' }}" {% if not entry.cpEditUrl %}style="pointer-events:none;opacity:.7;"{% endif %}>
                  {{ entry.title ?: ('(Untitled)'|t('site')) }}
                </a>
              </td>
              <td><code>{{ row.fieldHandle }}</code></td>
              <td>
                <input type="hidden" name="entries[{{ loop.index0 }}][entryId]" value="{{ entry.id }}">
                <input type="hidden" name="entries[{{ loop.index0 }}][fieldHandle]" value="{{ row.fieldHandle }}">
                <input type="hidden" name="entries[{{ loop.index0 }}][sitemapEnabled]" value="0">
                <input type="checkbox" class="sitemap-enabled-checkbox" name="entries[{{ loop.index0 }}][sitemapEnabled]" value="1" {{ row.sitemapEnabled ? 'checked' : '' }}>
              </td>
              <td>
                <input type="hidden" name="entries[{{ loop.index0 }}][sitemapIncludeImages]" value="0">
                <input type="checkbox" class="sitemap-images-checkbox" name="entries[{{ loop.index0 }}][sitemapIncludeImages]" value="1" {{ row.sitemapIncludeImages ? 'checked' : '' }}>
              </td>
            </tr>
          {% endfor %}
        </tbody>
      </table>

      <div class="buttons" style="margin-top: 14px;">
        <button type="submit" class="btn submit">{{ 'Save'|t('site') }}</button>
      </div>

      <script>
        (() => {
          const selectAllEnabled = document.getElementById('sitemap-select-all-enabled');
          const selectAllImages = document.getElementById('sitemap-select-all-images');
          const enabledBoxes = Array.from(document.querySelectorAll('.sitemap-enabled-checkbox'));
          const imageBoxes = Array.from(document.querySelectorAll('.sitemap-images-checkbox'));

          const syncMaster = (master, boxes) => {
            if (!master || boxes.length === 0) return;
            const checkedCount = boxes.filter((box) => box.checked).length;
            master.checked = checkedCount > 0 && checkedCount === boxes.length;
            master.indeterminate = checkedCount > 0 && checkedCount < boxes.length;
          };

          const bindColumn = (master, boxes) => {
            if (!master || boxes.length === 0) return;
            master.addEventListener('change', () => {
              boxes.forEach((box) => {
                box.checked = master.checked;
              });
              master.indeterminate = false;
            });
            boxes.forEach((box) => box.addEventListener('change', () => syncMaster(master, boxes)));
            syncMaster(master, boxes);
          };

          bindColumn(selectAllEnabled, enabledBoxes);
          bindColumn(selectAllImages, imageBoxes);
        })();
      </script>
    {% else %}
      <p class="light">{{ 'No entries with SEO field found for this site/section.'|t('site') }}</p>
    {% endif %}
  </form>
{% endblock %}

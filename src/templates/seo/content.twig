{% extends 'pragmatic-web-toolkit/seo/_layout' %}
{% import '_includes/forms' as forms %}

{% set title = 'Content'|t('pragmatic-web-toolkit') %}
{% set selectedTab = 'content' %}

{% set crumbs = [
  { label: 'SEO', url: url('pragmatic-toolkit/seo') },
  { label: 'Content'|t('pragmatic-web-toolkit'), url: url('pragmatic-toolkit/seo/content') },
] %}

{% block sidebar %}
  <nav aria-label="{{ 'Sections'|t('pragmatic-web-toolkit') }}">
    <ul class="nav">
      <li>
        <a class="{{ not sectionId ? 'sel' : '' }}" href="{{ url('pragmatic-toolkit/seo/content', { site: selectedSite.handle }) }}">
          {{ 'All entries'|t('pragmatic-web-toolkit') }}
        </a>
      </li>
      {% if sections|length %}
        <li class="heading"><span>{{ 'Sections'|t('pragmatic-web-toolkit') }}</span></li>
        {% for section in sections %}
          <li>
            <a class="{{ section.id == sectionId ? 'sel' : '' }}" href="{{ url('pragmatic-toolkit/seo/content', { site: selectedSite.handle, section: section.id }) }}">
              {{ section.name }} <span class="light" style="margin-left: 2px;">({{ section.count }})</span>
            </a>
          </li>
        {% endfor %}
      {% endif %}
    </ul>
  </nav>
{% endblock %}

{% block content %}
  {% css %}
    .pwt-entry-link {
      font-weight: 600;
      text-decoration: none;
    }
    .pwt-entry-link:hover {
      text-decoration: underline;
    }
    .pwt-row-actions {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
    }
    .pwt-image-selection-note {
      margin-top: 6px;
      font-size: 12px;
      color: #606d7b;
    }
    .pwt-disabled-textarea {
      background: #f8fafc;
      color: #606d7b;
    }
    .pwt-ai-manual-hint {
      margin-top: 10px;
    }
  {% endcss %}

  {% if not canManageContent %}
    {% include 'pragmatic-web-toolkit/_partials/tier-lock' with {
      tier: 'lite',
      heading: 'Requires Lite version',
      message: 'SEO content management is available in Lite and Pro.'
    } %}
  {% endif %}

  <form method="get" class="flex" style="gap:12px; align-items:flex-end; margin-bottom:16px;">
    <fieldset {{ not canManageContent ? 'disabled' : '' }} style="border:0; padding:0; margin:0; width:100%;">
      <input type="hidden" name="site" value="{{ selectedSite.handle }}">
      <input type="hidden" name="section" value="{{ sectionId }}">
      <div class="d-flex flex-row" style="gap:12px;">
        <div>
          <label for="q">Search</label>
          <input class="text" type="text" id="q" name="q" value="{{ search }}" placeholder="Entry title">
        </div>
        <div>
          <label for="perPage">Per page</label>
          <div class="select">
            <select id="perPage" name="perPage">
              {% for option in [50, 100, 250] %}
                <option value="{{ option }}" {{ option == perPage ? 'selected' : '' }}>{{ option }}</option>
              {% endfor %}
            </select>
          </div>
        </div>
        <button class="btn" type="submit">Filter</button>
      </div>
    </fieldset>
  </form>

  {% if canManageContent and aiEnabled and aiManualMode and aiDisabledReason %}
    <p class="light pwt-ai-manual-hint">{{ aiDisabledReason }} {{ 'The button will open a prompt you can paste into a chat that uses your Gemini Gem.'|t('pragmatic-web-toolkit') }}</p>
  {% elseif canManageContent and not aiEnabled and aiDisabledReason %}
    <p class="light">{{ aiDisabledReason }}</p>
  {% endif %}

  <form method="post" accept-charset="UTF-8" id="seo-content-form">
    {{ csrfInput() }}
    {{ actionInput('pragmatic-web-toolkit/seo/save-content') }}
    {{ redirectInput('pragmatic-toolkit/seo/content', { q: search, perPage: perPage, page: page, section: sectionId, site: selectedSite.handle }) }}
    <input type="hidden" name="site" value="{{ selectedSiteId }}">
    <fieldset {{ not canManageContent ? 'disabled' : '' }}>

    <table class="data fullwidth">
      <thead>
        <tr><th>Entry</th><th>Field</th><th>Title</th><th>Description</th><th>Image</th><th>Image Description</th><th>Action</th></tr>
      </thead>
      <tbody>
      {% for row in rows %}
        {% set i = loop.index0 %}
        <tr>
          <td>
            <a
              href="#"
              class="pwt-entry-link js-entry-slideout"
              data-entry-id="{{ row.entry.id }}"
              data-site-id="{{ row.entry.siteId }}"
            >
              {{ row.entry.title ?: ('Entry #' ~ row.entry.id) }}
            </a>
          </td>
          <td>{{ row.fieldLabel }}</td>
          <td>
            <input type="hidden" name="entries[{{ i }}][entryId]" value="{{ row.entry.id }}">
            <input type="hidden" name="entries[{{ i }}][fieldHandle]" value="{{ row.fieldHandle }}">
            <textarea class="text fullwidth" rows="2" name="entries[{{ i }}][values][title]">{{ row.value.title ?? '' }}</textarea>
          </td>
          <td><textarea class="text fullwidth" rows="2" name="entries[{{ i }}][values][description]">{{ row.value.description ?? '' }}</textarea></td>
          <td>
            <div data-image-cell="{{ i }}">
            {{ forms.elementSelect({
              id: 'seo-image-' ~ i,
              name: "entries[#{i}][values][imageId]",
              elementType: 'craft\\elements\\Asset',
              elements: row.value.imageId ? [craft.assets.id(row.value.imageId).status(null).one()] : [],
              limit: 1,
              criteria: { kind: 'image' },
              sources: '*'
            }) }}
              <div class="pwt-image-selection-note js-generated-image-note">
                {% if row.value.imageId %}
                  {{ 'Current selection:'|t('pragmatic-web-toolkit') }} {{ row.value.imageId }}
                {% else %}
                  {{ 'No image selected.'|t('pragmatic-web-toolkit') }}
                {% endif %}
              </div>
            </div>
          </td>
          <td>
            <textarea
              class="text fullwidth pwt-disabled-textarea js-image-description-display"
              rows="2"
              disabled
              data-row-index="{{ i }}"
              placeholder="{{ 'This field will be autofilled using the selected image alt field.'|t('pragmatic-web-toolkit') }}"
            >{{ row.value.imageDescription ?? '' }}</textarea>
          </td>
          <td>
            <div class="pwt-row-actions">
              {% if aiEnabled %}
                <button
                  class="btn js-generate-seo-row"
                  type="button"
                  data-entry-id="{{ row.entry.id }}"
                  data-site-id="{{ row.entry.siteId }}"
                  data-field-handle="{{ row.fieldHandle }}"
                  data-row-index="{{ i }}"
                >
                  {{ 'Generate with AI'|t('pragmatic-web-toolkit') }}
                </button>
              {% endif %}
              <button class="btn submit" type="submit" name="saveRow" value="{{ i }}">{{ 'Save row'|t('pragmatic-web-toolkit') }}</button>
            </div>
          </td>
        </tr>
      {% endfor %}
      </tbody>
    </table>
    </fieldset>
  </form>

  {% js %}
    function openManualPromptModal(title, promptText) {
      const modalEl = document.createElement('div');
      modalEl.className = 'modal fitted';
      modalEl.innerHTML =
        '<div class="body">' +
          '<div class="content">' +
            '<h2 style="margin-top:0;">' + title + '</h2>' +
            '<p>{{ "Paste this prompt into a chat that uses your Gemini Gem. Ask it to return only the requested JSON."|t("pragmatic-web-toolkit")|e("js") }}</p>' +
            '<textarea class="text fullwidth" rows="18" readonly style="font-family: Menlo, Monaco, Consolas, monospace;">' + Craft.escapeHtml(promptText) + '</textarea>' +
          '</div>' +
        '</div>' +
        '<div class="footer">' +
          '<div class="btngroup">' +
            '<button type="button" class="btn" data-action="copy">{{ "Copy prompt"|t("pragmatic-web-toolkit")|e("js") }}</button>' +
            '<button type="button" class="btn" data-action="close">{{ "Close"|t("pragmatic-web-toolkit")|e("js") }}</button>' +
          '</div>' +
        '</div>';

      const modal = new Garnish.Modal(modalEl, {
        autoShow: true,
        onHide: function() { modal.destroy(); }
      });
      const textarea = modalEl.querySelector('textarea');
      const copyBtn = modalEl.querySelector('[data-action="copy"]');
      const closeBtn = modalEl.querySelector('[data-action="close"]');
      if (textarea) {
        textarea.focus();
        textarea.select();
      }
      if (copyBtn) {
        copyBtn.addEventListener('click', async () => {
          try {
            await navigator.clipboard.writeText(promptText);
            Craft.cp.displayNotice('{{ "Prompt copied."|t("pragmatic-web-toolkit")|e("js") }}');
          } catch (error) {
            if (textarea) {
              textarea.focus();
              textarea.select();
            }
            Craft.cp.displayError('{{ "Could not copy automatically. Copy it manually from the textarea."|t("pragmatic-web-toolkit")|e("js") }}');
          }
        });
      }
      if (closeBtn) {
        closeBtn.addEventListener('click', () => modal.hide());
      }
    }

    document.querySelectorAll('.js-entry-slideout').forEach((link) => {
      link.addEventListener('click', (event) => {
        if (typeof Craft === 'undefined' || typeof Craft.createElementEditor !== 'function') {
          return;
        }

        event.preventDefault();
        const entryId = parseInt(link.dataset.entryId || '0', 10);
        const siteId = parseInt(link.dataset.siteId || '0', 10);
        if (!entryId) {
          return;
        }

        Craft.createElementEditor('craft\\elements\\Entry', {
          elementId: entryId,
          siteId: siteId || undefined,
          slideout: true
        });
      });
    });

    document.querySelectorAll('.js-generate-seo-row').forEach((button) => {
      button.addEventListener('click', async (event) => {
        event.preventDefault();
        if (typeof Craft === 'undefined' || typeof Craft.sendActionRequest !== 'function') {
          return;
        }

        const rowIndex = button.dataset.rowIndex || '';
        const originalLabel = button.textContent;
        button.disabled = true;
        button.classList.add('loading');

        try {
          const response = await Craft.sendActionRequest('POST', 'pragmatic-web-toolkit/seo/generate-content-suggestion', {
            data: {
              entryId: button.dataset.entryId,
              siteId: button.dataset.siteId,
              fieldHandle: button.dataset.fieldHandle,
            },
          });

          if (!response.data || !response.data.success) {
            throw new Error(response.data && response.data.error ? response.data.error : 'Could not generate SEO suggestion.');
          }

          if (response.data.mode === 'manual' && response.data.manualPrompt) {
            openManualPromptModal('{{ "SEO AI Prompt"|t("pragmatic-web-toolkit")|e("js") }}', response.data.manualPrompt);
            return;
          }

          const suggestion = response.data.suggestion || {};
          const titleField = document.querySelector(`textarea[name="entries[${rowIndex}][values][title]"]`);
          const descriptionField = document.querySelector(`textarea[name="entries[${rowIndex}][values][description]"]`);
          const imageInput = document.querySelector(`[name="entries[${rowIndex}][values][imageId]"], [name="entries[${rowIndex}][values][imageId][]"]`);
          const imageNote = document.querySelector(`[data-image-cell="${rowIndex}"] .js-generated-image-note`);
          const imageDescriptionField = document.querySelector(`.js-image-description-display[data-row-index="${rowIndex}"]`);

          if (titleField) titleField.value = suggestion.title || '';
          if (descriptionField) descriptionField.value = suggestion.description || '';
          if (imageInput) imageInput.value = suggestion.imageId || '';
          if (imageDescriptionField) imageDescriptionField.value = suggestion.image && suggestion.image.alt ? suggestion.image.alt : '';

          if (imageNote) {
            if (suggestion.image && suggestion.image.id) {
              imageNote.textContent = `{{ 'AI selected:'|t('pragmatic-web-toolkit')|e('js') }} ${suggestion.image.filename} (#${suggestion.image.id})`;
            } else if (suggestion.imageId) {
              imageNote.textContent = `{{ 'AI selected asset ID:'|t('pragmatic-web-toolkit')|e('js') }} ${suggestion.imageId}`;
            } else {
              imageNote.textContent = `{{ 'AI did not choose an image.'|t('pragmatic-web-toolkit')|e('js') }}`;
            }
          }

          Craft.cp.displayNotice(`{{ 'SEO suggestion generated.'|t('pragmatic-web-toolkit')|e('js') }}`);
        } catch (error) {
          const message = error && error.message ? error.message : `{{ 'Could not generate SEO suggestion.'|t('pragmatic-web-toolkit')|e('js') }}`;
          Craft.cp.displayError(message);
        } finally {
          button.disabled = false;
          button.classList.remove('loading');
          button.textContent = originalLabel;
        }
      });
    });
  {% endjs %}
{% endblock %}

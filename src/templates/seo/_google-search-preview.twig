{% set previewId = previewId ?? 'seo-google-preview' %}
{% set title = title ?? '' %}
{% set url = url ?? '' %}
{% set description = description ?? '' %}
{% set titleInputSelector = titleInputSelector ?? '' %}
{% set descriptionInputSelector = descriptionInputSelector ?? '' %}
{% set fallbackTitle = fallbackTitle ?? '' %}
{% set fallbackDescription = fallbackDescription ?? '' %}
{% set containerHeading = containerHeading ?? '' %}
{% set containerDescription = containerDescription ?? '' %}
{% set customizeEntrySeoSelector = customizeEntrySeoSelector ?? '' %}
{% set customizeEntrySeo = customizeEntrySeo ?? false %}
{% set resolvedTitle = title ?: fallbackTitle ?: 'Título SEO de ejemplo' %}
{% set resolvedDescription = description ?: fallbackDescription ?: 'La descripción SEO aparecerá aquí cuando añadas contenido.' %}

{% css %}
  .seo-preview-fieldset {
    min-inline-size: 0;
  }
  .seo-preview-meta {
    overflow: hidden;
  }
  .seo-preview-scale {
    zoom: 0.6;
    -moz-transform: scale(0.6);
    -moz-transform-origin: 0 0;
    width: 166.6667%;
  }
  .preview-column {
    width: 100%;
  }
  .displaypreview {
    border: none !important;
    padding: 12px 0 !important;
  }
  .metadata-title-separator {
    color: #5f6368 !important;
    font-size: 13px !important;
    font-weight: 600 !important;
    margin: 0 0 10px !important;
  }
  .metadata-title-separator span {
    position: relative;
  }
  .card-seo-google {
    font-family: Arial, sans-serif;
    max-width: 600px;
  }
  .card-seo-google__title {
    display: block;
    margin-bottom: 3px;
  }
  .card-seo-google__title a {
    color: #1a0dab;
    font-size: 26px;
    font-weight: 400;
    line-height: 1.3;
    text-decoration: none;
  }
  .card-seo-google__title a:hover {
    text-decoration: underline;
  }
  .card-seo-google__url {
    align-items: center;
    color: #202124;
    display: flex;
    font-size: 20px;
    gap: 8px;
    line-height: 1.4;
    margin-bottom: 6px;
  }
  .card-seo-google__url-title {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .card-seo-google__url-arrow {
    border-left: 5px solid transparent;
    border-right: 5px solid transparent;
    border-top: 6px solid #5f6368;
    display: inline-block;
    height: 0;
    width: 0;
  }
  .card-seo-google__description {
    color: #4d5156;
    display: block;
    font-size: 21px;
    line-height: 1.45;
    margin: 0;
  }
  .card-seo-google__description--muted {
    color: #9aa0a6;
  }
{% endcss %}

<fieldset class="seo-preview-fieldset">
  <legend class="h6">{{ containerHeading ?: 'SEO Preview' }}</legend>
  <div class="meta overflow-hidden">
    <div class="seo-preview-scale">
      <div class="preview-column">
        <div class="displaypreview">
          <h4 class="metadata-title-separator"><span>Google</span></h4>
          <div
            id="{{ previewId }}"
            class="card-seo-google"
            data-title-selector="{{ titleInputSelector }}"
            data-description-selector="{{ descriptionInputSelector }}"
            data-fallback-title="{{ fallbackTitle|e }}"
            data-fallback-description="{{ fallbackDescription|e }}"
            data-resolved-title="{{ resolvedTitle|e }}"
            data-resolved-description="{{ resolvedDescription|e }}"
            data-customize-entry-seo-selector="{{ customizeEntrySeoSelector }}"
            data-customize-entry-seo="{{ customizeEntrySeo ? '1' : '0' }}"
          >
            <span class="card-seo-google__title js-seo-search-preview-title">
              <a href="{{ url ?: '#' }}" rel="noopener" target="_blank" onclick="return false;">
                {{ resolvedTitle }}
              </a>
            </span>
            <div class="card-seo-google__url">
              <span class="card-seo-google__url-title">{{ url ?: 'example.com/url-de-la-entry' }}</span>
              <span class="card-seo-google__url-arrow"></span>
            </div>
            <span class="card-seo-google__description js-seo-search-preview-description{% if not description and not fallbackDescription %} card-seo-google__description--muted{% endif %}">
              {{ resolvedDescription }}
            </span>
          </div>
        </div>
      </div>
    </div>
  </div>
</fieldset>

{% js %}
  (() => {
    const root = document.getElementById({{ previewId|json_encode|raw }});
    if (!root) {
      return;
    }

    const titleEl = root.querySelector('.js-seo-search-preview-title a');
    const descriptionEl = root.querySelector('.js-seo-search-preview-description');
    const titleField = root.dataset.titleSelector ? document.querySelector(root.dataset.titleSelector) : null;
    const descriptionField = root.dataset.descriptionSelector ? document.querySelector(root.dataset.descriptionSelector) : null;
    const fallbackTitle = root.dataset.fallbackTitle || 'Título SEO de ejemplo';
    const fallbackDescription = root.dataset.fallbackDescription || 'La descripción SEO aparecerá aquí cuando añadas contenido.';
    const resolvedTitle = root.dataset.resolvedTitle || fallbackTitle;
    const resolvedDescription = root.dataset.resolvedDescription || fallbackDescription;
    const twigMarkers = {{ ['{{', '{%', '{#']|json_encode|raw }};
    const customizeEntrySeoField = root.dataset.customizeEntrySeoSelector ? document.querySelector(root.dataset.customizeEntrySeoSelector) : null;

    const hasTwigSyntax = (value) => twigMarkers.some((marker) => String(value || '').includes(marker));

    const update = () => {
      const customizeEntrySeo = customizeEntrySeoField
        ? !!customizeEntrySeoField.checked
        : root.dataset.customizeEntrySeo === '1';
      const rawTitle = (titleField?.value || '').trim();
      const rawDescription = (descriptionField?.value || '').trim();
      const nextTitle = customizeEntrySeo
        ? (hasTwigSyntax(rawTitle) ? resolvedTitle : (rawTitle || fallbackTitle))
        : resolvedTitle;
      const nextDescription = customizeEntrySeo
        ? (hasTwigSyntax(rawDescription) ? resolvedDescription : (rawDescription || fallbackDescription))
        : resolvedDescription;

      if (titleEl) {
        titleEl.textContent = nextTitle;
      }

      if (descriptionEl) {
        descriptionEl.textContent = nextDescription;
        descriptionEl.classList.toggle(
          'card-seo-google__description--muted',
          customizeEntrySeo ? (!rawDescription && !hasTwigSyntax(rawDescription)) : !resolvedDescription
        );
      }
    };

    titleField?.addEventListener('input', update);
    descriptionField?.addEventListener('input', update);
    customizeEntrySeoField?.addEventListener('change', update);
    update();
  })();
{% endjs %}

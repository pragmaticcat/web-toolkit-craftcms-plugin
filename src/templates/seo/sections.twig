{% extends 'pragmatic-web-toolkit/seo/_layout' %}
{% import '_includes/forms' as forms %}

{% set title = 'Sections' %}
{% set selectedTab = 'sections' %}

{% set crumbs = [
  { label: 'SEO', url: url('pragmatic-toolkit/seo') },
  { label: 'Sections', url: url('pragmatic-toolkit/seo/sections', { site: selectedSite.handle }) },
] %}

{% block sidebar %}
  <nav aria-label="Sections SEO">
    <ul class="nav">
      {% if sections|length %}
        {% for item in sections %}
          <li>
            <a class="{{ item.id == sectionId ? 'sel' : '' }}" href="{{ url('pragmatic-toolkit/seo/sections', { site: selectedSite.handle, section: item.id }) }}">
              {{ item.name }}
            </a>
          </li>
        {% endfor %}
      {% else %}
        <li class="heading"><span>No sections available</span></li>
      {% endif %}
    </ul>
  </nav>
{% endblock %}

{% block content %}
  {% css %}
    .seo-option-help {
      margin-top: -8px;
      margin-bottom: 14px;
      color: #606d7b;
      font-size: 12px;
    }
    .seo-option-help summary {
      cursor: pointer;
      user-select: none;
      font-weight: 600;
    }
    .seo-option-help p {
      margin: 6px 0 0;
      line-height: 1.45;
    }
    .seo-sections-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 18px;
      margin-bottom: 18px;
    }
    .seo-sections-block {
      border: 1px solid #e5e7eb;
      border-radius: 8px;
      padding: 14px;
      background: #fff;
    }
    .seo-sections-block h3 {
      margin: 0 0 4px;
      font-size: 15px;
    }
    .seo-sections-block > p {
      margin: 0 0 14px;
    }
    .seo-sections-block--entries {
      max-height: 720px;
      overflow-y: auto;
    }
    @media (max-width: 1023px) {
      .seo-sections-grid {
        grid-template-columns: 1fr;
      }
    }
  {% endcss %}

  {% if selectedSection %}
    <form method="post" accept-charset="UTF-8">
      {{ csrfInput() }}
      {{ actionInput('pragmatic-web-toolkit/seo/save-sections') }}
      {{ redirectInput('pragmatic-toolkit/seo/sections', { site: selectedSite.handle, section: selectedSection.id }) }}
      <input type="hidden" name="site" value="{{ selectedSiteId }}">
      <input type="hidden" name="sectionId" value="{{ selectedSection.id }}">

      <div class="seo-sections-grid">
        <section class="seo-sections-block seo-sections-block--entries">
          <h3>{{ selectedSection.name }}</h3>
          <p class="light">Define los valores SEO por defecto para las entries de esta section cuando no tengan activada la opción “Personalizar información SEO para esta entrada”. Si un campo queda vacío, se usará el valor global configurado en la tab Options.</p>

          {% include 'pragmatic-web-toolkit/seo/_title-site-settings' with {
            settings: settings,
            fieldPrefix: 'settings',
            isSectionOverride: true,
          } only %}
        </section>

        <section class="seo-sections-block">
          <h3>Entries de la section</h3>
          <p class="light">Activa o desactiva si cada entry de esta section debe usar una configuración SEO propia.</p>

          {% if entryRows|length %}
            <table class="data fullwidth">
              <thead>
                <tr>
                  <th>{{ 'Entry'|t('site') }}</th>
                  <th>
                    <label style="display:flex;align-items:center;gap:6px;">
                      <input type="checkbox" id="sections-select-all-customize">
                      <span>Personalizar información SEO para esta entrada</span>
                    </label>
                  </th>
                </tr>
              </thead>
              <tbody>
                {% for row in entryRows %}
                  {% set entry = row.entry %}
                  <tr>
                    <td>
                      <a href="{{ entry.cpEditUrl ?? '#' }}" {% if not entry.cpEditUrl %}style="pointer-events:none;opacity:.7;"{% endif %}>
                        {{ entry.title ?: ('(Untitled)'|t('site')) }}
                      </a>
                    </td>
                    <td>
                      <input type="hidden" name="entries[{{ loop.index0 }}][entryId]" value="{{ entry.id }}">
                      <input type="hidden" name="entries[{{ loop.index0 }}][fieldHandle]" value="{{ row.fieldHandle }}">
                      <input type="hidden" name="entries[{{ loop.index0 }}][customizeEntrySeo]" value="0">
                      <input type="checkbox" class="sections-customize-checkbox" name="entries[{{ loop.index0 }}][customizeEntrySeo]" value="1" {{ row.customizeEntrySeo ? 'checked' : '' }}>
                    </td>
                  </tr>
                {% endfor %}
              </tbody>
            </table>
          {% else %}
            <p class="light">No hay entries con campo SEO en esta section.</p>
          {% endif %}
        </section>
      </div>

      <button type="submit" class="btn submit">Guardar</button>
    </form>

    {% if entryRows|length %}
      <script>
        (() => {
          const selectAll = document.getElementById('sections-select-all-customize');
          const boxes = Array.from(document.querySelectorAll('.sections-customize-checkbox'));

          if (!selectAll || boxes.length === 0) {
            return;
          }

          const syncMaster = () => {
            const checkedCount = boxes.filter((box) => box.checked).length;
            selectAll.checked = checkedCount > 0 && checkedCount === boxes.length;
            selectAll.indeterminate = checkedCount > 0 && checkedCount < boxes.length;
          };

          selectAll.addEventListener('change', () => {
            boxes.forEach((box) => {
              box.checked = selectAll.checked;
            });
            selectAll.indeterminate = false;
          });

          boxes.forEach((box) => box.addEventListener('change', syncMaster));
          syncMaster();
        })();
      </script>
    {% endif %}
  {% else %}
    <p class="light">No sections with SEO fields are available for this site.</p>
  {% endif %}
{% endblock %}

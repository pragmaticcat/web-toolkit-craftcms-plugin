{% extends 'pragmatic-web-toolkit/seo/_layout' %}
{% import '_includes/forms' as forms %}

{% set title = 'Sections' %}
{% set selectedTab = 'sections' %}

{% set crumbs = [
  { label: 'SEO', url: url('pragmatic-toolkit/seo') },
  { label: 'Sections', url: url('pragmatic-toolkit/seo/sections', { site: selectedSite.handle }) },
] %}

{% block sidebar %}
  <nav aria-label="Sections SEO">
    <ul class="nav">
      {% if sections|length %}
        {% for item in sections %}
          <li>
            <a class="{{ item.id == sectionId ? 'sel' : '' }}" href="{{ url('pragmatic-toolkit/seo/sections', { site: selectedSite.handle, section: item.id }) }}">
              {{ item.name }}
            </a>
          </li>
        {% endfor %}
      {% else %}
        <li class="heading"><span>No sections available</span></li>
      {% endif %}
    </ul>
  </nav>
{% endblock %}

{% block content %}
  {% css %}
    .seo-option-help {
      margin-top: -8px;
      margin-bottom: 14px;
      color: #606d7b;
      font-size: 12px;
    }
    .seo-option-help summary {
      cursor: pointer;
      user-select: none;
      font-weight: 600;
    }
    .seo-option-help p {
      margin: 6px 0 0;
      line-height: 1.45;
    }
    .seo-sections-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 18px;
      margin-bottom: 18px;
    }
    .seo-sections-block {
      border: 1px solid #e5e7eb;
      border-radius: 8px;
      padding: 14px;
      background: #fff;
    }
    .seo-sections-block h3 {
      margin: 0 0 4px;
      font-size: 15px;
    }
    .seo-sections-block > p {
      margin: 0 0 14px;
    }
    .seo-sections-block--entries {
      max-height: 720px;
      overflow-y: scroll;
    }
    @media (max-width: 1023px) {
      .seo-sections-grid {
        grid-template-columns: 1fr;
      }
    }
  {% endcss %}

  {% if selectedSection %}
    <form method="post" accept-charset="UTF-8">
      {{ csrfInput() }}
      {{ actionInput('pragmatic-web-toolkit/seo/save-sections') }}
      {{ redirectInput('pragmatic-toolkit/seo/sections', { site: selectedSite.handle, section: selectedSection.id }) }}
      <input type="hidden" name="site" value="{{ selectedSiteId }}">
      <input type="hidden" name="sectionId" value="{{ selectedSection.id }}">

      <div class="seo-sections-grid">
        <section class="seo-sections-block">
          <h3>{{ selectedSection.name }}</h3>
          {% if showSectionSeoControls %}
            <p class="light">Activa esta opción para que las entries de esta section puedan heredar un SEO global de sección.</p>
            <input type="hidden" name="settings[enableSectionSeo]" value="0">
            {{ forms.lightswitchField({
              label: 'Activar SEO global para esta section',
              name: 'settings[enableSectionSeo]',
              on: settings.enableSectionSeo ?? false,
              value: 1,
              toggle: 'section-seo-settings-wrapper',
            }) }}
            <div id="section-seo-settings-wrapper"{% if not (settings.enableSectionSeo ?? false) %} style="display:none;"{% endif %}>
              <p class="light">Define los valores SEO por defecto para las entries de esta section que tengan activada la opción “Usar SEO global de la sección en esta entry”. Si un campo queda vacío, se usará el valor global configurado en la tab Options.</p>

              {% include 'pragmatic-web-toolkit/seo/_title-site-settings' with {
                settings: settings,
                fieldPrefix: 'settings',
                isSectionOverride: true,
              } only %}

              {{ forms.textField({
                label: 'Main Entity of Page',
                name: 'settings[mainEntityType]',
                value: settings.mainEntityType ?? '',
                placeholder: 'Vacío = heredar del site',
              }) }}
              <details class="seo-option-help">
                <summary>¿Qué hace este valor?</summary>
                <p>Override del tipo schema.org principal para las páginas de esta section. Ejemplos: <code>ProfessionalService</code>, <code>Dentist</code>, <code>LocalBusiness</code>, <code>LegalService</code>. Puedes consultar tipos válidos en <a href="https://schema.org/docs/full.html" target="_blank" rel="noopener">el directorio completo de schema.org</a>. Si lo dejas vacío, heredará el valor configurado en el site.</p>
              </details>
            </div>
          {% else %}
            <p class="light">El SEO global de section solo está disponible para sections de tipo channel o structure.</p>
          {% endif %}
        </section>

        <section class="seo-sections-block seo-sections-block--entries">
          <h3>Entries de la section</h3>
          {% if showSectionSeoControls %}
            <p class="light">Selecciona qué entries de esta section usarán el SEO global de la section cuando esté activado.</p>
          {% else %}
            <p class="light">Esta configuración no aplica a sections de tipo single.</p>
          {% endif %}

          {% if showSectionSeoControls and entryRows|length %}
            <div id="section-entry-seo-wrapper"{% if not (settings.enableSectionSeo ?? false) %} style="display:none;"{% endif %}>
            <table class="data fullwidth">
              <thead>
                <tr>
                  <th>{{ 'Entry'|t('site') }}</th>
                  <th>
                    <label style="display:flex;align-items:center;gap:6px;">
                      <input type="checkbox" id="sections-select-all-use-section-seo">
                      <span>Usar SEO global de la sección en esta entry</span>
                    </label>
                  </th>
                </tr>
              </thead>
              <tbody>
                {% for row in entryRows %}
                  {% set entry = row.entry %}
                  <tr>
                    <td>
                      <a href="{{ entry.cpEditUrl ?? '#' }}" {% if not entry.cpEditUrl %}style="pointer-events:none;opacity:.7;"{% endif %}>
                        {{ entry.title ?: ('(Untitled)'|t('site')) }}
                      </a>
                    </td>
                    <td>
                      <input type="hidden" name="entries[{{ loop.index0 }}][entryId]" value="{{ entry.id }}">
                      <input type="hidden" name="entries[{{ loop.index0 }}][fieldHandle]" value="{{ row.fieldHandle }}">
                      <input type="hidden" name="entries[{{ loop.index0 }}][useSectionSeo]" value="0">
                      <input type="checkbox" class="sections-use-section-seo-checkbox" name="entries[{{ loop.index0 }}][useSectionSeo]" value="1" {{ row.useSectionSeo ? 'checked' : '' }}>
                    </td>
                  </tr>
                {% endfor %}
              </tbody>
            </table>
            </div>
          {% elseif showSectionSeoControls %}
            <p class="light">No hay entries con campo SEO en esta section.</p>
          {% endif %}
        </section>
      </div>

      <button type="submit" class="btn submit">Guardar</button>
    </form>

    {% if showSectionSeoControls and entryRows|length %}
      <script>
        (() => {
          const selectAll = document.getElementById('sections-select-all-use-section-seo');
          const boxes = Array.from(document.querySelectorAll('.sections-use-section-seo-checkbox'));
          const sectionToggle = document.querySelector('[name="settings[enableSectionSeo]"][type="checkbox"]');
          const entryWrapper = document.getElementById('section-entry-seo-wrapper');

          if (!selectAll || boxes.length === 0) {
            return;
          }

          const syncMaster = () => {
            const checkedCount = boxes.filter((box) => box.checked).length;
            selectAll.checked = checkedCount > 0 && checkedCount === boxes.length;
            selectAll.indeterminate = checkedCount > 0 && checkedCount < boxes.length;
          };

          selectAll.addEventListener('change', () => {
            boxes.forEach((box) => {
              box.checked = selectAll.checked;
            });
            selectAll.indeterminate = false;
          });

          boxes.forEach((box) => box.addEventListener('change', syncMaster));
          sectionToggle?.addEventListener('change', () => {
            if (entryWrapper) {
              entryWrapper.style.display = sectionToggle.checked ? '' : 'none';
            }
          });
          syncMaster();
        })();
      </script>
    {% endif %}
  {% else %}
    <p class="light">No sections with SEO fields are available for this site.</p>
  {% endif %}
{% endblock %}

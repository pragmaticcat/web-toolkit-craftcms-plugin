{% extends 'pragmatic-web-toolkit/sync/_layout' %}
{% import '_includes/forms' as forms %}

{% set title = 'templates.sync.options.options'|t('pragmatic-web-toolkit') %}
{% set selectedTab = 'options' %}

{% block content %}
  {% css %}
    .sync-options-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 18px;
      margin-top: 18px;
    }
    .sync-options-card {
      border: 1px solid #e5e7eb;
      border-radius: 10px;
      padding: 18px;
      background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
    }
    .sync-options-card h2 {
      margin: 0 0 8px;
    }
    @media (max-width: 900px) {
      .sync-options-grid {
        grid-template-columns: 1fr;
      }
    }
  {% endcss %}

  <form method="post" accept-charset="UTF-8">
    {{ csrfInput() }}
    {{ actionInput('pragmatic-web-toolkit/sync/save-options') }}
    {{ redirectInput('pragmatic-toolkit/sync/options') }}

    <div class="sync-options-grid">
      <section class="sync-options-card">
        <h2>{{ 'templates.sync.options.support-boundary'|t('pragmatic-web-toolkit') }}</h2>
        <p class="light">{{ 'templates.sync.options.sync-is-a-manual-transfer-workflow-use-it-only-between-matching'|t('pragmatic-web-toolkit') }}</p>
        <ul>
          <li>{{ 'templates.sync.options.manual-package-transfer-only-no-direct-environment-to-environmen'|t('pragmatic-web-toolkit') }}</li>
          <li>{{ 'templates.sync.options.only-local-filesystem-asset-volumes-are-supported'|t('pragmatic-web-toolkit') }}</li>
          <li>{{ 'templates.sync.options.database-import-fully-replaces-the-target-database-using-a-pure'|t('pragmatic-web-toolkit') }}</li>
          <li>{{ 'templates.sync.options.asset-import-merges-imported-files-into-local-volume-roots-and-o'|t('pragmatic-web-toolkit') }}</li>
          <li>{{ 'templates.sync.options.views-triggers-routines-and-events-are-detected-and-warned-about'|t('pragmatic-web-toolkit') }}</li>
          <li>{{ 'templates.sync.options.target-only-asset-files-remain-on-disk-and-may-become-orphaned-a'|t('pragmatic-web-toolkit') }}</li>
        </ul>
      </section>

      <section class="sync-options-card">
        <h2>{{ 'templates.sync.options.retention'|t('pragmatic-web-toolkit') }}</h2>
        <p class="light">{{ 'templates.sync.options.control-how-long-staged-uploads-export-artifacts-and-transfer-lo'|t('pragmatic-web-toolkit') }}</p>

        {{ forms.textField({
          label: 'templates.sync.options.staged-upload-retention-hours'|t('pragmatic-web-toolkit'),
          name: 'settings[stagedUploadRetentionHours]',
          value: settings.stagedUploadRetentionHours,
          type: 'number',
          min: 1,
          max: 72,
        }) }}

        {{ forms.textField({
          label: 'templates.sync.options.history-retention-days'|t('pragmatic-web-toolkit'),
          name: 'settings[historyRetentionDays]',
          value: settings.historyRetentionDays,
          type: 'number',
          min: 1,
          max: 365,
        }) }}

        {{ forms.textField({
          label: 'templates.sync.options.export-artifact-retention-hours'|t('pragmatic-web-toolkit'),
          name: 'settings[exportArtifactRetentionHours]',
          value: settings.exportArtifactRetentionHours,
          type: 'number',
          min: 1,
          max: 168,
        }) }}
      </section>

      <section class="sync-options-card">
        <h2>{{ 'templates.sync.options.database-dump-tuning'|t('pragmatic-web-toolkit') }}</h2>
        <p class="light">{{ 'templates.sync.options.tune-the-pure-php-my-sql-maria-db-dump-format-for-large-environm'|t('pragmatic-web-toolkit') }}</p>

        {{ forms.textField({
          label: 'templates.sync.options.insert-batch-row-count'|t('pragmatic-web-toolkit'),
          name: 'settings[insertBatchRowCount]',
          value: settings.insertBatchRowCount,
          type: 'number',
          min: 1,
          max: 5000,
        }) }}

        {{ forms.textField({
          label: 'templates.sync.options.select-chunk-size'|t('pragmatic-web-toolkit'),
          name: 'settings[selectChunkSize]',
          value: settings.selectChunkSize,
          type: 'number',
          min: 1,
          max: 10000,
        }) }}
      </section>
    </div>

    <div class="buttons" style="margin-top: 18px;">
      <button class="btn submit" type="submit">{{ 'templates.sync.options.save'|t('pragmatic-web-toolkit') }}</button>
    </div>
  </form>
{% endblock %}

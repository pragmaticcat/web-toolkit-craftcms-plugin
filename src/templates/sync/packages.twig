{% extends 'pragmatic-web-toolkit/sync/_layout' %}

{% set title = 'templates.sync.packages.packages'|t('pragmatic-web-toolkit') %}
{% set selectedTab = 'packages' %}

{% block content %}
  {% css %}
    .sync-grid { display: grid; gap: 18px; margin-top: 18px; }
    .sync-card { border: 1px solid #e5e7eb; border-radius: 10px; padding: 18px; background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%); }
    .sync-card h2, .sync-card h3 { margin: 0 0 8px; }
    .sync-summary-list, .sync-warning-list { margin: 0; padding-left: 18px; }
    .sync-warning-list li { margin-bottom: 6px; }
    .sync-kpi-grid { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 12px; margin: 12px 0 18px; }
    .sync-kpi { border: 1px solid #dbe4f0; border-radius: 8px; padding: 12px; background: #fff; }
    .sync-kpi strong { display: block; font-size: 19px; margin-bottom: 4px; }
    .sync-inline-form { display: flex; gap: 10px; align-items: flex-end; flex-wrap: wrap; }
    .sync-result { padding: 12px 14px; border-radius: 8px; margin-bottom: 16px; }
    .sync-result.success { background: #ecfdf5; border: 1px solid #10b981; color: #065f46; }
    .sync-result.error { background: #fef2f2; border: 1px solid #ef4444; color: #991b1b; }
    .sync-history-table th, .sync-history-table td { vertical-align: top; }
    @media (max-width: 900px) { .sync-kpi-grid { grid-template-columns: 1fr; } }
  {% endcss %}

  {% if importResult %}
    <div class="sync-result {{ importResult.type }}">{{ importResult.message }}</div>
  {% endif %}

  <div class="sync-grid">
    <section class="sync-card">
      <h2>{{ 'templates.sync.packages.export-package'|t('pragmatic-web-toolkit') }}</h2>
      <p class="light">{{ 'templates.sync.packages.create-a-manual-transfer-package-from-this-craft-environment-exp'|t('pragmatic-web-toolkit') }}</p>
      <ul class="sync-summary-list">
        <li>{{ 'templates.sync.packages.choose-whether-to-export-the-database-the-local-assets-or-both'|t('pragmatic-web-toolkit') }}</li>
        <li>{{ 'templates.sync.packages.database-exports-use-the-pure-php-my-sql-maria-db-table-dump'|t('pragmatic-web-toolkit') }}</li>
        <li>{{ 'templates.sync.packages.asset-exports-include-all-local-asset-volumes-configured-in-craf'|t('pragmatic-web-toolkit') }}</li>
        <li>{{ 'templates.sync.packages.every-package-includes-manifest-metadata-for-compatibility-check'|t('pragmatic-web-toolkit') }}</li>
      </ul>
      <p class="warning" style="margin-top: 14px;">{{ 'templates.sync.packages.import-packages-only-into-matching-environments-that-already-run'|t('pragmatic-web-toolkit') }}</p>

      <form method="post" accept-charset="UTF-8" style="margin-top: 14px;">
        {{ csrfInput() }}
        {{ actionInput('pragmatic-web-toolkit/sync/export') }}
        <div class="field" style="max-width: 280px; margin-bottom: 14px;">
          <label for="sync-export-mode">{{ 'templates.sync.packages.export-contents'|t('pragmatic-web-toolkit') }}</label>
          <select id="sync-export-mode" name="exportMode">
            <option value="db">{{ 'templates.sync.packages.bbdd-only'|t('pragmatic-web-toolkit') }}</option>
            <option value="assets">{{ 'templates.sync.packages.assets-only'|t('pragmatic-web-toolkit') }}</option>
            <option value="both" selected>{{ 'templates.sync.packages.bbdd-assets'|t('pragmatic-web-toolkit') }}</option>
          </select>
        </div>
        <button class="btn submit" type="submit">{{ 'templates.sync.packages.export-package'|t('pragmatic-web-toolkit') }}</button>
      </form>
    </section>

    <section class="sync-card">
      <h2>{{ 'templates.sync.packages.import-package'|t('pragmatic-web-toolkit') }}</h2>
      <p class="light">{{ 'templates.sync.packages.upload-a-sync-package-to-validate-it-first-import-runs-in-the-qu'|t('pragmatic-web-toolkit') }}</p>

      <form method="post" enctype="multipart/form-data" accept-charset="UTF-8">
        {{ csrfInput() }}
        {{ actionInput('pragmatic-web-toolkit/sync/upload-import-package') }}
        <div class="sync-inline-form">
          <div>
            <label for="sync-package-file">{{ 'templates.sync.packages.zip-package'|t('pragmatic-web-toolkit') }}</label>
            <input id="sync-package-file" type="file" name="file" accept=".zip,application/zip" required>
          </div>
          <button class="btn" type="submit">{{ 'templates.sync.packages.upload-package'|t('pragmatic-web-toolkit') }}</button>
        </div>
      </form>

      {% if preflight %}
        <hr style="margin: 18px 0;">
        <h3>{{ 'templates.sync.packages.preflight-summary'|t('pragmatic-web-toolkit') }}</h3>
        <p class="light">{{ preflight.packageName }}</p>

        <div class="sync-kpi-grid">
          <div class="sync-kpi"><strong>{{ preflight.summary.exportMode ?: 'both' }}</strong>{{ 'templates.sync.packages.export-mode'|t('pragmatic-web-toolkit') }}</div>
          <div class="sync-kpi"><strong>{{ preflight.summary.craftVersion ?: 'n/a' }}</strong>{{ 'templates.sync.packages.craft-version'|t('pragmatic-web-toolkit') }}</div>
          <div class="sync-kpi"><strong>{{ preflight.summary.pluginVersion ?: 'n/a' }}</strong>{{ 'templates.sync.packages.plugin-version'|t('pragmatic-web-toolkit') }}</div>
          <div class="sync-kpi"><strong>{{ preflight.summary.dbEngine ?: 'n/a' }}</strong>{{ 'templates.sync.packages.db-engine'|t('pragmatic-web-toolkit') }}</div>
          <div class="sync-kpi"><strong>{{ preflight.summary.serverVersion ?: 'n/a' }}</strong>{{ 'templates.sync.packages.db-server-version'|t('pragmatic-web-toolkit') }}</div>
          <div class="sync-kpi"><strong>{{ preflight.summary.tablePrefix ?: '(none)' }}</strong>{{ 'templates.sync.packages.table-prefix'|t('pragmatic-web-toolkit') }}</div>
          <div class="sync-kpi"><strong>{{ preflight.summary.tableCount }}</strong>{{ 'templates.sync.packages.table-count'|t('pragmatic-web-toolkit') }}</div>
          <div class="sync-kpi"><strong>{{ preflight.summary.volumeCount }}</strong>{{ 'templates.sync.packages.included-volumes'|t('pragmatic-web-toolkit') }}</div>
          <div class="sync-kpi"><strong>{{ preflight.summary.fileCount }}</strong>{{ 'templates.sync.packages.asset-files'|t('pragmatic-web-toolkit') }}</div>
        </div>

        <p><strong>{{ 'templates.sync.packages.created'|t('pragmatic-web-toolkit') }}:</strong> {{ preflight.summary.createdAt ?: 'n/a' }}</p>
        <p><strong>{{ 'templates.sync.packages.asset-bytes'|t('pragmatic-web-toolkit') }}:</strong> {{ preflight.summary.totalBytes }}</p>
        <p><strong>{{ 'templates.sync.packages.database-included'|t('pragmatic-web-toolkit') }}:</strong> {{ preflight.summary.includesDatabase ? 'templates.sync.packages.yes'|t('pragmatic-web-toolkit') : 'templates.sync.packages.no'|t('pragmatic-web-toolkit') }}</p>
        <p><strong>{{ 'templates.sync.packages.assets-included'|t('pragmatic-web-toolkit') }}:</strong> {{ preflight.summary.includesAssets ? 'templates.sync.packages.yes'|t('pragmatic-web-toolkit') : 'templates.sync.packages.no'|t('pragmatic-web-toolkit') }}</p>

        {% if preflight.manifest.includedVolumes ?? [] %}
          <h3 style="margin-top: 18px;">{{ 'templates.sync.packages.included-volumes'|t('pragmatic-web-toolkit') }}</h3>
          <ul class="sync-summary-list">
            {% for volume in preflight.manifest.includedVolumes %}
              <li><strong>{{ volume.handle }}</strong> - {{ volume.fileCount }} {{ 'templates.sync.packages.files'|t('pragmatic-web-toolkit') }}, {{ volume.totalBytes }} {{ 'templates.sync.packages.bytes'|t('pragmatic-web-toolkit') }}</li>
            {% endfor %}
          </ul>
        {% endif %}

        {% if preflight.warnings %}
          <div class="warning" style="margin-top: 16px;">
            <strong>{{ 'templates.sync.packages.warnings'|t('pragmatic-web-toolkit') }}</strong>
            <ul class="sync-warning-list">
              {% for warning in preflight.warnings %}
                <li>{{ warning }}</li>
              {% endfor %}
            </ul>
          </div>
        {% endif %}

        {% if preflight.errors %}
          <div class="error" style="margin-top: 16px; padding: 12px 14px; border-radius: 8px;">
            <strong>{{ 'templates.sync.packages.package-blocked'|t('pragmatic-web-toolkit') }}</strong>
            <ul class="sync-warning-list">
              {% for error in preflight.errors %}
                <li>{{ error }}</li>
              {% endfor %}
            </ul>
          </div>
        {% else %}
          <form method="post" accept-charset="UTF-8" style="margin-top: 18px;">
            {{ csrfInput() }}
            {{ actionInput('pragmatic-web-toolkit/sync/confirm-import') }}
            <input type="hidden" name="token" value="{{ preflight.token }}">

            <div class="field">
              <label>
                <input type="checkbox" name="acknowledgeImport" value="1">
                {{ 'templates.sync.packages.i-understand-this-import-will-apply-only-the-contents-included-i'|t('pragmatic-web-toolkit') }}
              </label>
            </div>

            <div class="field" style="max-width: 280px;">
              <label for="sync-confirmation">{{ 'templates.sync.packages.type-import-to-continue'|t('pragmatic-web-toolkit') }}</label>
              <input id="sync-confirmation" class="text fullwidth" type="text" name="confirmation" value="">
            </div>

            <button class="btn submit" type="submit">{{ 'templates.sync.packages.queue-import'|t('pragmatic-web-toolkit') }}</button>
          </form>
        {% endif %}
      {% endif %}
    </section>

    <section class="sync-card">
      <h2>{{ 'templates.sync.packages.history'|t('pragmatic-web-toolkit') }}</h2>
      <p class="light">{{ 'templates.sync.packages.recent-sync-exports-and-imports'|t('pragmatic-web-toolkit') }}</p>

      <table class="data fullwidth sync-history-table">
        <thead>
          <tr>
            <th>{{ 'templates.sync.packages.direction'|t('pragmatic-web-toolkit') }}</th>
            <th>{{ 'templates.sync.packages.status'|t('pragmatic-web-toolkit') }}</th>
            <th>{{ 'templates.sync.packages.created-at'|t('pragmatic-web-toolkit') }}</th>
            <th>{{ 'templates.sync.packages.created-by'|t('pragmatic-web-toolkit') }}</th>
            <th>{{ 'templates.sync.packages.progress'|t('pragmatic-web-toolkit') }}</th>
            <th>{{ 'templates.sync.packages.package-summary'|t('pragmatic-web-toolkit') }}</th>
            <th>{{ 'templates.sync.packages.warnings'|t('pragmatic-web-toolkit') }}</th>
            <th>{{ 'templates.sync.packages.notes-errors'|t('pragmatic-web-toolkit') }}</th>
            <th>{{ 'templates.sync.packages.actions'|t('pragmatic-web-toolkit') }}</th>
          </tr>
        </thead>
        <tbody>
          {% for row in history %}
            <tr>
              <td>{{ row.direction }}</td>
              <td>{{ row.status }}</td>
              <td>{{ row.createdAt }}</td>
              <td>{{ row.triggeredBy ?: 'templates.sync.packages.system'|t('pragmatic-web-toolkit') }}</td>
              <td>{{ row.progressLabel ?: '-' }}</td>
              <td>
                <strong>{{ row.packageName }}</strong>
                {% if row.summary %}
                  <div class="light">{{ row.summary }}</div>
                {% endif %}
              </td>
              <td>
                {% if row.warnings %}
                  <ul class="sync-warning-list">
                    {% for warning in row.warnings %}
                      <li>{{ warning }}</li>
                    {% endfor %}
                  </ul>
                {% else %}
                  -
                {% endif %}
              </td>
              <td>{{ row.errorMessage ?: '-' }}</td>
              <td>
                {% if row.canDownload %}
                  <a class="btn small" href="{{ url('pragmatic-toolkit/sync/download-export/' ~ row.id) }}">{{ 'templates.sync.packages.download-package'|t('pragmatic-web-toolkit') }}</a>
                {% else %}
                  -
                {% endif %}
              </td>
            </tr>
          {% else %}
            <tr>
              <td colspan="9" class="light">{{ 'templates.sync.packages.no-sync-history-yet'|t('pragmatic-web-toolkit') }}</td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </section>
  </div>
{% endblock %}

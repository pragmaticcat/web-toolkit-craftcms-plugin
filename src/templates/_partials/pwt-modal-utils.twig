{% css %}
  .pwt-unified-modal {
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }
  .pwt-unified-modal .body {
    flex: 1 1 auto;
    min-height: 0;
    overflow: auto;
  }
  .pwt-unified-modal .footer {
    flex: 0 0 auto;
    position: sticky;
    bottom: 0;
    background: #fff;
    border-top: 1px solid #e5e7eb;
    z-index: 3;
    min-height: 56px;
    padding: 10px 16px;
    display: flex;
    align-items: center;
  }
  .pwt-unified-modal .footer .buttons,
  .pwt-unified-modal .footer .btngroup {
    margin: 0;
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
    width: 100%;
  }
  .pwt-unified-modal--large {
    width: 1400px;
    max-width: 1400px;
    height: 92vh;
    max-height: 92vh;
  }
  .pwt-unified-modal--compact {
    width: min(760px, 92vw);
    max-height: 80vh;
  }
{% endcss %}

{% js %}
  (function() {
    if (window.PWTUnifiedModal) {
      return;
    }

    window.PWTUnifiedModal = {
      create: function(options) {
        const opts = options || {};
        const size = opts.size === 'compact' ? 'compact' : 'large';
        const modalEl = document.createElement('div');
        modalEl.className = 'modal pwt-unified-modal pwt-unified-modal--' + size;
        modalEl.innerHTML = '' +
          '<div class="body"><div class="content">' +
            (opts.title ? ('<h2 style="margin-top:0;">' + opts.title + '</h2>') : '') +
            (opts.bodyHtml || '') +
          '</div></div>' +
          '<div class="footer"><div class="' + (opts.footerGroupClass || 'buttons') + '">' +
            (opts.footerHtml || '') +
          '</div></div>';

        const modal = new Garnish.Modal(modalEl, {
          autoShow: true,
          closeOtherModals: !!opts.closeOtherModals,
          onHide: function() {
            modal.destroy();
          },
        });

        modalEl.querySelectorAll('[data-action="close"]').forEach(function(button) {
          button.addEventListener('click', function() {
            modal.hide();
          });
        });

        return { modal: modal, modalEl: modalEl };
      },
    };

    function enforceSize(modalEl) {
      if (!(modalEl instanceof HTMLElement) || !modalEl.classList.contains('pwt-unified-modal')) {
        return;
      }
      if (modalEl.classList.contains('pwt-unified-modal--large')) {
        modalEl.style.setProperty('width', '1400px', 'important');
        modalEl.style.setProperty('min-width', '1400px', 'important');
        modalEl.style.setProperty('max-width', '1400px', 'important');
      } else if (modalEl.classList.contains('pwt-unified-modal--compact')) {
        modalEl.style.setProperty('width', '760px', 'important');
        modalEl.style.setProperty('min-width', '760px', 'important');
        modalEl.style.setProperty('max-width', '760px', 'important');
      }
    }

    function attachStyleObserver(modalEl) {
      if (!(modalEl instanceof HTMLElement) || modalEl.__pwtStyleObserverAttached) {
        return;
      }
      modalEl.__pwtStyleObserverAttached = true;
      const styleObserver = new MutationObserver(function() {
        enforceSize(modalEl);
      });
      styleObserver.observe(modalEl, {
        attributes: true,
        attributeFilter: ['style', 'class'],
      });
    }

    function initModalElement(modalEl) {
      enforceSize(modalEl);
      attachStyleObserver(modalEl);
      requestAnimationFrame(function() { enforceSize(modalEl); });
      setTimeout(function() { enforceSize(modalEl); }, 0);
      setTimeout(function() { enforceSize(modalEl); }, 80);
    }

    document.querySelectorAll('.pwt-unified-modal').forEach(initModalElement);
    const observer = new MutationObserver(function(mutations) {
      mutations.forEach(function(mutation) {
        mutation.addedNodes.forEach(function(node) {
          if (!(node instanceof HTMLElement)) {
            return;
          }
          if (node.matches('.pwt-unified-modal')) {
            initModalElement(node);
          }
          node.querySelectorAll?.('.pwt-unified-modal').forEach(initModalElement);
        });
      });
    });
    observer.observe(document.body, { childList: true, subtree: true });
  })();
{% endjs %}

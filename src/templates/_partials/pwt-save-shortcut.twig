{% js %}
  (function() {
    if (window.__pwtSaveShortcutBound) {
      return;
    }
    window.__pwtSaveShortcutBound = true;

    function isEligibleButton(el) {
      if (!el || el.disabled) return false;
      if (el.classList && el.classList.contains('danger')) return false;
      if (el.closest && el.closest('.modal')) return false;
      return true;
    }

    function submitViaButton(button) {
      if (!button) return false;
      const form = button.form || (button.getAttribute ? document.getElementById(button.getAttribute('form') || '') : null);
      if (!form) return false;

      if (typeof form.requestSubmit === 'function') {
        form.requestSubmit(button);
      } else if (typeof button.click === 'function') {
        button.click();
      } else {
        form.submit();
      }
      return true;
    }

    document.addEventListener('keydown', function(event) {
      const key = String(event.key || '').toLowerCase();
      if (key !== 's') return;
      if (!(event.metaKey || event.ctrlKey) || event.altKey || event.shiftKey) return;

      const explicitButton = document.querySelector('[data-pwt-save-shortcut]:not([disabled])');
      const genericButton = Array.from(document.querySelectorAll('button[type="submit"], input[type="submit"], button[data-pwt-save-shortcut], button[form], input[form]'))
        .find(isEligibleButton);
      const targetButton = isEligibleButton(explicitButton) ? explicitButton : genericButton;
      if (!targetButton) return;

      event.preventDefault();
      if (window.Craft && Craft.cp && typeof Craft.cp.displayNotice === 'function') {
        Craft.cp.displayNotice('{{ 'templates.pwt.save-shortcut.saving'|t('pragmatic-web-toolkit')|e('js') }}');
      }
      submitViaButton(targetButton);
    });
  })();
{% endjs %}

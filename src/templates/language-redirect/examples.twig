{% extends 'pragmatic-web-toolkit/language-redirect/_layout' %}

{% set title = 'Language Redirect Examples' %}
{% set selectedTab = 'examples' %}

{% set crumbs = [
  { label: 'Language Redirect', url: url('pragmatic-toolkit/language-redirect', { site: selectedSite.handle }) },
  { label: 'Examples', url: url('pragmatic-toolkit/language-redirect/examples', { site: selectedSite.handle }) },
] %}

{% block content %}
  {% css %}
    .language-redirect-examples {
      display: grid;
      gap: 18px;
    }
    .language-redirect-block {
      border: 1px solid #e5e7eb;
      border-radius: 8px;
      padding: 14px;
      background: #fff;
    }
    .language-redirect-block h3 {
      margin: 0 0 6px;
      font-size: 15px;
    }
    .language-redirect-block > p {
      margin: 0 0 12px;
    }
    .language-redirect-code {
      margin-top: 12px;
      padding: 12px 14px;
      border-radius: 8px;
      background: #0f172a;
      color: #e2e8f0;
      overflow-x: auto;
    }
    .language-redirect-code code {
      font-family: Menlo, Monaco, Consolas, monospace;
      font-size: 12px;
      white-space: pre-wrap;
      display: block;
      tab-size: 2;
    }
  {% endcss %}

  <div class="language-redirect-examples">
    <section class="language-redirect-block">
      <h3>Manual preference</h3>
      <p class="light">Direct URL example when you want the current page to persist a new language before redirecting.</p>

      <div class="language-redirect-code"><code>{{ '{currentUrl}'|e }}?{{ settings.persistQueryParam ?? 'lang' }}=es</code></div>
      <div class="language-redirect-code"><code>{{ '{{ siteSwitcher(\'espanol\', element) }}'|e }}</code></div>
    </section>

    <section class="language-redirect-block">
      <h3>All sites dropdown</h3>
      <p class="light">Loop through every available site using the switcher helper links.</p>

      <div class="language-redirect-code"><code>{{ '<ul class="dropdown-menu">'|e }}
{{ '    {% for item in craft.pragmaticToolkit.languageSwitcherLinks(entry ?? null) %}'|e }}
{{ '        <li><a class="dropdown-item {{ item.language == currentSite.locale ? \'active\' : \'\' }}"'|e }}
{{ '            href="{{ item.url }}" hreflang="{{ item.language }}"{{ item.isCurrent ? \' aria-current="page"\' : \'\' }}>{{ item.site.name }}</a></li>'|e }}
{{ '    {% endfor %}'|e }}
{{ '</ul>'|e }}</code></div>
    </section>

    <section class="language-redirect-block">
      <h3>Site group filter</h3>
      <p class="light">Loop only through the sites that belong to a specific site group.</p>

      <div class="language-redirect-code"><code>{{ '{% for item in craft.pragmaticToolkit.languageSwitcherLinks(entry ?? null, 1) %}'|e }}
{{ '    <a href="{{ item.url }}">{{ item.site.name }}</a>'|e }}
{{ '{% endfor %}'|e }}</code></div>

      <div class="language-redirect-code"><code>{{ '{% for item in craft.pragmaticToolkit.languageSwitcherLinks(entry ?? null, \'Corporate\') %}'|e }}
{{ '    <a href="{{ item.url }}">{{ item.site.name }}</a>'|e }}
{{ '{% endfor %}'|e }}</code></div>
    </section>

    <section class="language-redirect-block">
      <h3>Explicit site list</h3>
      <p class="light">Loop only through the sites you choose, preserving the order of the array you pass in.</p>

      <div class="language-redirect-code"><code>{{ '{% for item in craft.pragmaticToolkit.languageSwitcherLinks(entry ?? null, [1, 3, 5]) %}'|e }}
{{ '    <a href="{{ item.url }}">{{ item.site.name }}</a>'|e }}
{{ '{% endfor %}'|e }}</code></div>

      <div class="language-redirect-code"><code>{{ '{% for item in craft.pragmaticToolkit.languageSwitcherLinks(entry ?? null, [\'catala\', \'english\']) %}'|e }}
{{ '    <a href="{{ item.url }}">{{ item.site.name }}</a>'|e }}
{{ '{% endfor %}'|e }}</code></div>
    </section>

    <section class="language-redirect-block">
      <h3>Combined filter</h3>
      <p class="light">Apply a site-group constraint and also limit the switcher to a custom list.</p>

      <div class="language-redirect-code"><code>{{ '{% for item in craft.pragmaticToolkit.languageSwitcherLinks(entry ?? null, {'|e }}
{{ '    siteGroup: 1,'|e }}
{{ '    sites: [1, 3]'|e }}
{{ '}) %}'|e }}
{{ '    <a href="{{ item.url }}">{{ item.site.name }}</a>'|e }}
{{ '{% endfor %}'|e }}</code></div>
    </section>
  </div>
{% endblock %}

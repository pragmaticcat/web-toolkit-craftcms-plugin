{% extends 'pragmatic-web-toolkit/cookies/_layout' %}

{% set title = 'templates.cookies.cookies.title'|t('pragmatic-web-toolkit') %}
{% set selectedTab = 'cookies' %}
{% set _siteHandle = craft.app.request.getQueryParam('site') %}
{% set _siteParam = _siteHandle ? { site: _siteHandle } : {} %}

{% block content %}

  <div class="toolbar">
    <button class="btn submit add icon" id="new-cookie-btn" >{{ 'templates.cookies.cookies.new-cookie'|t('pragmatic-web-toolkit') }}</button>
    <button class="btn" id="scan-cookies-btn" >{{ 'templates.cookies.cookies.scan-cookies'|t('pragmatic-web-toolkit') }}</button>
  </div>

  {% if cookies|length %}
    <div class="tableview">
      <table class="data fullwidth">
        <thead>
          <tr>
            <th>{{ 'templates.cookies.cookies.table-name'|t('pragmatic-web-toolkit') }}</th>
            <th>{{ 'templates.cookies.cookies.table-provider'|t('pragmatic-web-toolkit') }}</th>
            <th>{{ 'templates.cookies.cookies.table-category'|t('pragmatic-web-toolkit') }}</th>
            <th>{{ 'templates.cookies.cookies.table-duration'|t('pragmatic-web-toolkit') }}</th>
            <th>{{ 'templates.cookies.cookies.table-regex'|t('pragmatic-web-toolkit') }}</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          {% for cookie in cookies %}
            <tr>
              <td>
                
                  <a href="#" class="edit-cookie-btn" data-id="{{ cookie.id }}" data-name="{{ cookie.name }}" data-provider="{{ cookie.provider }}" data-description="{{ cookie.description }}" data-duration="{{ cookie.duration }}" data-category-id="{{ cookie.categoryId }}" data-is-regex="{{ cookie.isRegex ? '1' : '0' }}">{{ cookie.name }}</a>
                
              </td>
              <td>{{ cookie.provider }}</td>
              <td>{% set cat = categories|filter(c => c.id == cookie.categoryId)|first %}{{ cat ? cat.name : 'templates.cookies.common.empty'|t('pragmatic-web-toolkit') }}</td>
              <td>{{ cookie.duration ?? 'templates.cookies.common.empty'|t('pragmatic-web-toolkit') }}</td>
              <td>{{ cookie.isRegex ? 'templates.cookies.common.yes'|t('pragmatic-web-toolkit') : 'templates.cookies.common.no'|t('pragmatic-web-toolkit') }}</td>
              <td class="thin"><a class="delete icon" role="button" data-cookie-id="{{ cookie.id }}"></a>{% endif %}</td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  

  <div id="cookie-modal" class="modal" style="display:none;">
    <form method="post" accept-charset="UTF-8">
      {{ csrfInput() }}
      {{ actionInput('pragmatic-web-toolkit/cookies/save-cookie') }}
      {{ redirectInput('pragmatic-toolkit/cookies/cookies', _siteParam) }}
      <input type="hidden" name="cookieId" id="modal-cookie-id" value="">
      <input type="hidden" name="site" value="{{ selectedSiteId ?? craft.app.sites.currentSite.id }}">
      <div class="body">
        <div class="field"><div class="heading"><label for="modal-name">{{ 'templates.cookies.cookies.modal-name'|t('pragmatic-web-toolkit') }}</label></div><div class="input"><input type="text" id="modal-name" name="name" class="text fullwidth" required></div></div>
        <div class="field"><div class="heading"><label for="modal-provider">{{ 'templates.cookies.cookies.modal-provider'|t('pragmatic-web-toolkit') }}</label></div><div class="input"><input type="text" id="modal-provider" name="provider" class="text fullwidth"></div></div>
        <div class="field"><div class="heading"><label for="modal-category">{{ 'templates.cookies.cookies.modal-category'|t('pragmatic-web-toolkit') }}</label></div><div class="input"><select id="modal-category" name="categoryId" class="fullwidth"><option value="">{{ 'templates.cookies.cookies.modal-uncategorized'|t('pragmatic-web-toolkit') }}</option>{% for cat in categories %}<option value="{{ cat.id }}">{{ cat.name }}</option>{% endfor %}</select></div></div>
        <div class="field"><div class="heading"><label for="modal-description">{{ 'templates.cookies.cookies.modal-description'|t('pragmatic-web-toolkit') }}</label></div><div class="input"><textarea id="modal-description" name="description" class="text fullwidth" rows="2"></textarea></div></div>
        <div class="field"><div class="heading"><label for="modal-duration">{{ 'templates.cookies.cookies.modal-duration'|t('pragmatic-web-toolkit') }}</label></div><div class="input"><input type="text" id="modal-duration" name="duration" class="text fullwidth"></div></div>
        <div class="field"><div class="heading"><label>{{ 'templates.cookies.cookies.modal-regex'|t('pragmatic-web-toolkit') }}</label></div><div class="input"><label><input type="checkbox" id="modal-is-regex" name="isRegex" value="1"> {{ 'templates.cookies.cookies.modal-regex-help'|t('pragmatic-web-toolkit') }}</label></div></div>
      </div>
      <div class="footer"><div class="btngroup"><button type="submit" class="btn submit">{{ 'templates.cookies.actions.save'|t('pragmatic-web-toolkit') }}</button><button type="button" class="btn cancel-modal">{{ 'templates.cookies.actions.cancel'|t('pragmatic-web-toolkit') }}</button></div></div>
    </form>
  </div>

  {% js %}
    (function() {
      var existingNames = {{ cookies|map(c => c.name)|json_encode|raw }};
      var modal = document.getElementById('cookie-modal');
      var modalInstance = new Garnish.Modal(modal, { autoShow: false, closeOtherModals: true });
      function openModal() { modalInstance.show(); }
      function closeModal() { modalInstance.hide(); }
      function resetForm() { document.getElementById('modal-cookie-id').value=''; document.getElementById('modal-name').value=''; document.getElementById('modal-provider').value=''; document.getElementById('modal-category').value=''; document.getElementById('modal-description').value=''; document.getElementById('modal-duration').value=''; document.getElementById('modal-is-regex').checked=false; }
      document.getElementById('new-cookie-btn').addEventListener('click', function() { resetForm(); openModal(); });
      document.getElementById('scan-cookies-btn').addEventListener('click', function() {
        var names = document.cookie.split(';').map(function(chunk) { return chunk.trim().split('=')[0]; }).filter(Boolean);
        var unique = Array.from(new Set(names));
        var toAdd = unique.filter(function(name) { return existingNames.indexOf(name) === -1; });
        if (!toAdd.length) {
          if (Craft.cp && Craft.cp.displayNotice) {
            Craft.cp.displayNotice('{{ 'templates.cookies.cookies.scan-none'|t('pragmatic-web-toolkit')|e('js') }}');
          } else {
            alert('{{ 'templates.cookies.cookies.scan-none'|t('pragmatic-web-toolkit')|e('js') }}');
          }
          return;
        }
        if (!confirm('{{ 'templates.cookies.cookies.scan-confirm'|t('pragmatic-web-toolkit')|e('js') }}'.replace('{count}', toAdd.length))) return;
        Craft.sendActionRequest('POST', 'pragmatic-web-toolkit/cookies/scan-cookies', { data: { names: toAdd, site: {{ selectedSiteId ?? craft.app.sites.currentSite.id }} } })
          .then(function(response) {
            var added = response && response.data ? response.data.added : 0;
            if (Craft.cp && Craft.cp.displayNotice) {
              Craft.cp.displayNotice('{{ 'templates.cookies.cookies.scan-added'|t('pragmatic-web-toolkit')|e('js') }}'.replace('{count}', added));
            }
            location.reload();
          })
          .catch(function(error) {
            if (Craft.cp && Craft.cp.displayError) {
              Craft.cp.displayError(error && error.message ? error.message : '{{ 'templates.cookies.cookies.scan-failed'|t('pragmatic-web-toolkit')|e('js') }}');
            } else {
              alert('{{ 'templates.cookies.cookies.scan-failed'|t('pragmatic-web-toolkit')|e('js') }}');
            }
          });
      });
      document.querySelectorAll('.edit-cookie-btn').forEach(function(btn) { btn.addEventListener('click', function(e) { e.preventDefault(); document.getElementById('modal-cookie-id').value=this.dataset.id; document.getElementById('modal-name').value=this.dataset.name; document.getElementById('modal-provider').value=this.dataset.provider; document.getElementById('modal-category').value=this.dataset.categoryId; document.getElementById('modal-description').value=this.dataset.description; document.getElementById('modal-duration').value=this.dataset.duration; document.getElementById('modal-is-regex').checked=this.dataset.isRegex==='1'; openModal(); }); });
      document.querySelectorAll('.cancel-modal').forEach(function(btn) { btn.addEventListener('click', closeModal); });
      document.querySelectorAll('.delete.icon[data-cookie-id]').forEach(function(btn) { btn.addEventListener('click', function(e) { e.preventDefault(); if (!confirm('{{ 'templates.cookies.cookies.confirm-delete'|t('pragmatic-web-toolkit')|e('js') }}')) return; Craft.sendActionRequest('POST', 'pragmatic-web-toolkit/cookies/delete-cookie', { data: { id: this.dataset.cookieId } }).then(function() { location.reload(); }); }); });
    })();
  {% endjs %}
{% endblock %}

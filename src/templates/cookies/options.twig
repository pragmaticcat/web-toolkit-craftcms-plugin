{% extends 'pragmatic-web-toolkit/cookies/_layout' %}
{% import '_includes/forms' as forms %}

{% set title = 'templates.cookies.options.title'|t('pragmatic-web-toolkit') %}
{% set selectedTab = 'options' %}
{% set _siteHandle = craft.app.request.getQueryParam('site') %}
{% set _siteParam = _siteHandle ? { site: _siteHandle } : {} %}
{% set appearanceLocked = not canCustomizeAppearance %}

{% block content %}
  {% css %}
    .cookies-option-help {
      margin-top: -8px;
      margin-bottom: 14px;
      color: #606d7b;
      font-size: 12px;
    }
    .cookies-option-help summary {
      cursor: pointer;
      user-select: none;
      font-weight: 600;
    }
    .cookies-option-help p {
      margin: 6px 0 0;
      line-height: 1.45;
    }
    .cookies-options-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 18px;
      margin-bottom: 18px;
    }
    .cookies-options-block {
      border: 1px solid #e5e7eb;
      border-radius: 8px;
      padding: 14px;
      background: #fff;
    }
    .cookies-options-block h3 {
      margin: 0 0 4px;
      font-size: 15px;
    }
    .cookies-options-block > p {
      margin: 0 0 14px;
    }
    @media (max-width: 1023px) {
      .cookies-options-grid {
        grid-template-columns: 1fr;
      }
    }
  {% endcss %}

  <form method="post" accept-charset="UTF-8">
    {{ csrfInput() }}
    {{ actionInput('pragmatic-web-toolkit/cookies/save-options') }}
    {{ redirectInput('pragmatic-toolkit/cookies/options', _siteParam) }}

    {% if appearanceLocked %}
      {% include 'pragmatic-web-toolkit/_partials/tier-lock' with {
        tier: 'pro',
        heading: 'templates.cookies.options.requires-pro'|t('pragmatic-web-toolkit'),
        message: 'templates.cookies.options.requires-pro-message'|t('pragmatic-web-toolkit')
      } %}
    {% endif %}

    <div class="cookies-options-grid">
      <section class="cookies-options-block">
        <h3>{{ 'templates.cookies.options.layout-title'|t('pragmatic-web-toolkit') }}</h3>
        <p class="light">{{ 'templates.cookies.options.layout-desc'|t('pragmatic-web-toolkit') }}</p>

        {{ forms.selectField({ label: 'templates.cookies.options.popup-layout'|t('pragmatic-web-toolkit'), id: 'popupLayout', name: 'popupLayout', value: settings.popupLayout, disabled: appearanceLocked, options: [
          { label: 'templates.cookies.options.layout-bar'|t('pragmatic-web-toolkit'), value: 'bar' },
          { label: 'templates.cookies.options.layout-box'|t('pragmatic-web-toolkit'), value: 'box' },
          { label: 'templates.cookies.options.layout-modal'|t('pragmatic-web-toolkit'), value: 'modal' }
        ] }) }}
        <details class="cookies-option-help">
          <summary>{{ 'templates.cookies.options.what-does-this-do'|t('pragmatic-web-toolkit') }}</summary>
          <p>{{ 'templates.cookies.options.popup-layout-help'|t('pragmatic-web-toolkit') }}</p>
        </details>

        {{ forms.selectField({ label: 'templates.cookies.options.popup-position'|t('pragmatic-web-toolkit'), id: 'popupPosition', name: 'popupPosition', value: settings.popupPosition, disabled: appearanceLocked, options: [
          { label: 'templates.cookies.options.position-bottom'|t('pragmatic-web-toolkit'), value: 'bottom' },
          { label: 'templates.cookies.options.position-top'|t('pragmatic-web-toolkit'), value: 'top' },
          { label: 'templates.cookies.options.position-center'|t('pragmatic-web-toolkit'), value: 'center' }
        ] }) }}
        <details class="cookies-option-help">
          <summary>{{ 'templates.cookies.options.what-does-this-do'|t('pragmatic-web-toolkit') }}</summary>
          <p>{{ 'templates.cookies.options.popup-position-help'|t('pragmatic-web-toolkit') }}</p>
        </details>
      </section>

      <section class="cookies-options-block">
        <h3>{{ 'templates.cookies.options.colors-title'|t('pragmatic-web-toolkit') }}</h3>
        <p class="light">{{ 'templates.cookies.options.colors-desc'|t('pragmatic-web-toolkit') }}</p>

        {{ forms.colorField({ label: 'templates.cookies.options.primary-color'|t('pragmatic-web-toolkit'), id: 'primaryColor', name: 'primaryColor', value: settings.primaryColor, disabled: appearanceLocked }) }}
        <details class="cookies-option-help">
          <summary>{{ 'templates.cookies.options.what-does-this-do'|t('pragmatic-web-toolkit') }}</summary>
          <p>{{ 'templates.cookies.options.primary-color-help'|t('pragmatic-web-toolkit') }}</p>
        </details>

        {{ forms.colorField({ label: 'templates.cookies.options.background-color'|t('pragmatic-web-toolkit'), id: 'backgroundColor', name: 'backgroundColor', value: settings.backgroundColor, disabled: appearanceLocked }) }}
        <details class="cookies-option-help">
          <summary>{{ 'templates.cookies.options.what-does-this-do'|t('pragmatic-web-toolkit') }}</summary>
          <p>{{ 'templates.cookies.options.background-color-help'|t('pragmatic-web-toolkit') }}</p>
        </details>

        {{ forms.colorField({ label: 'templates.cookies.options.text-color'|t('pragmatic-web-toolkit'), id: 'textColor', name: 'textColor', value: settings.textColor, disabled: appearanceLocked }) }}
        <details class="cookies-option-help">
          <summary>{{ 'templates.cookies.options.what-does-this-do'|t('pragmatic-web-toolkit') }}</summary>
          <p>{{ 'templates.cookies.options.text-color-help'|t('pragmatic-web-toolkit') }}</p>
        </details>
      </section>

      <section class="cookies-options-block">
        <h3>{{ 'templates.cookies.options.behavior-title'|t('pragmatic-web-toolkit') }}</h3>
        <p class="light">{{ 'templates.cookies.options.behavior-desc'|t('pragmatic-web-toolkit') }}</p>

        {{ forms.lightswitchField({ label: 'templates.cookies.options.show-overlay'|t('pragmatic-web-toolkit'), id: 'overlayEnabled', name: 'overlayEnabled', on: settings.overlayEnabled == 'true' }) }}
        <details class="cookies-option-help">
          <summary>{{ 'templates.cookies.options.what-does-this-do'|t('pragmatic-web-toolkit') }}</summary>
          <p>{{ 'templates.cookies.options.show-overlay-help'|t('pragmatic-web-toolkit') }}</p>
        </details>

        {{ forms.lightswitchField({ label: 'templates.cookies.options.auto-show'|t('pragmatic-web-toolkit'), id: 'autoShowPopup', name: 'autoShowPopup', on: settings.autoShowPopup == 'true' }) }}
        <details class="cookies-option-help">
          <summary>{{ 'templates.cookies.options.what-does-this-do'|t('pragmatic-web-toolkit') }}</summary>
          <p>{{ 'templates.cookies.options.auto-show-help'|t('pragmatic-web-toolkit') }}</p>
        </details>

        {{ forms.textField({ label: 'templates.cookies.options.consent-expiry'|t('pragmatic-web-toolkit'), id: 'consentExpiry', name: 'consentExpiry', value: settings.consentExpiry, type: 'number' }) }}
        <details class="cookies-option-help">
          <summary>{{ 'templates.cookies.options.what-does-this-do'|t('pragmatic-web-toolkit') }}</summary>
          <p>{{ 'templates.cookies.options.consent-expiry-help'|t('pragmatic-web-toolkit') }}</p>
        </details>

        {{ forms.lightswitchField({ label: 'templates.cookies.options.log-consent'|t('pragmatic-web-toolkit'), id: 'logConsent', name: 'logConsent', on: settings.logConsent == 'true' }) }}
        <details class="cookies-option-help">
          <summary>{{ 'templates.cookies.options.what-does-this-do'|t('pragmatic-web-toolkit') }}</summary>
          <p>{{ 'templates.cookies.options.log-consent-help'|t('pragmatic-web-toolkit') }}</p>
        </details>
      </section>

      <section class="cookies-options-block">
        <h3>{{ 'templates.cookies.options.on-demand-title'|t('pragmatic-web-toolkit') }}</h3>
        <p class="light">{{ 'templates.cookies.options.on-demand-desc'|t('pragmatic-web-toolkit') }}</p>

        {{ forms.lightswitchField({ label: 'templates.cookies.options.show-preferences-button'|t('pragmatic-web-toolkit'), id: 'showPreferencesButton', name: 'showPreferencesButton', on: settings.showPreferencesButton == 'true' }) }}
        <details class="cookies-option-help">
          <summary>{{ 'templates.cookies.options.what-does-this-do'|t('pragmatic-web-toolkit') }}</summary>
          <p>{{ 'templates.cookies.options.show-preferences-button-help'|t('pragmatic-web-toolkit') }}</p>
        </details>

        {{ forms.textField({ label: 'templates.cookies.options.preferences-button-label'|t('pragmatic-web-toolkit'), id: 'preferencesButtonLabel', name: 'preferencesButtonLabel', value: settings.preferencesButtonLabel }) }}
        <details class="cookies-option-help">
          <summary>{{ 'templates.cookies.options.what-does-this-do'|t('pragmatic-web-toolkit') }}</summary>
          <p>{{ 'templates.cookies.options.preferences-button-label-help'|t('pragmatic-web-toolkit') }}</p>
        </details>
      </section>
    </div>

    <div class="btngroup">
      <button type="submit" class="btn submit">{{ 'templates.cookies.actions.save'|t('pragmatic-web-toolkit') }}</button>
    </div>
  </form>
{% endblock %}

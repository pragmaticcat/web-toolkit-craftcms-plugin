{% extends "pragmatic-web-toolkit/translations/_layout" %}

{% set title = 'templates.translations.seo.seo'|t('pragmatic-web-toolkit') %}
{% set selectedTab = 'seo' %}

{% set crumbs = [
    { label: 'templates.translations.seo.translations'|t('pragmatic-web-toolkit'), url: url('pragmatic-toolkit/translations', { site: selectedSite.handle }) },
    { label: 'templates.translations.seo.seo'|t('pragmatic-web-toolkit'), url: url('pragmatic-toolkit/translations/seo', { site: selectedSite.handle }) },
] %}

{% block sidebar %}
  <nav aria-label="{{ 'templates.translations.seo.sections'|t('pragmatic-web-toolkit') }}">
    <ul class="nav">
      <li>
        <a class="{{ not sectionFilter ? 'sel' : '' }}" href="{{ url('pragmatic-toolkit/translations/seo', { site: selectedSite.handle }) }}">
          {{ 'templates.translations.seo.all-entries'|t('pragmatic-web-toolkit') }}
        </a>
      </li>
      {% if sections|length %}
        <li class="heading"><span>{{ 'templates.translations.seo.sections'|t('pragmatic-web-toolkit') }}</span></li>
        {% for section in sections %}
          <li>
            <a class="{{ section.id|string == sectionFilter ? 'sel' : '' }}" href="{{ url('pragmatic-toolkit/translations/seo', { site: selectedSite.handle, section: section.id }) }}">
              {{ section.name }} <span class="light" style="margin-left: 2px;">({{ section.count }})</span>
            </a>
          </li>
        {% endfor %}
      {% endif %}
    </ul>
  </nav>
{% endblock %}

{% block content %}
  {% set currentLanguage = selectedSite.language ?? '' %}
  {% set orderedLanguages = [] %}
  {% if currentLanguage and currentLanguage in languages %}
    {% set orderedLanguages = orderedLanguages|merge([currentLanguage]) %}
  {% endif %}
  {% for language in languages %}
    {% if language != currentLanguage %}
      {% set orderedLanguages = orderedLanguages|merge([language]) %}
    {% endif %}
  {% endfor %}

  {% css %}
    tr.entry-group-border > td { border-top: 2px solid #d1d5db; }
    .pwt-seo-current-language-col { background: #f3f9ff; }
    .pwt-batch-actions { display:flex; gap:8px; flex-wrap: wrap; margin:0; }
    .pwt-language-target-toggle { display:flex; align-items:center; gap:6px; margin-top:4px; font-weight: normal; }
    .btn-ai { display:flex; gap:8px; align-items:center; }
    .btn-ai svg { display:block; width:16px; height:16px; fill:currentColor; }
  {% endcss %}

  <div class="flex" style="margin-top: 12px; gap: 16px; align-items: flex-end; justify-content: space-between;">
    <form method="get" id="seo-filter" class="flex" style="gap: 12px; align-items: flex-end;">
      <input type="hidden" name="page" value="1">
      <input type="hidden" name="site" value="{{ selectedSite.handle }}">
      <input type="hidden" id="section-input" name="section" value="{{ sectionFilter }}">
      <div>
        <label for="q">{{ 'templates.translations.seo.search'|t('pragmatic-web-toolkit') }}</label>
        <input class="text" type="text" id="q" name="q" value="{{ search }}" placeholder="{{ 'templates.translations.seo.entry-title'|t('pragmatic-web-toolkit') }}">
      </div>
      <input type="hidden" name="perPage" value="{{ perPage }}">
    </form>
    <div class="pwt-batch-actions">
      <button class="btn btn-ai" type="button" id="generate-selected-seo">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 30 30" aria-hidden="true">
          <path d="M14.217,19.707l-1.112,2.547c-0.427,0.979-1.782,0.979-2.21,0l-1.112-2.547c-0.99-2.267-2.771-4.071-4.993-5.057L1.73,13.292c-0.973-0.432-0.973-1.848,0-2.28l2.965-1.316C6.974,8.684,8.787,6.813,9.76,4.47l1.126-2.714c0.418-1.007,1.81-1.007,2.228,0L14.24,4.47c0.973,2.344,2.786,4.215,5.065,5.226l2.965,1.316c0.973,0.432,0.973,1.848,0,2.28l-3.061,1.359C16.988,15.637,15.206,17.441,14.217,19.707z"></path>
          <path d="M24.481,27.796l-0.339,0.777c-0.248,0.569-1.036,0.569-1.284,0l-0.339-0.777c-0.604-1.385-1.693-2.488-3.051-3.092l-1.044-0.464c-0.565-0.251-0.565-1.072,0-1.323l0.986-0.438c1.393-0.619,2.501-1.763,3.095-3.195l0.348-0.84c0.243-0.585,1.052-0.585,1.294,0l0.348,0.84c0.594,1.432,1.702,2.576,3.095,3.195l0.986,0.438c0.565,0.251,0.565,1.072,0,1.323l-1.044,0.464C26.174,25.308,25.085,26.411,24.481,27.796z"></path>
        </svg>
        Crear prompt
      </button>
      <button class="btn" type="button" id="export-seo-json">{{ 'templates.translations.seo.export-json'|t('pragmatic-web-toolkit') }}</button>
      <button class="btn" type="button" id="import-seo-json">{{ 'templates.translations.seo.import-json'|t('pragmatic-web-toolkit') }}</button>
      <button class="btn submit" type="submit" form="seo-form" id="save-all-seo">{{ 'templates.translations.seo.save-all'|t('pragmatic-web-toolkit') }}</button>
    </div>
  </div>

  <form method="post" accept-charset="UTF-8" id="seo-form">
    {{ csrfInput() }}
    {{ actionInput('pragmatic-web-toolkit/translations/save-entry-rows') }}
    {{ redirectInput('pragmatic-toolkit/translations/seo', { q: search, perPage: perPage, page: page, section: sectionFilter, site: selectedSite.handle }) }}
    <input type="hidden" name="q" value="{{ search }}">
    <input type="hidden" name="perPage" value="{{ perPage }}">
    <input type="hidden" name="page" value="{{ page }}">
    <input type="hidden" name="section" value="{{ sectionFilter }}">
    <input type="hidden" name="site" value="{{ selectedSite.handle }}">

    <table class="data fullwidth" style="margin-top: 16px;">
      <thead>
        <tr>
          <th style="width: 30px;">
            <input type="checkbox" id="select-all-seo-rows" title="{{ 'templates.translations.seo.select-all-rows'|t('pragmatic-web-toolkit') }}">
          </th>
          <th>{{ 'templates.translations.seo.entry'|t('pragmatic-web-toolkit') }}</th>
          <th>{{ 'templates.translations.seo.field'|t('pragmatic-web-toolkit') }}</th>
          {% for language in orderedLanguages %}
            <th class="{{ language == currentLanguage ? 'pwt-seo-current-language-col' : '' }}">
              {{ language }}{{ language == currentLanguage ? ' (' ~ 'templates.translations.seo.current'|t('pragmatic-web-toolkit') ~ ')' : '' }}
              {% if languages|length > 2 and language != currentLanguage %}
                <label class="pwt-language-target-toggle">
                  <input type="checkbox" class="js-language-target" data-language="{{ language }}" checked>
                  <span>{{ 'templates.translations.seo.translate'|t('pragmatic-web-toolkit') }}</span>
                </label>
              {% endif %}
            </th>
          {% endfor %}
          <th>{{ 'templates.translations.seo.action'|t('pragmatic-web-toolkit') }}</th>
        </tr>
      </thead>
      <tbody>
        {% for row in rows %}
          {% set rowIndex = loop.index0 %}
          {% set elementId = row.elementId %}
          {% set elementKey = row.elementKey ?? ('entry:' ~ row.elementId) %}
          {% set prevElementKey = loop.first ? null : (rows[loop.index0 - 1].elementKey ?? ('entry:' ~ rows[loop.index0 - 1].elementId)) %}
          {% set isFirstOfGroup = elementKey != prevElementKey %}
          <tr{{ isFirstOfGroup and not loop.first ? ' class="entry-group-border"' : '' }} data-entry-id="{{ elementId }}">
            <td>
              <input
                type="checkbox"
                class="js-seo-row-select"
                data-element-type="entry"
                data-element-id="{{ elementId }}"
                data-field-handle="{{ row.fieldHandle }}"
              >
            </td>
            {% if isFirstOfGroup %}
              <td rowspan="{{ entryRowCounts[elementKey] ?? 1 }}" style="vertical-align: top;">
                <a href="#" class="js-entry-slideout" data-entry-id="{{ elementId }}" data-site-id="{{ row.element.siteId }}">{{ row.element.title|default('Entry #' ~ elementId) }}</a>
                <div class="light">{{ row.element.section.name ?? row.element.type.name ?? 'templates.translations.seo.no-section-or-type'|t('pragmatic-web-toolkit') }}</div>
              </td>
            {% endif %}
            <td>
              <input type="hidden" name="entries[{{ rowIndex }}][elementType]" value="entry">
              <input type="hidden" name="entries[{{ rowIndex }}][elementId]" value="{{ elementId }}">
              <input type="hidden" name="entries[{{ rowIndex }}][entryId]" value="{{ elementId }}">
              <input type="hidden" name="entries[{{ rowIndex }}][fieldHandle]" value="{{ row.fieldHandle }}">
              <div>{{ row.fieldLabel }}</div>
              <div class="light">{{ row.fieldHandle }}</div>
            </td>
            {% for language in orderedLanguages %}
              <td class="{{ language == currentLanguage ? 'pwt-seo-current-language-col' : '' }}">
                <textarea class="text fullwidth" rows="2" name="entries[{{ rowIndex }}][values][{{ language }}]">{{ row.values[language] ?? '' }}</textarea>
              </td>
            {% endfor %}
            <td style="white-space: nowrap;">
              <button class="btn submit js-save-seo-row" type="button" data-row-index="{{ rowIndex }}">{{ 'templates.translations.seo.save'|t('pragmatic-web-toolkit') }}</button>
            </td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  </form>

  <div class="flex justify-between align-center" style="margin-top: 16px;">
    <div>{{ total }} {{ 'templates.translations.seo.total'|t('pragmatic-web-toolkit') }}</div>
    <div class="flex" style="gap: 8px; align-items: center;">
      {% set prevPage = page > 1 ? page - 1 : 1 %}
      {% set nextPage = page < totalPages ? page + 1 : totalPages %}
      {% if page == 1 %}
        <span class="btn disabled">{{ 'templates.translations.seo.prev'|t('pragmatic-web-toolkit') }}</span>
      {% else %}
        <a class="btn" href="{{ url('pragmatic-toolkit/translations/seo', { q: search, perPage: perPage, page: prevPage, section: sectionFilter, site: selectedSite.handle }) }}">{{ 'templates.translations.seo.prev'|t('pragmatic-web-toolkit') }}</a>
      {% endif %}
      <div>{{ 'templates.translations.seo.page'|t('pragmatic-web-toolkit') }} {{ page }} / {{ totalPages }}</div>
      {% if page == totalPages %}
        <span class="btn disabled">{{ 'templates.translations.seo.next'|t('pragmatic-web-toolkit') }}</span>
      {% else %}
        <a class="btn" href="{{ url('pragmatic-toolkit/translations/seo', { q: search, perPage: perPage, page: nextPage, section: sectionFilter, site: selectedSite.handle }) }}">{{ 'templates.translations.seo.next'|t('pragmatic-web-toolkit') }}</a>
      {% endif %}
      <label for="perPage" class="light" style="margin: 0 0 0 8px;">{{ 'templates.translations.seo.per-page'|t('pragmatic-web-toolkit') }}</label>
      <div class="select">
        <select id="perPage" name="perPage">
          {% for option in [50, 100, 250] %}
            <option value="{{ option }}" {{ option == perPage ? 'selected' : '' }}>{{ option }}</option>
          {% endfor %}
        </select>
      </div>
    </div>
  </div>

  {% js %}
    (function() {
      const filterForm = document.getElementById('seo-filter');
      const searchInput = document.getElementById('q');
      const perPageSelect = document.getElementById('perPage');
      const perPageHidden = filterForm ? filterForm.querySelector('input[name="perPage"]') : null;
      const seoForm = document.getElementById('seo-form');
      const selectedSiteId = {{ selectedSiteId|json_encode|raw }};
      const languageCount = {{ languages|length }};
      const currentLanguage = {{ currentLanguage|json_encode|raw }};

      if (filterForm) {
        const pageInput = filterForm.querySelector('input[name="page"]');
        function resetPageAndSubmit() {
          if (pageInput) pageInput.value = '1';
          if (perPageHidden && perPageSelect) perPageHidden.value = perPageSelect.value;
          filterForm.submit();
        }
        let searchTimer = null;
        searchInput?.addEventListener('input', function() {
          if (searchTimer) clearTimeout(searchTimer);
          searchTimer = setTimeout(resetPageAndSubmit, 300);
        });
        perPageSelect?.addEventListener('change', resetPageAndSubmit);
      }

      document.querySelectorAll('.js-entry-slideout').forEach(function(link) {
        link.addEventListener('click', function(ev) {
          ev.preventDefault();
          const entryId = parseInt(link.getAttribute('data-entry-id'), 10);
          const siteId = parseInt(link.getAttribute('data-site-id'), 10);
          if (!entryId || !window.Craft) return;
          Craft.createElementEditor('craft\\elements\\Entry', {
            elementId: entryId,
            siteId: siteId || undefined,
            slideout: true
          });
        });
      });

      function getSelectedSeoItems() {
        return Array.from(document.querySelectorAll('.js-seo-row-select:checked')).map(function(checkbox) {
          return {
            elementType: 'entry',
            elementId: parseInt(checkbox.getAttribute('data-element-id') || '0', 10),
            fieldHandle: String(checkbox.getAttribute('data-field-handle') || ''),
          };
        }).filter(function(item) { return item.elementId > 0 && item.fieldHandle !== ''; });
      }

      function requireSelectedSeoItems() {
        const items = getSelectedSeoItems();
        if (!items.length) {
          Craft.cp.displayError('{{ 'templates.translations.seo.select-at-least-one-row'|t('pragmatic-web-toolkit')|e('js') }}');
          return null;
        }
        return items;
      }

      function getSelectedTargetLanguages() {
        if (languageCount <= 2) {
          return [];
        }
        return Array.from(document.querySelectorAll('.js-language-target:checked'))
          .map(function(checkbox) { return String(checkbox.getAttribute('data-language') || '').trim(); })
          .filter(function(language) { return language !== '' && language !== currentLanguage; });
      }

      function openModalLayout(title, bodyHtml, footerHtml) {
        const modalEl = document.createElement('div');
        modalEl.className = 'modal pwt-unified-modal pwt-unified-modal--large';
        modalEl.innerHTML =
          '<div class="body"><div class="content"><h2 style="margin-top:0;">' + title + '</h2>' + bodyHtml + '</div></div>' +
          '<div class="footer"><div class="buttons">' + footerHtml + '</div></div>';
        const modal = new Garnish.Modal(modalEl, { autoShow: true, onHide: function() { modal.destroy(); } });
        return { modal, modalEl };
      }

      function downloadJson(filename, payload) {
        const blob = new Blob([payload], { type: 'application/json;charset=utf-8' });
        const url = URL.createObjectURL(blob);
        const link = document.createElement('a');
        link.href = url;
        link.download = filename;
        document.body.appendChild(link);
        link.click();
        link.remove();
        URL.revokeObjectURL(url);
      }

      function openPromptModal(promptText) {
        const { modal, modalEl } = openModalLayout(
          '{{ 'templates.translations.seo.translation-ai-prompt'|t('pragmatic-web-toolkit')|e("js") }}',
          '<textarea class="text fullwidth js-prompt" rows="24" readonly style="font-family: Menlo, Monaco, Consolas, monospace; min-height: 72vh;">' + Craft.escapeHtml(promptText) + '</textarea>',
          '<button type="button" class="btn" data-action="copy">{{ 'templates.translations.seo.copy-prompt'|t('pragmatic-web-toolkit')|e("js") }}</button><button type="button" class="btn" data-action="close">{{ 'templates.translations.seo.close'|t('pragmatic-web-toolkit')|e("js") }}</button>'
        );
        modalEl.querySelector('[data-action="copy"]')?.addEventListener('click', async function() {
          try {
            await navigator.clipboard.writeText(promptText);
            Craft.cp.displayNotice('{{ 'templates.translations.seo.prompt-copied'|t('pragmatic-web-toolkit')|e("js") }}');
          } catch (error) {
            Craft.cp.displayError('{{ 'templates.translations.seo.could-not-copy-automatically'|t('pragmatic-web-toolkit')|e("js") }}');
          }
        });
        modalEl.querySelector('[data-action="close"]')?.addEventListener('click', function() { modal.hide(); });
      }

      function openExportModal(filename, jsonText) {
        const { modal, modalEl } = openModalLayout(
          '{{ 'templates.translations.seo.export-json'|t('pragmatic-web-toolkit')|e("js") }}',
          '<textarea class="text fullwidth js-export-json" rows="24" readonly style="font-family: Menlo, Monaco, Consolas, monospace; min-height: 72vh;">' + Craft.escapeHtml(jsonText) + '</textarea>',
          '<button type="button" class="btn" data-action="copy">{{ 'templates.translations.seo.copy-json'|t('pragmatic-web-toolkit')|e("js") }}</button><button type="button" class="btn" data-action="download">{{ 'templates.translations.seo.download-json'|t('pragmatic-web-toolkit')|e("js") }}</button><button type="button" class="btn" data-action="close">{{ 'templates.translations.seo.close'|t('pragmatic-web-toolkit')|e("js") }}</button>'
        );
        modalEl.querySelector('[data-action="copy"]')?.addEventListener('click', async function() {
          try {
            await navigator.clipboard.writeText(jsonText);
            Craft.cp.displayNotice('{{ 'templates.translations.seo.json-copied'|t('pragmatic-web-toolkit')|e("js") }}');
          } catch (error) {
            Craft.cp.displayError('{{ 'templates.translations.seo.could-not-copy-automatically'|t('pragmatic-web-toolkit')|e("js") }}');
          }
        });
        modalEl.querySelector('[data-action="download"]')?.addEventListener('click', function() { downloadJson(filename, jsonText); });
        modalEl.querySelector('[data-action="close"]')?.addEventListener('click', function() { modal.hide(); });
      }

      function openImportModal() {
        const { modal, modalEl } = openModalLayout(
          '{{ 'templates.translations.seo.import-json'|t('pragmatic-web-toolkit')|e("js") }}',
          '<textarea class="text fullwidth js-import-json-text" rows="16" style="min-height: 38vh;" placeholder="{{ 'templates.translations.seo.paste-json-here'|t('pragmatic-web-toolkit')|e("js") }}"></textarea><div style="margin-top:10px;"><input type="file" class="js-import-json-file" accept=".json,application/json"></div><div class="js-import-preview" style="margin-top:14px; max-height:28vh; overflow:auto;"></div>',
          '<button type="button" class="btn" data-action="preview">{{ 'templates.translations.seo.preview-import'|t('pragmatic-web-toolkit')|e("js") }}</button><button type="button" class="btn submit disabled" data-action="apply" disabled>{{ 'templates.translations.seo.apply-import'|t('pragmatic-web-toolkit')|e("js") }}</button><button type="button" class="btn" data-action="close">{{ 'templates.translations.seo.close'|t('pragmatic-web-toolkit')|e("js") }}</button>'
        );

        const textArea = modalEl.querySelector('.js-import-json-text');
        const fileInput = modalEl.querySelector('.js-import-json-file');
        const previewEl = modalEl.querySelector('.js-import-preview');
        const previewBtn = modalEl.querySelector('[data-action="preview"]');
        const applyBtn = modalEl.querySelector('[data-action="apply"]');
        let lastMatchedChanged = [];
        let lastPreviewTotals = null;

        const normalizePreviewItems = (items) => Array.isArray(items) ? items : (items && typeof items === 'object' ? Object.values(items) : []);
        const buildRequestOptions = () => {
          const jsonText = (textArea?.value || '').trim();
          if (jsonText) return { data: { siteId: selectedSiteId, jsonText: jsonText } };
          if (fileInput?.files?.[0]) {
            const data = new FormData();
            data.append('siteId', String(selectedSiteId));
            data.append('jsonFile', fileInput.files[0]);
            return { data };
          }
          throw new Error('{{ 'templates.translations.seo.paste-json-or-select-a-file'|t('pragmatic-web-toolkit')|e("js") }}');
        };

        const syncApplyEnabled = () => {
          const hasText = !!((textArea?.value || '').trim());
          const hasFile = !!(fileInput?.files && fileInput.files.length);
          const hasPreviewItems = lastMatchedChanged.length > 0;
          const hasPreviewChanges = !!(lastPreviewTotals && parseInt(lastPreviewTotals.matchedChanged, 10) > 0);
          const enabled = hasText || hasFile || hasPreviewItems || hasPreviewChanges;
          applyBtn.disabled = !enabled;
          applyBtn.classList.toggle('disabled', !enabled);
        };

        previewBtn?.addEventListener('click', async function() {
          previewBtn.disabled = true;
          lastMatchedChanged = [];
          lastPreviewTotals = null;
          try {
            const response = await Craft.sendActionRequest('POST', 'pragmatic-web-toolkit/translations/import-entries-json-preview', buildRequestOptions());
            if (!response.data || !response.data.success || !response.data.preview) {
              throw new Error(response.data && response.data.error ? response.data.error : '{{ 'templates.translations.seo.could-not-preview-import'|t('pragmatic-web-toolkit')|e("js") }}');
            }
            const preview = response.data.preview;
            lastMatchedChanged = normalizePreviewItems(preview.matchedChanged);
            lastPreviewTotals = preview.totals || null;
            previewEl.innerHTML =
              '<div style="padding:10px;border:1px solid #e5e7eb;border-radius:6px;">' +
              '<p><strong>{{ 'templates.translations.seo.total-items'|t('pragmatic-web-toolkit')|e("js") }}:</strong> ' + (preview.totals?.totalItems || 0) + '</p>' +
              '<p><strong>{{ 'templates.translations.seo.matched-changed'|t('pragmatic-web-toolkit')|e("js") }}:</strong> ' + (preview.totals?.matchedChanged || 0) + '</p>' +
              '<p><strong>{{ 'templates.translations.seo.matched-unchanged'|t('pragmatic-web-toolkit')|e("js") }}:</strong> ' + (preview.totals?.matchedUnchanged || 0) + '</p>' +
              '<p><strong>{{ 'templates.translations.seo.skipped-unmatched'|t('pragmatic-web-toolkit')|e("js") }}:</strong> ' + (preview.totals?.skippedUnmatched || 0) + '</p>' +
              '<p><strong>{{ 'templates.translations.seo.invalid-items'|t('pragmatic-web-toolkit')|e("js") }}:</strong> ' + (preview.totals?.invalidItems || 0) + '</p>' +
              '</div>';
          } catch (error) {
            previewEl.innerHTML = '<p class="error">' + Craft.escapeHtml(error.message || '{{ 'templates.translations.seo.could-not-preview-import'|t('pragmatic-web-toolkit')|e("js") }}') + '</p>';
          } finally {
            previewBtn.disabled = false;
            syncApplyEnabled();
          }
        });

        applyBtn?.addEventListener('click', async function() {
          applyBtn.disabled = true;
          try {
            let options;
            if (lastMatchedChanged.length > 0) {
              options = { data: { siteId: selectedSiteId, itemsJson: JSON.stringify(lastMatchedChanged) } };
            } else {
              options = buildRequestOptions();
            }
            const response = await Craft.sendActionRequest('POST', 'pragmatic-web-toolkit/translations/import-entries-json-apply', options);
            if (!response.data || !response.data.success) {
              throw new Error(response.data && response.data.error ? response.data.error : '{{ 'templates.translations.seo.could-not-apply-import'|t('pragmatic-web-toolkit')|e("js") }}');
            }
            Craft.cp.displayNotice('{{ 'templates.translations.seo.import-applied'|t('pragmatic-web-toolkit')|e("js") }}');
            window.location.reload();
          } catch (error) {
            Craft.cp.displayError(error.message || '{{ 'templates.translations.seo.could-not-apply-import'|t('pragmatic-web-toolkit')|e("js") }}');
          } finally {
            syncApplyEnabled();
          }
        });

        textArea?.addEventListener('input', syncApplyEnabled);
        fileInput?.addEventListener('change', syncApplyEnabled);
        syncApplyEnabled();
        modalEl.querySelector('[data-action="close"]')?.addEventListener('click', function() { modal.hide(); });
      }

      document.getElementById('select-all-seo-rows')?.addEventListener('change', function(event) {
        document.querySelectorAll('.js-seo-row-select').forEach(function(cb) { cb.checked = event.target.checked; });
      });

      seoForm?.addEventListener('click', async function(event) {
        const button = event.target ? event.target.closest('.js-save-seo-row') : null;
        if (!button) return;
        event.preventDefault();
        const rowIndex = button.getAttribute('data-row-index');
        if (rowIndex === null || rowIndex === '') return;
        button.disabled = true;
        try {
          const formData = new FormData(seoForm);
          formData.set('saveRow', String(rowIndex));
          const response = await Craft.sendActionRequest('POST', 'pragmatic-web-toolkit/translations/save-entry-row', { data: formData });
          if (!response.data || !response.data.success) {
            throw new Error(response.data && response.data.error ? response.data.error : '{{ 'templates.translations.seo.could-not-save-row'|t('pragmatic-web-toolkit')|e("js") }}');
          }
          Craft.cp.displayNotice('{{ 'templates.translations.seo.seo-row-saved'|t('pragmatic-web-toolkit')|e("js") }}');
        } catch (error) {
          Craft.cp.displayError(error.message || '{{ 'templates.translations.seo.could-not-save-row'|t('pragmatic-web-toolkit')|e("js") }}');
        } finally {
          button.disabled = false;
        }
      });

      document.getElementById('generate-selected-seo')?.addEventListener('click', async function() {
        const items = requireSelectedSeoItems();
        if (!items) return;
        const targetLanguages = getSelectedTargetLanguages();
        if (languageCount > 2 && targetLanguages.length === 0) {
          Craft.cp.displayError('{{ 'templates.translations.seo.select-at-least-one-target-language-column'|t('pragmatic-web-toolkit')|e("js") }}');
          return;
        }
        try {
          const response = await Craft.sendActionRequest('POST', 'pragmatic-web-toolkit/translations/generate-entries-prompt-batch', {
            data: {
              siteId: selectedSiteId,
              items: items,
              targetLanguages: targetLanguages,
              q: (searchInput?.value || ''),
              section: '{{ sectionFilter|e("js") }}'
            },
          });
          if (!response.data || !response.data.success || !response.data.manualPrompt) {
            throw new Error(response.data && response.data.error ? response.data.error : '{{ 'templates.translations.seo.could-not-generate-prompt'|t('pragmatic-web-toolkit')|e("js") }}');
          }
          openPromptModal(response.data.manualPrompt);
        } catch (error) {
          Craft.cp.displayError(error.message || '{{ 'templates.translations.seo.could-not-generate-prompt'|t('pragmatic-web-toolkit')|e("js") }}');
        }
      });

      document.getElementById('export-seo-json')?.addEventListener('click', async function() {
        const items = requireSelectedSeoItems();
        if (!items) return;
        try {
          const response = await Craft.sendActionRequest('POST', 'pragmatic-web-toolkit/translations/export-entries-json-bundle', {
            data: { siteId: selectedSiteId, items: items, q: (searchInput?.value || ''), section: '{{ sectionFilter|e("js") }}' },
          });
          if (!response.data || !response.data.success || !response.data.bundle) {
            throw new Error(response.data && response.data.error ? response.data.error : '{{ 'templates.translations.seo.could-not-export-json'|t('pragmatic-web-toolkit')|e("js") }}');
          }
          openExportModal(response.data.filename || 'translations-seo-export.json', JSON.stringify(response.data.bundle, null, 2));
        } catch (error) {
          Craft.cp.displayError(error.message || '{{ 'templates.translations.seo.could-not-export-json'|t('pragmatic-web-toolkit')|e("js") }}');
        }
      });

      document.getElementById('import-seo-json')?.addEventListener('click', function() { openImportModal(); });
    })();
  {% endjs %}
{% endblock %}

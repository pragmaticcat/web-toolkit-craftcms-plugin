{% extends "pragmatic-web-toolkit/translations/_layout" %}

{% set title = "Assets"|t('pragmatic-web-toolkit') %}
{% set selectedTab = 'assets' %}

{% set crumbs = [
    { label: "Translations"|t('pragmatic-web-toolkit'), url: url('pragmatic-toolkit/translations', { site: selectedSite.handle }) },
    { label: "Assets"|t('pragmatic-web-toolkit'), url: url('pragmatic-toolkit/translations/assets', { site: selectedSite.handle }) },
] %}

{% block content %}
  {% set currentLanguage = selectedSite.language ?? '' %}
  {% set orderedLanguages = [] %}
  {% if currentLanguage and currentLanguage in languages %}
    {% set orderedLanguages = orderedLanguages|merge([currentLanguage]) %}
  {% endif %}
  {% for language in languages %}
    {% if language != currentLanguage %}
      {% set orderedLanguages = orderedLanguages|merge([language]) %}
    {% endif %}
  {% endfor %}

  {% css %}
    tr.asset-group-border > td { border-top: 2px solid #d1d5db; }
    .assets-current-language-col { background: #f3f9ff; }
    .assets-current-language-header { background: #e5f2ff; box-shadow: inset 0 -1px 0 #c8def5; }
  {% endcss %}

  <div class="flex" style="margin-top: 12px; gap: 16px; align-items: flex-end; justify-content: space-between;">
    <form method="get" id="assets-filter" class="flex" style="gap: 12px; align-items: flex-end;">
      <input type="hidden" name="page" value="1">
      <input type="hidden" name="site" value="{{ selectedSite.handle }}">
      <div>
        <label for="q">{{ "Search"|t('pragmatic-web-toolkit') }}</label>
        <input class="text" type="text" id="q" name="q" value="{{ search }}" placeholder="{{ "Filename or text"|t('pragmatic-web-toolkit') }}">
      </div>
      <input type="hidden" name="perPage" value="{{ perPage }}">
    </form>
    <button class="btn submit" type="submit" form="assets-form" id="save-all-assets">{{ "Save all"|t('pragmatic-web-toolkit') }}</button>
  </div>

  <form method="post" accept-charset="UTF-8" id="assets-form">
    {{ csrfInput() }}
    {{ actionInput('pragmatic-web-toolkit/translations/save-asset-rows') }}
    {{ redirectInput('pragmatic-toolkit/translations/assets', { q: search, perPage: perPage, page: page, site: selectedSite.handle }) }}
    <input type="hidden" name="q" value="{{ search }}">
    <input type="hidden" name="perPage" value="{{ perPage }}">
    <input type="hidden" name="page" value="{{ page }}">
    <input type="hidden" name="site" value="{{ selectedSite.handle }}">

    <table class="data fullwidth" style="margin-top: 16px;">
      <thead>
        <tr>
          <th>{{ "Asset"|t('pragmatic-web-toolkit') }}</th>
          <th>{{ "Field"|t('pragmatic-web-toolkit') }}</th>
          {% for language in orderedLanguages %}
            {% set isCurrentLanguage = language == currentLanguage %}
            <th class="{{ isCurrentLanguage ? 'assets-current-language-col assets-current-language-header' : '' }}">
              {% if isCurrentLanguage %}
                {{ language }}{{ ' (' ~ "Current"|t('pragmatic-web-toolkit') ~ ')' }}
              {% else %}
                {{ language }}
              {% endif %}
            </th>
          {% endfor %}
          <th>{{ "Action"|t('pragmatic-web-toolkit') }}</th>
        </tr>
      </thead>
      <tbody>
        {% for row in rows %}
          {% set rowIndex = loop.index0 %}
          {% set assetId = row.assetId %}
          {% set assetKey = row.assetKey ?? ('asset:' ~ row.assetId) %}
          {% set prevAssetKey = loop.first ? null : (rows[loop.index0 - 1].assetKey ?? ('asset:' ~ rows[loop.index0 - 1].assetId)) %}
          {% set isFirstOfGroup = assetKey != prevAssetKey %}
          {% set defaultAsset = row.defaultAsset ?? row.asset %}
          <tr{{ isFirstOfGroup and not loop.first ? ' class="asset-group-border"' : '' }}>
            {% if isFirstOfGroup %}
              <td rowspan="{{ assetRowCounts[assetKey] ?? 1 }}" style="vertical-align: top;">
                <a href="#" class="js-asset-slideout" data-asset-id="{{ assetId }}" data-site-id="{{ selectedSiteId }}">{{ defaultAsset.filename|default('Asset #' ~ assetId) }}</a>
                <div class="light">{{ "Filename from default language"|t('pragmatic-web-toolkit') }}</div>
              </td>
            {% endif %}
            <td>
              <input type="hidden" name="assets[{{ rowIndex }}][assetId]" value="{{ assetId }}">
              <input type="hidden" name="assets[{{ rowIndex }}][fieldHandle]" value="{{ row.fieldHandle }}">
              <div>{{ row.fieldLabel }}</div>
              <div class="light">{{ row.fieldHandle }}</div>
            </td>
            {% for language in orderedLanguages %}
              {% set isCurrentLanguage = language == currentLanguage %}
              <td class="{{ isCurrentLanguage ? 'assets-current-language-col' : '' }}">
                <textarea class="text fullwidth js-asset-input" rows="2" name="assets[{{ rowIndex }}][values][{{ language }}]" data-language="{{ language }}">{{ row.values[language] ?? '' }}</textarea>
              </td>
            {% endfor %}
            <td style="white-space: nowrap;">
              <button class="btn submit js-save-asset-row" type="button" data-row-index="{{ rowIndex }}">{{ "Save"|t('pragmatic-web-toolkit') }}</button>
            </td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  </form>

  <div class="flex justify-between align-center" style="margin-top: 16px;">
    <div>{{ total }} {{ "total"|t('pragmatic-web-toolkit') }}</div>
    <div class="flex" style="gap: 8px; align-items: center;">
      {% set prevPage = page > 1 ? page - 1 : 1 %}
      {% set nextPage = page < totalPages ? page + 1 : totalPages %}
      {% if page == 1 %}
        <span class="btn disabled">{{ "Prev"|t('pragmatic-web-toolkit') }}</span>
      {% else %}
        <a class="btn" href="{{ url('pragmatic-toolkit/translations/assets', { q: search, perPage: perPage, page: prevPage, site: selectedSite.handle }) }}">{{ "Prev"|t('pragmatic-web-toolkit') }}</a>
      {% endif %}
      <div>{{ "Page"|t('pragmatic-web-toolkit') }} {{ page }} / {{ totalPages }}</div>
      {% if page == totalPages %}
        <span class="btn disabled">{{ "Next"|t('pragmatic-web-toolkit') }}</span>
      {% else %}
        <a class="btn" href="{{ url('pragmatic-toolkit/translations/assets', { q: search, perPage: perPage, page: nextPage, site: selectedSite.handle }) }}">{{ "Next"|t('pragmatic-web-toolkit') }}</a>
      {% endif %}
      <label for="perPage" class="light" style="margin: 0 0 0 8px;">{{ "Per page"|t('pragmatic-web-toolkit') }}</label>
      <div class="select">
        <select id="perPage" name="perPage">
          {% for option in [50, 100, 250] %}
            <option value="{{ option }}" {{ option == perPage ? 'selected' : '' }}>{{ option }}</option>
          {% endfor %}
        </select>
      </div>
    </div>
  </div>

  {% js %}
    (function() {
      const filterForm = document.getElementById('assets-filter');
      const searchInput = document.getElementById('q');
      const perPageSelect = document.getElementById('perPage');
      const perPageHidden = filterForm ? filterForm.querySelector('input[name="perPage"]') : null;
      const assetsForm = document.getElementById('assets-form');

      if (filterForm) {
        const pageInput = filterForm.querySelector('input[name="page"]');
        function resetPageAndSubmit() {
          if (pageInput) pageInput.value = '1';
          if (perPageHidden && perPageSelect) perPageHidden.value = perPageSelect.value;
          filterForm.submit();
        }

        let searchTimer = null;
        if (searchInput) {
          searchInput.addEventListener('input', function() {
            if (searchTimer) clearTimeout(searchTimer);
            searchTimer = setTimeout(resetPageAndSubmit, 300);
          });
        }
        if (perPageSelect) {
          perPageSelect.addEventListener('change', resetPageAndSubmit);
        }
      }

      document.querySelectorAll('.js-asset-slideout').forEach(function(link) {
        link.addEventListener('click', function(ev) {
          ev.preventDefault();
          const assetId = parseInt(link.getAttribute('data-asset-id'), 10);
          const siteId = parseInt(link.getAttribute('data-site-id'), 10);
          if (!assetId || !window.Craft) return;
          Craft.createElementEditor('craft\\\\elements\\\\Asset', {
            elementId: assetId,
            siteId: siteId || undefined,
            slideout: true
          });
        });
      });

      if (assetsForm && typeof Craft !== 'undefined') {
        assetsForm.addEventListener('click', async function(event) {
          const button = event.target ? event.target.closest('.js-save-asset-row') : null;
          if (!button) return;
          event.preventDefault();

          const rowIndex = button.getAttribute('data-row-index');
          if (rowIndex === null || rowIndex === '') return;

          const originalText = button.textContent;
          button.classList.add('loading');
          button.disabled = true;
          try {
            const formData = new FormData(assetsForm);
            formData.set('saveRow', String(rowIndex));
            const response = await Craft.sendActionRequest('POST', 'pragmatic-web-toolkit/translations/save-asset-row', {
              data: formData,
            });

            if (!response.data || !response.data.success) {
              const backendError = response && response.data && response.data.error
                ? response.data.error
                : '{{ "Could not save row."|t('pragmatic-web-toolkit')|e('js') }}';
              throw new Error(backendError);
            }

            Craft.cp.displayNotice('{{ "Asset row saved."|t('pragmatic-web-toolkit')|e('js') }}');
          } catch (error) {
            const message = error && error.response && error.response.data && error.response.data.error
              ? error.response.data.error
              : (error && error.message ? error.message : '{{ "Could not save row."|t('pragmatic-web-toolkit')|e('js') }}');
            Craft.cp.displayError(message);
          } finally {
            button.classList.remove('loading');
            button.disabled = false;
            button.textContent = originalText;
          }
        });
      }
    })();
  {% endjs %}
{% endblock %}

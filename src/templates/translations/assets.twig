{% extends "pragmatic-web-toolkit/translations/_layout" %}

{% set title = 'templates.translations.assets.assets'|t('pragmatic-web-toolkit') %}
{% set selectedTab = 'assets' %}

{% set crumbs = [
    { label: 'templates.translations.assets.translations'|t('pragmatic-web-toolkit'), url: url('pragmatic-toolkit/translations', { site: selectedSite.handle }) },
    { label: 'templates.translations.assets.assets'|t('pragmatic-web-toolkit'), url: url('pragmatic-toolkit/translations/assets', { site: selectedSite.handle }) },
] %}

{% block content %}
  {% set currentLanguage = selectedSite.language ?? '' %}
  {% set orderedLanguages = [] %}
  {% if currentLanguage and currentLanguage in languages %}
    {% set orderedLanguages = orderedLanguages|merge([currentLanguage]) %}
  {% endif %}
  {% for language in languages %}
    {% if language != currentLanguage %}
      {% set orderedLanguages = orderedLanguages|merge([language]) %}
    {% endif %}
  {% endfor %}

  {% css %}
    tr.asset-group-border > td { border-top: 2px solid #d1d5db; }
    .assets-current-language-col { background: #f3f9ff; }
    .assets-current-language-header { background: #e5f2ff; box-shadow: inset 0 -1px 0 #c8def5; }
    .assets-language-target-toggle { display:flex; align-items:center; gap:6px; margin-top:4px; font-weight: normal; }
    .img-preview-wrap { position: relative; display: inline-block; }
    .img-preview-popover {
      display: none;
      position: absolute;
      left: 100%;
      top: 50%;
      transform: translateY(-50%);
      margin-left: 10px;
      background: #fff;
      border: 1px solid #d1d5db;
      border-radius: 8px;
      box-shadow: 0 4px 16px rgba(0,0,0,0.12);
      padding: 6px;
      z-index: 100;
      pointer-events: none;
      white-space: nowrap;
    }
    .img-preview-popover img {
      display: block;
      max-width: 200px;
      max-height: 200px;
      width: auto;
      height: auto;
      border-radius: 4px;
    }
    .img-preview-wrap:hover .img-preview-popover { display: block; }
    .btn-ai { display:flex; gap:8px; align-items:center; }
    .btn-ai svg { display:block; width:16px; height:16px; fill:currentColor; }
  {% endcss %}

  <div class="flex" style="margin-top: 12px; gap: 16px; align-items: flex-end; justify-content: space-between;">
    <form method="get" id="assets-filter" class="flex" style="gap: 12px; align-items: flex-end;">
      <input type="hidden" name="page" value="1">
      <input type="hidden" name="site" value="{{ selectedSite.handle }}">
      <input type="hidden" name="sort" value="{{ sort }}">
      <input type="hidden" name="dir" value="{{ dir }}">
      <div>
        <label for="q">{{ 'templates.translations.assets.search'|t('pragmatic-web-toolkit') }}</label>
        <input class="text" type="text" id="q" name="q" value="{{ search }}" placeholder="{{ 'templates.translations.assets.filename-or-text'|t('pragmatic-web-toolkit') }}">
      </div>
      <input type="hidden" name="perPage" value="{{ perPage }}">
    </form>
    <div class="buttons" style="margin:0;">
      <button class="btn btn-ai" type="button" id="generate-selected-assets">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 30 30" aria-hidden="true">
          <path d="M14.217,19.707l-1.112,2.547c-0.427,0.979-1.782,0.979-2.21,0l-1.112-2.547c-0.99-2.267-2.771-4.071-4.993-5.057L1.73,13.292c-0.973-0.432-0.973-1.848,0-2.28l2.965-1.316C6.974,8.684,8.787,6.813,9.76,4.47l1.126-2.714c0.418-1.007,1.81-1.007,2.228,0L14.24,4.47c0.973,2.344,2.786,4.215,5.065,5.226l2.965,1.316c0.973,0.432,0.973,1.848,0,2.28l-3.061,1.359C16.988,15.637,15.206,17.441,14.217,19.707z"></path>
          <path d="M24.481,27.796l-0.339,0.777c-0.248,0.569-1.036,0.569-1.284,0l-0.339-0.777c-0.604-1.385-1.693-2.488-3.051-3.092l-1.044-0.464c-0.565-0.251-0.565-1.072,0-1.323l0.986-0.438c1.393-0.619,2.501-1.763,3.095-3.195l0.348-0.84c0.243-0.585,1.052-0.585,1.294,0l0.348,0.84c0.594,1.432,1.702,2.576,3.095,3.195l0.986,0.438c0.565,0.251,0.565,1.072,0,1.323l-1.044,0.464C26.174,25.308,25.085,26.411,24.481,27.796z"></path>
        </svg>
        Crear prompt
      </button>
      <button class="btn" type="button" id="export-assets-json">{{ 'templates.translations.assets.export-json'|t('pragmatic-web-toolkit') }}</button>
      <button class="btn" type="button" id="import-assets-json">{{ 'templates.translations.assets.import-json'|t('pragmatic-web-toolkit') }}</button>
      <button class="btn submit" type="submit" form="assets-form" id="save-all-assets" data-pwt-save-shortcut>{{ 'templates.translations.assets.save-all'|t('pragmatic-web-toolkit') }}</button>
    </div>
  </div>

  <form method="post" accept-charset="UTF-8" id="assets-form">
    {{ csrfInput() }}
    {{ actionInput('pragmatic-web-toolkit/translations/save-asset-rows') }}
    {{ redirectInput('pragmatic-toolkit/translations/assets', { q: search, perPage: perPage, page: page, sort: sort, dir: dir, site: selectedSite.handle }) }}
    <input type="hidden" name="q" value="{{ search }}">
    <input type="hidden" name="perPage" value="{{ perPage }}">
    <input type="hidden" name="page" value="{{ page }}">
    <input type="hidden" name="sort" value="{{ sort }}">
    <input type="hidden" name="dir" value="{{ dir }}">
    <input type="hidden" name="site" value="{{ selectedSite.handle }}">

    {% set usedNextDir = sort == 'used' and dir == 'desc' ? 'asc' : 'desc' %}
    {% set assetNextDir = sort == 'asset' and dir == 'asc' ? 'desc' : 'asc' %}
    <table class="data fullwidth" style="margin-top: 16px;">
      <thead>
        <tr>
          <th style="width: 30px;">
            <input type="checkbox" id="select-all-asset-rows" title="{{ 'templates.translations.assets.select-all-rows'|t('pragmatic-web-toolkit') }}">
          </th>
          <th>
            <a href="{{ url('pragmatic-toolkit/translations/assets', { q: search, perPage: perPage, page: 1, sort: 'used', dir: usedNextDir, site: selectedSite.handle }) }}">
              {{ 'templates.translations.assets.used'|t('pragmatic-web-toolkit') }}
            </a>
          </th>
          <th>
            <a href="{{ url('pragmatic-toolkit/translations/assets', { q: search, perPage: perPage, page: 1, sort: 'asset', dir: assetNextDir, site: selectedSite.handle }) }}">
              {{ 'templates.translations.assets.asset'|t('pragmatic-web-toolkit') }}
            </a>
          </th>
          <th>{{ 'templates.translations.assets.field'|t('pragmatic-web-toolkit') }}</th>
          {% for language in orderedLanguages %}
            {% set isCurrentLanguage = language == currentLanguage %}
            <th class="{{ isCurrentLanguage ? 'assets-current-language-col assets-current-language-header' : '' }}">
              {{ language }}{{ isCurrentLanguage ? ' (' ~ 'templates.translations.assets.current'|t('pragmatic-web-toolkit') ~ ')' : '' }}
              {% if languages|length > 2 and not isCurrentLanguage %}
                <label class="assets-language-target-toggle">
                  <input type="checkbox" class="js-language-target" data-language="{{ language }}" checked>
                  <span>{{ 'templates.translations.assets.translate'|t('pragmatic-web-toolkit') }}</span>
                </label>
              {% endif %}
            </th>
          {% endfor %}
          <th>{{ 'templates.translations.assets.action'|t('pragmatic-web-toolkit') }}</th>
        </tr>
      </thead>
      <tbody>
        {% for row in rows %}
          {% set rowIndex = loop.index0 %}
          {% set assetId = row.assetId %}
          {% set assetKey = row.assetKey ?? ('asset:' ~ row.assetId) %}
          {% set prevAssetKey = loop.first ? null : (rows[loop.index0 - 1].assetKey ?? ('asset:' ~ rows[loop.index0 - 1].assetId)) %}
          {% set isFirstOfGroup = assetKey != prevAssetKey %}
          {% set defaultAsset = row.defaultAsset ?? row.asset %}
          <tr{{ isFirstOfGroup and not loop.first ? ' class="asset-group-border"' : '' }}>
            <td>
              <input
                type="checkbox"
                class="js-asset-row-select"
                data-asset-id="{{ assetId }}"
                data-field-handle="{{ row.fieldHandle }}"
              >
            </td>
            {% if isFirstOfGroup %}
              <td rowspan="{{ assetRowCounts[assetKey] ?? 1 }}" style="vertical-align: top;">
                {% if row.isUsed %}
                  <span class="status enabled" title="{{ 'templates.translations.assets.used'|t('pragmatic-web-toolkit') }}"></span>
                {% else %}
                  <span class="status" title="{{ 'templates.translations.assets.unused'|t('pragmatic-web-toolkit') }}"></span>
                {% endif %}
              </td>
              <td rowspan="{{ assetRowCounts[assetKey] ?? 1 }}" style="vertical-align: top;">
                <span class="img-preview-wrap">
                  <a href="#" class="js-asset-slideout" data-asset-id="{{ assetId }}" data-site-id="{{ selectedSiteId }}">{{ defaultAsset.filename|default('Asset #' ~ assetId) }}</a>
                  {% if defaultAsset.url %}
                    <span class="img-preview-popover">
                      <img src="{{ defaultAsset.url }}" alt="{{ defaultAsset.title|default(defaultAsset.filename|default('Asset')) }}" loading="lazy">
                    </span>
                  {% endif %}
                </span>
                <div class="light">ID {{ assetId }}</div>
              </td>
            {% endif %}
            <td>
              <input type="hidden" name="assets[{{ rowIndex }}][assetId]" value="{{ assetId }}">
              <input type="hidden" name="assets[{{ rowIndex }}][fieldHandle]" value="{{ row.fieldHandle }}">
              <div>{{ row.fieldLabel }}</div>
              <div class="light">{{ row.fieldHandle }}</div>
            </td>
            {% for language in orderedLanguages %}
              {% set isCurrentLanguage = language == currentLanguage %}
              <td class="{{ isCurrentLanguage ? 'assets-current-language-col' : '' }}">
                <textarea class="text fullwidth js-asset-input" rows="2" name="assets[{{ rowIndex }}][values][{{ language }}]" data-language="{{ language }}">{{ row.values[language] ?? '' }}</textarea>
              </td>
            {% endfor %}
            <td style="white-space: nowrap;">
              <button class="btn submit js-save-asset-row" type="button" data-row-index="{{ rowIndex }}">{{ 'templates.translations.assets.save'|t('pragmatic-web-toolkit') }}</button>
            </td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  </form>

  <div class="flex justify-between align-center" style="margin-top: 16px;">
    <div>{{ total }} {{ 'templates.translations.assets.total'|t('pragmatic-web-toolkit') }}</div>
    <div class="flex" style="gap: 8px; align-items: center;">
      {% set prevPage = page > 1 ? page - 1 : 1 %}
      {% set nextPage = page < totalPages ? page + 1 : totalPages %}
      {% if page == 1 %}
        <span class="btn disabled">{{ 'templates.translations.assets.prev'|t('pragmatic-web-toolkit') }}</span>
      {% else %}
        <a class="btn" href="{{ url('pragmatic-toolkit/translations/assets', { q: search, perPage: perPage, page: prevPage, sort: sort, dir: dir, site: selectedSite.handle }) }}">{{ 'templates.translations.assets.prev'|t('pragmatic-web-toolkit') }}</a>
      {% endif %}
      <div>{{ 'templates.translations.assets.page'|t('pragmatic-web-toolkit') }} {{ page }} / {{ totalPages }}</div>
      {% if page == totalPages %}
        <span class="btn disabled">{{ 'templates.translations.assets.next'|t('pragmatic-web-toolkit') }}</span>
      {% else %}
        <a class="btn" href="{{ url('pragmatic-toolkit/translations/assets', { q: search, perPage: perPage, page: nextPage, sort: sort, dir: dir, site: selectedSite.handle }) }}">{{ 'templates.translations.assets.next'|t('pragmatic-web-toolkit') }}</a>
      {% endif %}
      <label for="perPage" class="light" style="margin: 0 0 0 8px;">{{ 'templates.translations.assets.per-page'|t('pragmatic-web-toolkit') }}</label>
      <div class="select">
        <select id="perPage" name="perPage">
          {% for option in [50, 100, 250] %}
            <option value="{{ option }}" {{ option == perPage ? 'selected' : '' }}>{{ option }}</option>
          {% endfor %}
        </select>
      </div>
    </div>
  </div>

  {% js %}
    (function() {
      const filterForm = document.getElementById('assets-filter');
      const searchInput = document.getElementById('q');
      const perPageSelect = document.getElementById('perPage');
      const perPageHidden = filterForm ? filterForm.querySelector('input[name="perPage"]') : null;
      const assetsForm = document.getElementById('assets-form');
      const selectAllAssetRows = document.getElementById('select-all-asset-rows');
      const generateSelectedAssetsButton = document.getElementById('generate-selected-assets');
      const exportAssetsJsonButton = document.getElementById('export-assets-json');
      const importAssetsJsonButton = document.getElementById('import-assets-json');
      const selectedSiteId = {{ selectedSiteId|json_encode|raw }};
      const generateAssetsPromptUrl = {{ actionUrl('pragmatic-web-toolkit/translations/generate-assets-prompt-batch')|json_encode|raw }};
      const exportAssetsJsonUrl = {{ actionUrl('pragmatic-web-toolkit/translations/export-assets-json-bundle')|json_encode|raw }};
      const importAssetsPreviewUrl = {{ actionUrl('pragmatic-web-toolkit/translations/import-assets-json-preview')|json_encode|raw }};
      const importAssetsApplyUrl = {{ actionUrl('pragmatic-web-toolkit/translations/import-assets-json-apply')|json_encode|raw }};
      const languageCount = {{ languages|length }};
      const currentLanguage = {{ currentLanguage|json_encode|raw }};

      if (filterForm) {
        const pageInput = filterForm.querySelector('input[name="page"]');
        function resetPageAndSubmit() {
          if (pageInput) pageInput.value = '1';
          if (perPageHidden && perPageSelect) perPageHidden.value = perPageSelect.value;
          filterForm.submit();
        }

        let searchTimer = null;
        if (searchInput) {
          searchInput.addEventListener('input', function() {
            if (searchTimer) clearTimeout(searchTimer);
            searchTimer = setTimeout(resetPageAndSubmit, 300);
          });
        }
        if (perPageSelect) {
          perPageSelect.addEventListener('change', resetPageAndSubmit);
        }
      }

      document.querySelectorAll('.js-asset-slideout').forEach(function(link) {
        link.addEventListener('click', function(ev) {
          ev.preventDefault();
          const assetId = parseInt(link.getAttribute('data-asset-id'), 10);
          const siteId = parseInt(link.getAttribute('data-site-id'), 10);
          if (!assetId || !siteId || !window.Craft || typeof Craft.createElementEditor !== 'function') return;
          Craft.createElementEditor('craft\\elements\\Asset', $(link), {
            elementId: assetId,
            siteId: siteId,
          });
        });
      });

      function getSelectedAssetItems() {
        return Array.from(document.querySelectorAll('.js-asset-row-select:checked')).map(function(checkbox) {
          return {
            assetId: parseInt(checkbox.getAttribute('data-asset-id') || '0', 10),
            fieldHandle: String(checkbox.getAttribute('data-field-handle') || ''),
          };
        }).filter(function(item) { return item.assetId > 0 && item.fieldHandle !== ''; });
      }
      function requireSelectedAssetItems() {
        const items = getSelectedAssetItems();
        if (!items.length) {
          Craft.cp.displayError('{{ 'templates.translations.assets.select-at-least-one-row'|t('pragmatic-web-toolkit')|e('js') }}');
          return null;
        }
        return items;
      }
      function getSelectedTargetLanguages() {
        if (languageCount <= 2) {
          return [];
        }
        return Array.from(document.querySelectorAll('.js-language-target:checked'))
          .map(function(checkbox) { return String(checkbox.getAttribute('data-language') || '').trim(); })
          .filter(function(language) { return language !== '' && language !== currentLanguage; });
      }
      function downloadJson(filename, payload) {
        const blob = new Blob([payload], { type: 'application/json;charset=utf-8' });
        const url = URL.createObjectURL(blob);
        const link = document.createElement('a');
        link.href = url;
        link.download = filename;
        document.body.appendChild(link);
        link.click();
        link.remove();
        URL.revokeObjectURL(url);
      }
      function openManualPromptModal(title, promptText) {
        const modalEl = document.createElement('div');
        modalEl.className = 'modal pwt-unified-modal pwt-unified-modal--large';
        modalEl.innerHTML =
          '<div class="body"><div class="content">' +
            '<h2 style="margin-top:0;">' + title + '</h2>' +
            '<textarea class="text fullwidth js-manual-prompt-output" rows="18" readonly style="font-family: Menlo, Monaco, Consolas, monospace;">' + Craft.escapeHtml(promptText) + '</textarea>' +
          '</div></div>' +
          '<div class="footer"><div class="btngroup">' +
            '<button type="button" class="btn" data-action="copy">{{ 'templates.translations.assets.copy-prompt'|t('pragmatic-web-toolkit')|e('js') }}</button>' +
            '<button type="button" class="btn" data-action="close">{{ 'templates.translations.assets.close'|t('pragmatic-web-toolkit')|e('js') }}</button>' +
          '</div></div>';
        const modal = new Garnish.Modal(modalEl, { autoShow: true, onHide: function() { modal.destroy(); } });
        const outputField = modalEl.querySelector('.js-manual-prompt-output');
        if (outputField) {
          outputField.focus();
          outputField.select();
        }
        modalEl.querySelector('[data-action="copy"]')?.addEventListener('click', async function() {
          try {
            await navigator.clipboard.writeText(promptText);
            Craft.cp.displayNotice('{{ 'templates.translations.assets.prompt-copied'|t('pragmatic-web-toolkit')|e('js') }}');
          } catch (error) {
            Craft.cp.displayError('{{ 'templates.translations.assets.could-not-copy-automatically'|t('pragmatic-web-toolkit')|e('js') }}');
          }
        });
        modalEl.querySelector('[data-action="close"]')?.addEventListener('click', function() { modal.hide(); });
      }
      function openExportJsonModal(filename, jsonText) {
        const modalEl = document.createElement('div');
        modalEl.className = 'modal pwt-unified-modal pwt-unified-modal--large';
        modalEl.innerHTML =
          '<div class="body"><div class="content">' +
            '<h2 style="margin-top:0;">{{ 'templates.translations.assets.export-json'|t('pragmatic-web-toolkit')|e('js') }}</h2>' +
            '<textarea class="text fullwidth js-export-json-text" rows="24" readonly style="font-family: Menlo, Monaco, Consolas, monospace; min-height: 72vh;">' + Craft.escapeHtml(jsonText) + '</textarea>' +
          '</div></div>' +
          '<div class="footer"><div class="buttons">' +
            '<button type="button" class="btn" data-action="copy">{{ 'templates.translations.assets.copy-json'|t('pragmatic-web-toolkit')|e('js') }}</button>' +
            '<button type="button" class="btn" data-action="download">{{ 'templates.translations.assets.download-json'|t('pragmatic-web-toolkit')|e('js') }}</button>' +
            '<button type="button" class="btn" data-action="close">{{ 'templates.translations.assets.close'|t('pragmatic-web-toolkit')|e('js') }}</button>' +
          '</div></div>';
        const modal = new Garnish.Modal(modalEl, { autoShow: true, onHide: function() { modal.destroy(); } });
        const textarea = modalEl.querySelector('.js-export-json-text');
        if (textarea) {
          textarea.focus();
          textarea.select();
        }
        modalEl.querySelector('[data-action="copy"]')?.addEventListener('click', async function() {
          try {
            await navigator.clipboard.writeText(jsonText);
            Craft.cp.displayNotice('{{ 'templates.translations.assets.json-copied'|t('pragmatic-web-toolkit')|e('js') }}');
          } catch (error) {
            Craft.cp.displayError('{{ 'templates.translations.assets.could-not-copy-automatically'|t('pragmatic-web-toolkit')|e('js') }}');
          }
        });
        modalEl.querySelector('[data-action="download"]')?.addEventListener('click', function() { downloadJson(filename, jsonText); });
        modalEl.querySelector('[data-action="close"]')?.addEventListener('click', function() { modal.hide(); });
      }
      function renderImportPreview(preview) {
        if (!preview || !preview.totals) {
          return '<p class="error">{{ 'templates.translations.assets.invalid-preview-response'|t('pragmatic-web-toolkit')|e('js') }}</p>';
        }
        return [
          '<div style="padding:10px;border:1px solid #e5e7eb;border-radius:6px;">',
          '<p><strong>{{ 'templates.translations.assets.total-items'|t('pragmatic-web-toolkit')|e('js') }}:</strong> ' + preview.totals.totalItems + '</p>',
          '<p><strong>{{ 'templates.translations.assets.matched-changed'|t('pragmatic-web-toolkit')|e('js') }}:</strong> ' + preview.totals.matchedChanged + '</p>',
          '<p><strong>{{ 'templates.translations.assets.matched-unchanged'|t('pragmatic-web-toolkit')|e('js') }}:</strong> ' + preview.totals.matchedUnchanged + '</p>',
          '<p><strong>{{ 'templates.translations.assets.skipped-unmatched'|t('pragmatic-web-toolkit')|e('js') }}:</strong> ' + preview.totals.skippedUnmatched + '</p>',
          '<p><strong>{{ 'templates.translations.assets.invalid-items'|t('pragmatic-web-toolkit')|e('js') }}:</strong> ' + preview.totals.invalidItems + '</p>',
          '</div>',
        ].join('');
      }
      function normalizePreviewItems(items) {
        if (Array.isArray(items)) {
          return items;
        }
        if (items && typeof items === 'object') {
          return Object.values(items);
        }
        return [];
      }
      function openImportJsonModal() {
        const modalEl = document.createElement('div');
        modalEl.className = 'modal pwt-unified-modal pwt-unified-modal--large';
        modalEl.innerHTML =
          '<div class="body"><div class="content">' +
            '<h2 style="margin-top:0;">{{ 'templates.translations.assets.import-json'|t('pragmatic-web-toolkit')|e('js') }}</h2>' +
            '<textarea class="text fullwidth js-import-json-text" rows="16" style="min-height: 38vh;" placeholder="{{ 'templates.translations.assets.paste-json-here'|t('pragmatic-web-toolkit')|e('js') }}"></textarea>' +
            '<div style="margin-top:10px;"><input type="file" class="js-import-json-file" accept=".json,application/json"></div>' +
            '<div class="js-import-preview" style="margin-top:14px; max-height:28vh; overflow:auto;"></div>' +
          '</div></div>' +
          '<div class="footer"><div class="buttons">' +
            '<button type="button" class="btn" data-action="preview">{{ 'templates.translations.assets.preview-import'|t('pragmatic-web-toolkit')|e('js') }}</button>' +
            '<button type="button" class="btn submit disabled" data-action="apply" disabled>{{ 'templates.translations.assets.apply-import'|t('pragmatic-web-toolkit')|e('js') }}</button>' +
            '<button type="button" class="btn" data-action="close">{{ 'templates.translations.assets.close'|t('pragmatic-web-toolkit')|e('js') }}</button>' +
          '</div></div>';
        const modal = new Garnish.Modal(modalEl, { autoShow: true, onHide: function() { modal.destroy(); } });
        const textArea = modalEl.querySelector('.js-import-json-text');
        const fileInput = modalEl.querySelector('.js-import-json-file');
        const previewEl = modalEl.querySelector('.js-import-preview');
        const previewBtn = modalEl.querySelector('[data-action="preview"]');
        const applyBtn = modalEl.querySelector('[data-action="apply"]');
        let lastMatchedChanged = [];
        let lastPreviewTotals = null;

        function buildImportRequestOptions() {
          const jsonText = (textArea?.value || '').trim();
          const hasFile = !!(fileInput && fileInput.files && fileInput.files[0]);
          if (!jsonText && !hasFile) {
            throw new Error('{{ 'templates.translations.assets.paste-json-or-select-a-file'|t('pragmatic-web-toolkit')|e('js') }}');
          }
          if (jsonText) {
            return { data: { siteId: selectedSiteId, jsonText: jsonText } };
          }
          const data = new FormData();
          data.append('siteId', String(selectedSiteId));
          data.append('jsonFile', fileInput.files[0]);
          return { data: data };
        }

        previewBtn?.addEventListener('click', async function() {
          previewBtn.disabled = true;
          lastMatchedChanged = [];
          lastPreviewTotals = null;
          try {
            const options = buildImportRequestOptions();
            const response = await Craft.sendActionRequest('POST', importAssetsPreviewUrl, options);
            if (!response.data || !response.data.success || !response.data.preview) {
              throw new Error(response.data && response.data.error ? response.data.error : '{{ 'templates.translations.assets.could-not-preview-import'|t('pragmatic-web-toolkit')|e('js') }}');
            }
            previewEl.innerHTML = renderImportPreview(response.data.preview);
            lastPreviewTotals = response.data.preview.totals || null;
            lastMatchedChanged = normalizePreviewItems(response.data.preview.matchedChanged);
            const changedCount = lastPreviewTotals && typeof lastPreviewTotals.matchedChanged !== 'undefined'
              ? parseInt(lastPreviewTotals.matchedChanged, 10) || 0
              : lastMatchedChanged.length;
            if (changedCount > 0) {
              applyBtn.disabled = false;
              applyBtn.classList.remove('disabled');
            }
          } catch (error) {
            previewEl.innerHTML = '<p class="error">' + Craft.escapeHtml(error.message || '{{ 'templates.translations.assets.could-not-preview-import'|t('pragmatic-web-toolkit')|e('js') }}') + '</p>';
          } finally {
            previewBtn.disabled = false;
            syncApplyEnabled();
          }
        });
        applyBtn?.addEventListener('click', async function() {
          applyBtn.disabled = true;
          try {
            let requestOptions;
            if (lastMatchedChanged.length) {
              requestOptions = {
                data: {
                  siteId: selectedSiteId,
                  itemsJson: JSON.stringify(lastMatchedChanged),
                },
              };
            } else {
              requestOptions = buildImportRequestOptions();
            }

            const response = await Craft.sendActionRequest('POST', importAssetsApplyUrl, requestOptions);
            if (!response.data || !response.data.success) {
              throw new Error(response.data && response.data.error ? response.data.error : '{{ 'templates.translations.assets.could-not-apply-import'|t('pragmatic-web-toolkit')|e('js') }}');
            }
            Craft.cp.displayNotice('{{ 'templates.translations.assets.import-applied'|t('pragmatic-web-toolkit')|e('js') }}');
            window.location.reload();
          } catch (error) {
            Craft.cp.displayError(error.message || '{{ 'templates.translations.assets.could-not-apply-import'|t('pragmatic-web-toolkit')|e('js') }}');
          } finally {
            applyBtn.disabled = false;
            syncApplyEnabled();
          }
        });
        function syncApplyEnabled() {
          const hasText = !!((textArea?.value || '').trim());
          const hasFile = !!(fileInput?.files && fileInput.files.length);
          const hasPreviewItems = lastMatchedChanged.length > 0;
          const hasPreviewChanges = !!(lastPreviewTotals && parseInt(lastPreviewTotals.matchedChanged, 10) > 0);
          const enabled = hasText || hasFile || hasPreviewItems || hasPreviewChanges;
          applyBtn.disabled = !enabled;
          if (enabled) {
            applyBtn.classList.remove('disabled');
          } else {
            applyBtn.classList.add('disabled');
          }
        }
        textArea?.addEventListener('input', syncApplyEnabled);
        fileInput?.addEventListener('change', syncApplyEnabled);
        syncApplyEnabled();
        modalEl.querySelector('[data-action="close"]')?.addEventListener('click', function() { modal.hide(); });
      }
      if (selectAllAssetRows) {
        selectAllAssetRows.addEventListener('change', function() {
          document.querySelectorAll('.js-asset-row-select').forEach(function(checkbox) {
            checkbox.checked = selectAllAssetRows.checked;
          });
        });
      }
      if (generateSelectedAssetsButton) {
        generateSelectedAssetsButton.addEventListener('click', async function() {
          const items = requireSelectedAssetItems();
          if (!items) return;
          const targetLanguages = getSelectedTargetLanguages();
          if (languageCount > 2 && targetLanguages.length === 0) {
            Craft.cp.displayError('{{ 'templates.translations.assets.select-at-least-one-target-language-column'|t('pragmatic-web-toolkit')|e("js") }}');
            return;
          }
          generateSelectedAssetsButton.disabled = true;
          generateSelectedAssetsButton.classList.add('loading');
          try {
            const response = await Craft.sendActionRequest('POST', generateAssetsPromptUrl, {
              data: { siteId: selectedSiteId, items: items, targetLanguages: targetLanguages, q: (searchInput?.value || '') },
            });
            if (!response.data || !response.data.success || !response.data.manualPrompt) {
              throw new Error(response.data && response.data.error ? response.data.error : '{{ 'templates.translations.assets.could-not-generate-prompt'|t('pragmatic-web-toolkit')|e('js') }}');
            }
            openManualPromptModal('{{ 'templates.translations.assets.translation-ai-prompt'|t('pragmatic-web-toolkit')|e('js') }}', response.data.manualPrompt);
          } catch (error) {
            Craft.cp.displayError(error.message || '{{ 'templates.translations.assets.could-not-generate-prompt'|t('pragmatic-web-toolkit')|e('js') }}');
          } finally {
            generateSelectedAssetsButton.disabled = false;
            generateSelectedAssetsButton.classList.remove('loading');
          }
        });
      }
      if (exportAssetsJsonButton) {
        exportAssetsJsonButton.addEventListener('click', async function() {
          const items = requireSelectedAssetItems();
          if (!items) return;
          exportAssetsJsonButton.disabled = true;
          exportAssetsJsonButton.classList.add('loading');
          try {
            const response = await Craft.sendActionRequest('POST', exportAssetsJsonUrl, {
              data: { siteId: selectedSiteId, items: items, q: (searchInput?.value || '') },
            });
            if (!response.data || !response.data.success || !response.data.bundle) {
              throw new Error(response.data && response.data.error ? response.data.error : '{{ 'templates.translations.assets.could-not-export-json'|t('pragmatic-web-toolkit')|e('js') }}');
            }
            openExportJsonModal(response.data.filename || 'translations-assets-export.json', JSON.stringify(response.data.bundle, null, 2));
          } catch (error) {
            Craft.cp.displayError(error.message || '{{ 'templates.translations.assets.could-not-export-json'|t('pragmatic-web-toolkit')|e('js') }}');
          } finally {
            exportAssetsJsonButton.disabled = false;
            exportAssetsJsonButton.classList.remove('loading');
          }
        });
      }
      if (importAssetsJsonButton) {
        importAssetsJsonButton.addEventListener('click', function() { openImportJsonModal(); });
      }
      if (assetsForm && typeof Craft !== 'undefined') {
        assetsForm.addEventListener('click', async function(event) {
          const button = event.target ? event.target.closest('.js-save-asset-row') : null;
          if (!button) return;
          event.preventDefault();

          const rowIndex = button.getAttribute('data-row-index');
          if (rowIndex === null || rowIndex === '') return;

          const originalText = button.textContent;
          button.classList.add('loading');
          button.disabled = true;
          try {
            const formData = new FormData(assetsForm);
            formData.set('saveRow', String(rowIndex));
            const response = await Craft.sendActionRequest('POST', 'pragmatic-web-toolkit/translations/save-asset-row', {
              data: formData,
            });

            if (!response.data || !response.data.success) {
              const backendError = response && response.data && response.data.error
                ? response.data.error
                : '{{ 'templates.translations.assets.could-not-save-row'|t('pragmatic-web-toolkit')|e('js') }}';
              throw new Error(backendError);
            }

            Craft.cp.displayNotice('{{ 'templates.translations.assets.asset-row-saved'|t('pragmatic-web-toolkit')|e('js') }}');
          } catch (error) {
            const message = error && error.response && error.response.data && error.response.data.error
              ? error.response.data.error
              : (error && error.message ? error.message : '{{ 'templates.translations.assets.could-not-save-row'|t('pragmatic-web-toolkit')|e('js') }}');
            Craft.cp.displayError(message);
          } finally {
            button.classList.remove('loading');
            button.disabled = false;
            button.textContent = originalText;
          }
        });
      }

      document.addEventListener('keydown', function(event) {
        const key = String(event.key || '').toLowerCase();
        if (key !== 's') return;
        if (!(event.metaKey || event.ctrlKey) || event.altKey || event.shiftKey) return;
        if (event.__pwtSaveShortcutHandled) return;
        if (!assetsForm) return;
        const saveButton = document.getElementById('save-all-assets');
        if (!saveButton || saveButton.disabled) return;
        event.preventDefault();
        if (window.Craft && Craft.cp && typeof Craft.cp.displayNotice === 'function') {
          Craft.cp.displayNotice('{{ 'templates.pwt.save-shortcut.saving'|t('pragmatic-web-toolkit')|e('js') }}');
        }
        if (typeof assetsForm.requestSubmit === 'function') {
          assetsForm.requestSubmit(saveButton);
        } else {
          saveButton.click();
        }
      });
    })();
  {% endjs %}
{% endblock %}

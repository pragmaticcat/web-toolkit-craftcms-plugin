{% extends "pragmatic-web-toolkit/translations/_layout" %}

{% set title = "Entries"|t('pragmatic-web-toolkit') %}
{% set selectedTab = 'entries' %}

{% set crumbs = [
    { label: "Translations"|t('pragmatic-web-toolkit'), url: url('pragmatic-toolkit/translations', { site: selectedSite.handle }) },
    { label: "Entries"|t('pragmatic-web-toolkit'), url: url('pragmatic-toolkit/translations/entries', { site: selectedSite.handle }) },
] %}

{% block sidebar %}
  <nav aria-label="{{ "Sections"|t('pragmatic-web-toolkit') }}">
    <ul class="nav">
      <li>
        <a class="{{ not sectionFilter ? 'sel' : '' }}" href="{{ url('pragmatic-toolkit/translations/entries', { site: selectedSite.handle, entry: entryFilter }) }}">
          {{ "All entries"|t('pragmatic-web-toolkit') }}
        </a>
      </li>
      {% if sections|length %}
        <li class="heading"><span>{{ "Sections"|t('pragmatic-web-toolkit') }}</span></li>
        {% for section in sections %}
          <li>
            <a class="{{ section.id|string == sectionFilter ? 'sel' : '' }}" href="{{ url('pragmatic-toolkit/translations/entries', { site: selectedSite.handle, section: section.id, entry: entryFilter }) }}">
              {{ section.name }} <span class="light" style="margin-left: 2px;">({{ section.count }})</span>
            </a>
          </li>
        {% endfor %}
      {% endif %}
    </ul>
  </nav>
{% endblock %}

{% block content %}
  {% set currentLanguage = selectedSite.language ?? '' %}
  {% set orderedLanguages = [] %}
  {% if currentLanguage and currentLanguage in languages %}
    {% set orderedLanguages = orderedLanguages|merge([currentLanguage]) %}
  {% endif %}
  {% for language in languages %}
    {% if language != currentLanguage %}
      {% set orderedLanguages = orderedLanguages|merge([language]) %}
    {% endif %}
  {% endfor %}

  {% css %}
    tr.entry-group-border > td { border-top: 2px solid #d1d5db; }
    .entries-current-language-col { background: #f3f9ff; }
    .entries-current-language-header { background: #e5f2ff; box-shadow: inset 0 -1px 0 #c8def5; }
    .entries-language-target-toggle { display:flex; align-items:center; gap:6px; margin-top:4px; font-weight: normal; }
    .btn-ai { display:flex; gap:8px; align-items:center; }
    .btn-ai svg { display:block; width:16px; height:16px; fill:currentColor; }
  {% endcss %}
  <div class="flex" style="margin-top: 12px; gap: 16px; align-items: flex-end; justify-content: space-between;">
    <form method="get" id="entries-filter" class="flex" style="gap: 12px; align-items: flex-end;">
      <input type="hidden" name="page" value="1">
      <input type="hidden" name="site" value="{{ selectedSite.handle }}">
      <input type="hidden" id="section-input" name="section" value="{{ sectionFilter }}">
      <div>
        <label for="q">{{ "Search"|t('pragmatic-web-toolkit') }}</label>
        <input class="text" type="text" id="q" name="q" value="{{ search }}" placeholder="{{ "Entry title"|t('pragmatic-web-toolkit') }}">
      </div>
      <div>
        <label for="entry">{{ "Entry"|t('pragmatic-web-toolkit') }}</label>
        <div class="select">
          <select id="entry" name="entry">
            {% for option in entryOptions %}
              <option value="{{ option.value }}" {{ option.value == entryFilter ? 'selected' : '' }}>{{ option.label }}</option>
            {% endfor %}
          </select>
        </div>
      </div>
      <input type="hidden" name="perPage" value="{{ perPage }}">
    </form>
    <div class="buttons" style="margin:0;">
      <button class="btn btn-ai" type="button" id="generate-selected-entries">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 30 30" aria-hidden="true">
          <path d="M14.217,19.707l-1.112,2.547c-0.427,0.979-1.782,0.979-2.21,0l-1.112-2.547c-0.99-2.267-2.771-4.071-4.993-5.057L1.73,13.292c-0.973-0.432-0.973-1.848,0-2.28l2.965-1.316C6.974,8.684,8.787,6.813,9.76,4.47l1.126-2.714c0.418-1.007,1.81-1.007,2.228,0L14.24,4.47c0.973,2.344,2.786,4.215,5.065,5.226l2.965,1.316c0.973,0.432,0.973,1.848,0,2.28l-3.061,1.359C16.988,15.637,15.206,17.441,14.217,19.707z"></path>
          <path d="M24.481,27.796l-0.339,0.777c-0.248,0.569-1.036,0.569-1.284,0l-0.339-0.777c-0.604-1.385-1.693-2.488-3.051-3.092l-1.044-0.464c-0.565-0.251-0.565-1.072,0-1.323l0.986-0.438c1.393-0.619,2.501-1.763,3.095-3.195l0.348-0.84c0.243-0.585,1.052-0.585,1.294,0l0.348,0.84c0.594,1.432,1.702,2.576,3.095,3.195l0.986,0.438c0.565,0.251,0.565,1.072,0,1.323l-1.044,0.464C26.174,25.308,25.085,26.411,24.481,27.796z"></path>
        </svg>
        Crear prompt
      </button>
      <button class="btn" type="button" id="export-entries-json">{{ "Export JSON"|t('pragmatic-web-toolkit') }}</button>
      <button class="btn" type="button" id="import-entries-json">{{ "Import JSON"|t('pragmatic-web-toolkit') }}</button>
      <button class="btn submit" type="submit" form="entries-form" id="save-all-entries">{{ "Save all"|t('pragmatic-web-toolkit') }}</button>
    </div>
  </div>

  <form method="post" accept-charset="UTF-8" id="entries-form">
    {{ csrfInput() }}
    {{ actionInput('pragmatic-web-toolkit/translations/save-entry-rows') }}
    {{ redirectInput('pragmatic-toolkit/translations/entries', { q: search, perPage: perPage, page: page, section: sectionFilter, entry: entryFilter, site: selectedSite.handle }) }}
    <input type="hidden" name="q" value="{{ search }}">
    <input type="hidden" name="perPage" value="{{ perPage }}">
    <input type="hidden" name="page" value="{{ page }}">
    <input type="hidden" name="section" value="{{ sectionFilter }}">
    <input type="hidden" name="entry" value="{{ entryFilter }}">
    <input type="hidden" name="site" value="{{ selectedSite.handle }}">

    <table class="data fullwidth" style="margin-top: 16px;">
      <thead>
        <tr>
          <th style="width: 30px;">
            <input type="checkbox" id="select-all-entry-rows" title="{{ 'Select all rows'|t('pragmatic-web-toolkit') }}">
          </th>
          <th>{{ "Entry"|t('pragmatic-web-toolkit') }}</th>
          <th>{{ "Field"|t('pragmatic-web-toolkit') }}</th>
          {% for language in orderedLanguages %}
            {% set isCurrentLanguage = language == currentLanguage %}
            <th class="{{ isCurrentLanguage ? 'entries-current-language-col entries-current-language-header' : '' }}">
              {{ language }}{{ isCurrentLanguage ? ' (' ~ "Current"|t('pragmatic-web-toolkit') ~ ')' : '' }}
              {% if languages|length > 2 and not isCurrentLanguage %}
                <label class="entries-language-target-toggle">
                  <input type="checkbox" class="js-language-target" data-language="{{ language }}" checked>
                  <span>{{ "Translate"|t('pragmatic-web-toolkit') }}</span>
                </label>
              {% endif %}
            </th>
          {% endfor %}
          <th>{{ "Action"|t('pragmatic-web-toolkit') }}</th>
        </tr>
      </thead>
      <tbody>
        {% for row in rows %}
          {% set rowIndex = loop.index0 %}
          {% set elementId = row.elementId %}
          {% set elementKey = row.elementKey ?? (row.elementType ~ ':' ~ row.elementId) %}
          {% set prevElementKey = loop.first ? null : (rows[loop.index0 - 1].elementKey ?? (rows[loop.index0 - 1].elementType ~ ':' ~ rows[loop.index0 - 1].elementId)) %}
          {% set isFirstOfGroup = elementKey != prevElementKey %}
          <tr{{ isFirstOfGroup and not loop.first ? ' class="entry-group-border"' : '' }} data-entry-id="{{ elementId }}">
            <td>
              <input
                type="checkbox"
                class="js-entry-row-select"
                data-element-type="{{ row.elementType }}"
                data-element-id="{{ elementId }}"
                data-field-handle="{{ row.fieldHandle }}"
              >
            </td>
            {% if isFirstOfGroup %}
              <td rowspan="{{ entryRowCounts[elementKey] ?? 1 }}" style="vertical-align: top;">
                {% if row.elementType == 'globalSet' %}
                  <a href="#" class="js-globalset-slideout" data-global-id="{{ elementId }}" data-site-id="{{ selectedSiteId }}">{{ row.element.name|default('Global #' ~ elementId) }}</a>
                  <div class="light">{{ "Global Set"|t('pragmatic-web-toolkit') }}</div>
                {% else %}
                  <a href="#" class="js-entry-slideout" data-entry-id="{{ elementId }}" data-site-id="{{ row.element.siteId }}">{{ row.element.title|default('Entry #' ~ elementId) }}</a>
                  <div class="light">{{ row.element.section.name ?? row.element.type.name ?? "No section or type"|t('pragmatic-web-toolkit') }}</div>
                {% endif %}
              </td>
            {% endif %}
            <td>
              <input type="hidden" name="entries[{{ rowIndex }}][elementType]" value="{{ row.elementType }}">
              <input type="hidden" name="entries[{{ rowIndex }}][elementId]" value="{{ elementId }}">
              <input type="hidden" name="entries[{{ rowIndex }}][entryId]" value="{{ row.elementType == 'entry' ? elementId : '' }}">
              <input type="hidden" name="entries[{{ rowIndex }}][fieldHandle]" value="{{ row.fieldHandle }}">
              <div>{{ row.fieldLabel }}</div>
              <div class="light">{{ row.fieldHandle }}</div>
            </td>
            {% for language in orderedLanguages %}
              {% set isCurrentLanguage = language == currentLanguage %}
              <td class="{{ isCurrentLanguage ? 'entries-current-language-col' : '' }}">
                <textarea class="text fullwidth js-entry-input" rows="2" name="entries[{{ rowIndex }}][values][{{ language }}]" data-row-index="{{ rowIndex }}" data-language="{{ language }}">{{ row.values[language] ?? '' }}</textarea>
              </td>
            {% endfor %}
            <td style="white-space: nowrap;">
              <button class="btn submit js-save-entry-row" type="button" data-row-index="{{ rowIndex }}">{{ "Save"|t('pragmatic-web-toolkit') }}</button>
            </td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  </form>

  <div class="flex justify-between align-center" style="margin-top: 16px;">
    <div>{{ total }} {{ "total"|t('pragmatic-web-toolkit') }}</div>
    <div class="flex" style="gap: 8px; align-items: center;">
      {% set prevPage = page > 1 ? page - 1 : 1 %}
      {% set nextPage = page < totalPages ? page + 1 : totalPages %}
      {% if page == 1 %}
        <span class="btn disabled">{{ "Prev"|t('pragmatic-web-toolkit') }}</span>
      {% else %}
        <a class="btn" href="{{ url('pragmatic-toolkit/translations/entries', { q: search, perPage: perPage, page: prevPage, section: sectionFilter, entry: entryFilter, site: selectedSite.handle }) }}">{{ "Prev"|t('pragmatic-web-toolkit') }}</a>
      {% endif %}
      <div>{{ "Page"|t('pragmatic-web-toolkit') }} {{ page }} / {{ totalPages }}</div>
      {% if page == totalPages %}
        <span class="btn disabled">{{ "Next"|t('pragmatic-web-toolkit') }}</span>
      {% else %}
        <a class="btn" href="{{ url('pragmatic-toolkit/translations/entries', { q: search, perPage: perPage, page: nextPage, section: sectionFilter, entry: entryFilter, site: selectedSite.handle }) }}">{{ "Next"|t('pragmatic-web-toolkit') }}</a>
      {% endif %}
      <label for="perPage" class="light" style="margin: 0 0 0 8px;">{{ "Per page"|t('pragmatic-web-toolkit') }}</label>
      <div class="select">
        <select id="perPage" name="perPage">
          {% for option in [50, 100, 250] %}
            <option value="{{ option }}" {{ option == perPage ? 'selected' : '' }}>{{ option }}</option>
          {% endfor %}
        </select>
      </div>
    </div>
  </div>

  {% js %}
    (function() {
      const filterForm = document.getElementById('entries-filter');
      const searchInput = document.getElementById('q');
      const entrySelect = document.getElementById('entry');
      const perPageSelect = document.getElementById('perPage');
      const perPageHidden = filterForm ? filterForm.querySelector('input[name="perPage"]') : null;
      const selectAllEntryRows = document.getElementById('select-all-entry-rows');
      const generateSelectedEntriesButton = document.getElementById('generate-selected-entries');
      const exportEntriesJsonButton = document.getElementById('export-entries-json');
      const importEntriesJsonButton = document.getElementById('import-entries-json');
      const selectedSiteId = {{ selectedSiteId|json_encode|raw }};
      const generateEntriesPromptUrl = {{ actionUrl('pragmatic-web-toolkit/translations/generate-entries-prompt-batch')|json_encode|raw }};
      const exportEntriesJsonUrl = {{ actionUrl('pragmatic-web-toolkit/translations/export-entries-json-bundle')|json_encode|raw }};
      const importEntriesPreviewUrl = {{ actionUrl('pragmatic-web-toolkit/translations/import-entries-json-preview')|json_encode|raw }};
      const importEntriesApplyUrl = {{ actionUrl('pragmatic-web-toolkit/translations/import-entries-json-apply')|json_encode|raw }};
      const languageCount = {{ languages|length }};
      const currentLanguage = {{ currentLanguage|json_encode|raw }};

      if (filterForm) {
        const pageInput = filterForm.querySelector('input[name="page"]');
        function resetPageAndSubmit() {
          if (pageInput) pageInput.value = '1';
          if (perPageHidden && perPageSelect) perPageHidden.value = perPageSelect.value;
          filterForm.submit();
        }

        let searchTimer = null;
        if (searchInput) {
          searchInput.addEventListener('input', function() {
            if (searchTimer) clearTimeout(searchTimer);
            searchTimer = setTimeout(resetPageAndSubmit, 300);
          });
        }
        [entrySelect, perPageSelect].forEach(function(el) {
          if (el) el.addEventListener('change', resetPageAndSubmit);
        });
      }

      document.querySelectorAll('.js-entry-slideout').forEach(function(link) {
        link.addEventListener('click', function(ev) {
          ev.preventDefault();
          const entryId = parseInt(link.getAttribute('data-entry-id'), 10);
          const siteId = parseInt(link.getAttribute('data-site-id'), 10);
          if (!entryId || !window.Craft) return;
          Craft.createElementEditor('craft\\elements\\Entry', {
            elementId: entryId,
            siteId: siteId || undefined,
            slideout: true
          });
        });
      });
      document.querySelectorAll('.js-globalset-slideout').forEach(function(link) {
        link.addEventListener('click', function(ev) {
          ev.preventDefault();
          const globalId = parseInt(link.getAttribute('data-global-id'), 10);
          const siteId = parseInt(link.getAttribute('data-site-id'), 10);
          if (!globalId || !window.Craft) return;
          Craft.createElementEditor('craft\\elements\\GlobalSet', {
            elementId: globalId,
            siteId: siteId || undefined,
            slideout: true
          });
        });
      });

      const entriesForm = document.getElementById('entries-form');
      function getSelectedEntryItems() {
        return Array.from(document.querySelectorAll('.js-entry-row-select:checked')).map(function(checkbox) {
          return {
            elementType: String(checkbox.getAttribute('data-element-type') || 'entry'),
            elementId: parseInt(checkbox.getAttribute('data-element-id') || '0', 10),
            fieldHandle: String(checkbox.getAttribute('data-field-handle') || ''),
          };
        }).filter(function(item) { return item.elementId > 0 && item.fieldHandle !== ''; });
      }
      function requireSelectedEntryItems() {
        const items = getSelectedEntryItems();
        if (!items.length) {
          Craft.cp.displayError('{{ "Select at least one row."|t('pragmatic-web-toolkit')|e('js') }}');
          return null;
        }
        return items;
      }
      function getSelectedTargetLanguages() {
        if (languageCount <= 2) {
          return [];
        }
        return Array.from(document.querySelectorAll('.js-language-target:checked'))
          .map(function(checkbox) { return String(checkbox.getAttribute('data-language') || '').trim(); })
          .filter(function(language) { return language !== '' && language !== currentLanguage; });
      }
      function downloadJson(filename, payload) {
        const blob = new Blob([payload], { type: 'application/json;charset=utf-8' });
        const url = URL.createObjectURL(blob);
        const link = document.createElement('a');
        link.href = url;
        link.download = filename;
        document.body.appendChild(link);
        link.click();
        link.remove();
        URL.revokeObjectURL(url);
      }
      function openManualPromptModal(title, promptText) {
        const modalEl = document.createElement('div');
        modalEl.className = 'modal pwt-unified-modal pwt-unified-modal--large';
        modalEl.innerHTML =
          '<div class="body"><div class="content">' +
            '<h2 style="margin-top:0;">' + title + '</h2>' +
            '<textarea class="text fullwidth js-manual-prompt-output" rows="18" readonly style="font-family: Menlo, Monaco, Consolas, monospace;">' + Craft.escapeHtml(promptText) + '</textarea>' +
          '</div></div>' +
          '<div class="footer"><div class="btngroup">' +
            '<button type="button" class="btn" data-action="copy">{{ "Copy prompt"|t('pragmatic-web-toolkit')|e('js') }}</button>' +
            '<button type="button" class="btn" data-action="close">{{ "Close"|t('pragmatic-web-toolkit')|e('js') }}</button>' +
          '</div></div>';
        const modal = new Garnish.Modal(modalEl, { autoShow: true, onHide: function() { modal.destroy(); } });
        const outputField = modalEl.querySelector('.js-manual-prompt-output');
        if (outputField) {
          outputField.focus();
          outputField.select();
        }
        modalEl.querySelector('[data-action="copy"]')?.addEventListener('click', async function() {
          try {
            await navigator.clipboard.writeText(promptText);
            Craft.cp.displayNotice('{{ "Prompt copied."|t('pragmatic-web-toolkit')|e('js') }}');
          } catch (error) {
            Craft.cp.displayError('{{ "Could not copy automatically."|t('pragmatic-web-toolkit')|e('js') }}');
          }
        });
        modalEl.querySelector('[data-action="close"]')?.addEventListener('click', function() { modal.hide(); });
      }
      function openExportJsonModal(filename, jsonText) {
        const modalEl = document.createElement('div');
        modalEl.className = 'modal pwt-unified-modal pwt-unified-modal--large';
        modalEl.innerHTML =
          '<div class="body"><div class="content">' +
            '<h2 style="margin-top:0;">{{ "Export JSON"|t('pragmatic-web-toolkit')|e('js') }}</h2>' +
            '<textarea class="text fullwidth js-export-json-text" rows="24" readonly style="font-family: Menlo, Monaco, Consolas, monospace; min-height: 72vh;">' + Craft.escapeHtml(jsonText) + '</textarea>' +
          '</div></div>' +
          '<div class="footer"><div class="buttons">' +
            '<button type="button" class="btn" data-action="copy">{{ "Copy JSON"|t('pragmatic-web-toolkit')|e('js') }}</button>' +
            '<button type="button" class="btn" data-action="download">{{ "Download JSON"|t('pragmatic-web-toolkit')|e('js') }}</button>' +
            '<button type="button" class="btn" data-action="close">{{ "Close"|t('pragmatic-web-toolkit')|e('js') }}</button>' +
          '</div></div>';
        const modal = new Garnish.Modal(modalEl, { autoShow: true, onHide: function() { modal.destroy(); } });
        const textarea = modalEl.querySelector('.js-export-json-text');
        if (textarea) {
          textarea.focus();
          textarea.select();
        }
        modalEl.querySelector('[data-action="copy"]')?.addEventListener('click', async function() {
          try {
            await navigator.clipboard.writeText(jsonText);
            Craft.cp.displayNotice('{{ "JSON copied."|t('pragmatic-web-toolkit')|e('js') }}');
          } catch (error) {
            Craft.cp.displayError('{{ "Could not copy automatically."|t('pragmatic-web-toolkit')|e('js') }}');
          }
        });
        modalEl.querySelector('[data-action="download"]')?.addEventListener('click', function() { downloadJson(filename, jsonText); });
        modalEl.querySelector('[data-action="close"]')?.addEventListener('click', function() { modal.hide(); });
      }
      function renderImportPreview(preview) {
        if (!preview || !preview.totals) {
          return '<p class="error">{{ "Invalid preview response."|t('pragmatic-web-toolkit')|e('js') }}</p>';
        }
        return [
          '<div style="padding:10px;border:1px solid #e5e7eb;border-radius:6px;">',
          '<p><strong>{{ "Total items"|t('pragmatic-web-toolkit')|e('js') }}:</strong> ' + preview.totals.totalItems + '</p>',
          '<p><strong>{{ "Matched (changed)"|t('pragmatic-web-toolkit')|e('js') }}:</strong> ' + preview.totals.matchedChanged + '</p>',
          '<p><strong>{{ "Matched (unchanged)"|t('pragmatic-web-toolkit')|e('js') }}:</strong> ' + preview.totals.matchedUnchanged + '</p>',
          '<p><strong>{{ "Skipped (unmatched)"|t('pragmatic-web-toolkit')|e('js') }}:</strong> ' + preview.totals.skippedUnmatched + '</p>',
          '<p><strong>{{ "Invalid items"|t('pragmatic-web-toolkit')|e('js') }}:</strong> ' + preview.totals.invalidItems + '</p>',
          '</div>',
        ].join('');
      }
      function openImportJsonModal() {
        const modalEl = document.createElement('div');
        modalEl.className = 'modal pwt-unified-modal pwt-unified-modal--large';
        modalEl.innerHTML =
          '<div class="body"><div class="content">' +
            '<h2 style="margin-top:0;">{{ "Import JSON"|t('pragmatic-web-toolkit')|e('js') }}</h2>' +
            '<textarea class="text fullwidth js-import-json-text" rows="16" style="min-height: 38vh;" placeholder="{{ "Paste JSON here"|t('pragmatic-web-toolkit')|e('js') }}"></textarea>' +
            '<div style="margin-top:10px;"><input type="file" class="js-import-json-file" accept=".json,application/json"></div>' +
            '<div class="js-import-preview" style="margin-top:14px; max-height:28vh; overflow:auto;"></div>' +
          '</div></div>' +
          '<div class="footer"><div class="buttons">' +
            '<button type="button" class="btn" data-action="preview">{{ "Preview import"|t('pragmatic-web-toolkit')|e('js') }}</button>' +
            '<button type="button" class="btn submit disabled" data-action="apply" disabled>{{ "Apply import"|t('pragmatic-web-toolkit')|e('js') }}</button>' +
            '<button type="button" class="btn" data-action="close">{{ "Close"|t('pragmatic-web-toolkit')|e('js') }}</button>' +
          '</div></div>';
        const modal = new Garnish.Modal(modalEl, { autoShow: true, onHide: function() { modal.destroy(); } });
        const textArea = modalEl.querySelector('.js-import-json-text');
        const fileInput = modalEl.querySelector('.js-import-json-file');
        const previewEl = modalEl.querySelector('.js-import-preview');
        const previewBtn = modalEl.querySelector('[data-action="preview"]');
        const applyBtn = modalEl.querySelector('[data-action="apply"]');
        let lastMatchedChanged = [];
        let lastPreviewTotals = null;

        function normalizePreviewItems(items) {
          if (Array.isArray(items)) {
            return items;
          }
          if (items && typeof items === 'object') {
            return Object.values(items);
          }
          return [];
        }

        function buildImportRequestOptions() {
          const jsonText = (textArea?.value || '').trim();
          const hasFile = !!(fileInput && fileInput.files && fileInput.files[0]);
          if (!jsonText && !hasFile) {
            throw new Error('{{ "Paste JSON or select a file."|t('pragmatic-web-toolkit')|e('js') }}');
          }
          if (jsonText) {
            return { data: { siteId: selectedSiteId, jsonText: jsonText } };
          }
          const data = new FormData();
          data.append('siteId', String(selectedSiteId));
          data.append('jsonFile', fileInput.files[0]);
          return { data: data };
        }

        previewBtn?.addEventListener('click', async function() {
          previewBtn.disabled = true;
          lastMatchedChanged = [];
          lastPreviewTotals = null;
          try {
            const options = buildImportRequestOptions();
            const response = await Craft.sendActionRequest('POST', importEntriesPreviewUrl, options);
            if (!response.data || !response.data.success || !response.data.preview) {
              throw new Error(response.data && response.data.error ? response.data.error : '{{ "Could not preview import."|t('pragmatic-web-toolkit')|e('js') }}');
            }
            previewEl.innerHTML = renderImportPreview(response.data.preview);
            lastPreviewTotals = response.data.preview.totals || null;
            lastMatchedChanged = normalizePreviewItems(response.data.preview.matchedChanged);
            const changedCount = lastPreviewTotals && typeof lastPreviewTotals.matchedChanged !== 'undefined'
              ? parseInt(lastPreviewTotals.matchedChanged, 10) || 0
              : lastMatchedChanged.length;
            if (changedCount > 0) {
              applyBtn.disabled = false;
              applyBtn.classList.remove('disabled');
            }
          } catch (error) {
            previewEl.innerHTML = '<p class="error">' + Craft.escapeHtml(error.message || '{{ "Could not preview import."|t('pragmatic-web-toolkit')|e('js') }}') + '</p>';
          } finally {
            previewBtn.disabled = false;
            syncApplyEnabled();
          }
        });
        applyBtn?.addEventListener('click', async function() {
          applyBtn.disabled = true;
          try {
            let requestOptions;
            if (lastMatchedChanged.length) {
              requestOptions = {
                data: {
                  siteId: selectedSiteId,
                  itemsJson: JSON.stringify(lastMatchedChanged),
                },
              };
            } else {
              requestOptions = buildImportRequestOptions();
            }
            const response = await Craft.sendActionRequest('POST', importEntriesApplyUrl, requestOptions);
            if (!response.data || !response.data.success) {
              throw new Error(response.data && response.data.error ? response.data.error : '{{ "Could not apply import."|t('pragmatic-web-toolkit')|e('js') }}');
            }
            Craft.cp.displayNotice('{{ "Import applied."|t('pragmatic-web-toolkit')|e('js') }}');
            window.location.reload();
          } catch (error) {
            Craft.cp.displayError(error.message || '{{ "Could not apply import."|t('pragmatic-web-toolkit')|e('js') }}');
          } finally {
            applyBtn.disabled = false;
            syncApplyEnabled();
          }
        });
        function syncApplyEnabled() {
          const hasText = !!((textArea?.value || '').trim());
          const hasFile = !!(fileInput?.files && fileInput.files.length);
          const hasPreviewItems = lastMatchedChanged.length > 0;
          const hasPreviewChanges = !!(lastPreviewTotals && parseInt(lastPreviewTotals.matchedChanged, 10) > 0);
          const enabled = hasText || hasFile || hasPreviewItems || hasPreviewChanges;
          applyBtn.disabled = !enabled;
          if (enabled) {
            applyBtn.classList.remove('disabled');
          } else {
            applyBtn.classList.add('disabled');
          }
        }
        textArea?.addEventListener('input', syncApplyEnabled);
        fileInput?.addEventListener('change', syncApplyEnabled);
        syncApplyEnabled();
        modalEl.querySelector('[data-action="close"]')?.addEventListener('click', function() { modal.hide(); });
      }
      if (selectAllEntryRows) {
        selectAllEntryRows.addEventListener('change', function() {
          document.querySelectorAll('.js-entry-row-select').forEach(function(checkbox) {
            checkbox.checked = selectAllEntryRows.checked;
          });
        });
      }
      if (generateSelectedEntriesButton) {
        generateSelectedEntriesButton.addEventListener('click', async function() {
          const items = requireSelectedEntryItems();
          if (!items) return;
          const targetLanguages = getSelectedTargetLanguages();
          if (languageCount > 2 && targetLanguages.length === 0) {
            Craft.cp.displayError('{{ "Select at least one target language column."|t("pragmatic-web-toolkit")|e("js") }}');
            return;
          }
          generateSelectedEntriesButton.disabled = true;
          generateSelectedEntriesButton.classList.add('loading');
          try {
            const response = await Craft.sendActionRequest('POST', generateEntriesPromptUrl, {
              data: { siteId: selectedSiteId, items: items, targetLanguages: targetLanguages, q: (searchInput?.value || ''), section: '{{ sectionFilter|e('js') }}', entry: (entrySelect?.value || '') },
            });
            if (!response.data || !response.data.success || !response.data.manualPrompt) {
              throw new Error(response.data && response.data.error ? response.data.error : '{{ "Could not generate prompt."|t('pragmatic-web-toolkit')|e('js') }}');
            }
            openManualPromptModal('{{ "Translation AI Prompt"|t('pragmatic-web-toolkit')|e('js') }}', response.data.manualPrompt);
          } catch (error) {
            Craft.cp.displayError(error.message || '{{ "Could not generate prompt."|t('pragmatic-web-toolkit')|e('js') }}');
          } finally {
            generateSelectedEntriesButton.disabled = false;
            generateSelectedEntriesButton.classList.remove('loading');
          }
        });
      }
      if (exportEntriesJsonButton) {
        exportEntriesJsonButton.addEventListener('click', async function() {
          const items = requireSelectedEntryItems();
          if (!items) return;
          exportEntriesJsonButton.disabled = true;
          exportEntriesJsonButton.classList.add('loading');
          try {
            const response = await Craft.sendActionRequest('POST', exportEntriesJsonUrl, {
              data: { siteId: selectedSiteId, items: items, q: (searchInput?.value || ''), section: '{{ sectionFilter|e('js') }}', entry: (entrySelect?.value || '') },
            });
            if (!response.data || !response.data.success || !response.data.bundle) {
              throw new Error(response.data && response.data.error ? response.data.error : '{{ "Could not export JSON."|t('pragmatic-web-toolkit')|e('js') }}');
            }
            openExportJsonModal(response.data.filename || 'translations-entries-export.json', JSON.stringify(response.data.bundle, null, 2));
          } catch (error) {
            Craft.cp.displayError(error.message || '{{ "Could not export JSON."|t('pragmatic-web-toolkit')|e('js') }}');
          } finally {
            exportEntriesJsonButton.disabled = false;
            exportEntriesJsonButton.classList.remove('loading');
          }
        });
      }
      if (importEntriesJsonButton) {
        importEntriesJsonButton.addEventListener('click', function() { openImportJsonModal(); });
      }
      if (entriesForm && typeof Craft !== 'undefined') {
        entriesForm.addEventListener('click', async function(event) {
          const button = event.target ? event.target.closest('.js-save-entry-row') : null;
          if (!button) return;
          event.preventDefault();

          const rowIndex = button.getAttribute('data-row-index');
          if (rowIndex === null || rowIndex === '') return;

          const originalText = button.textContent;
          button.classList.add('loading');
          button.disabled = true;
          try {
            const formData = new FormData(entriesForm);
            formData.set('saveRow', String(rowIndex));
            const response = await Craft.sendActionRequest('POST', 'pragmatic-web-toolkit/translations/save-entry-row', {
              data: formData,
            });

            if (!response.data || !response.data.success) {
              const backendError = response && response.data && response.data.error
                ? response.data.error
                : '{{ "Could not save row."|t('pragmatic-web-toolkit')|e('js') }}';
              throw new Error(backendError);
            }

            Craft.cp.displayNotice('{{ "Entry row saved."|t('pragmatic-web-toolkit')|e('js') }}');
          } catch (error) {
            const message = error && error.response && error.response.data && error.response.data.error
              ? error.response.data.error
              : (error && error.message ? error.message : '{{ "Could not save row."|t('pragmatic-web-toolkit')|e('js') }}');
            Craft.cp.displayError(message);
          } finally {
            button.classList.remove('loading');
            button.disabled = false;
            button.textContent = originalText;
          }
        });
      }

    })();
  {% endjs %}
{% endblock %}

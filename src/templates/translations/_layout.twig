{% extends parentLayout|default('_layouts/cp') %}

{% set title = title ?? 'templates.translations.layout.translations'|t('pragmatic-web-toolkit') %}
{% set selectedSubnavItem = "translations" %}
{% set _requestedSiteHandleRaw = craft.app.request.getQueryParam('site') %}
{% set _requestedSiteHandle = _requestedSiteHandleRaw is string ? _requestedSiteHandleRaw : null %}
{% set _selectedTab = selectedTab ?? '' %}
{% set _selectedSiteHandle = selectedSite is defined and selectedSite ? selectedSite.handle : (_requestedSiteHandle ?? null) %}
{% set _siteParam = _selectedSiteHandle ? { site: _selectedSiteHandle } : {} %}
{% set tabs = [
  {
    label: 'Static',
    url: url('pragmatic-toolkit/translations/static', _siteParam),
    class: _selectedTab == 'static' ? 'sel' : '',
  },
  {
    label: 'Entries',
    url: url('pragmatic-toolkit/translations/entries', _siteParam),
    class: _selectedTab == 'entries' ? 'sel' : '',
  },
  {
    label: 'SEO',
    url: url('pragmatic-toolkit/translations/seo', _siteParam),
    class: _selectedTab == 'seo' ? 'sel' : '',
  },
  {
    label: 'Assets',
    url: url('pragmatic-toolkit/translations/assets', _siteParam),
    class: _selectedTab == 'assets' ? 'sel' : '',
  },
] %}

{% set _allEditableSites = craft.app.sites.getEditableSites() %}
{% if _allEditableSites|length > 1 %}
  {% set _selectedSite = craft.app.sites.getPrimarySite() %}
  {% if _requestedSiteHandle %}
    {% set _siteByHandle = craft.app.sites.getSiteByHandle(_requestedSiteHandle) %}
    {% if _siteByHandle %}
      {% set _selectedSite = _siteByHandle %}
    {% endif %}
  {% endif %}
  {% if selectedSite is defined and selectedSite %}
    {% set _selectedSite = selectedSite %}
  {% endif %}
  {% set _siteMenuItems = siteMenuItems(_allEditableSites, _selectedSite) %}
  {% if _siteMenuItems|length %}
    {% set crumbs = (crumbs ?? [])|unshift({
      id: 'site-crumb',
      icon: 'world',
      iconAltText: 'Site'|t('app'),
      label: _selectedSite.name|t('site'),
      menu: {
        items: _siteMenuItems,
        label: 'Select site'|t('app')
      }
    }) %}
  {% endif %}
{% endif %}

{% set __pwtModalUtils %}
  {% include 'pragmatic-web-toolkit/_partials/pwt-modal-utils' %}
{% endset %}
{% include 'pragmatic-web-toolkit/_partials/pwt-save-shortcut' %}

{% block content %}
{% endblock %}

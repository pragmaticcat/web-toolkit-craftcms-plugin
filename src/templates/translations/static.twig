        {% set newGroupIndex = groups|length %}
        <tr data-new-group="1">
          <td>
            <div class="btngroup">
              <button type="button" class="btn small js-group-move-up" title="{{ 'templates.translations.static.move-up'|t('pragmatic-web-toolkit') }}">↑</button>
              <button type="button" class="btn small js-group-move-down" title="{{ 'templates.translations.static.move-down'|t('pragmatic-web-toolkit') }}">↓</button>
            </div>
            <input type="hidden" name="groups[{{ newGroupIndex }}][sortOrder]" value="" class="js-group-sort-order">
          </td>
          <td></td>
          <td>
            <input type="hidden" name="groups[{{ newGroupIndex }}][original]" value="">
            <input type="hidden" name="groups[{{ newGroupIndex }}][isActive]" value="1">
            <input type="hidden" name="groups[{{ newGroupIndex }}][delete]" value="0" class="js-group-delete-flag">
            <input class="text fullwidth" name="groups[{{ newGroupIndex }}][name]" placeholder="{{ 'templates.translations.static.new-group'|t('pragmatic-web-toolkit') }}">
          </td>
          <td>
            <button type="button" class="btn small danger js-group-remove">{{ 'templates.translations.static.remove'|t('pragmatic-web-toolkit') }}</button>
          </td>
        </tr>
      </tbody>
    </table>

    <div class="buttons" style="margin-top: 12px;">
      <button class="btn" id="add-group-row" type="button">{{ 'templates.translations.static.add-group'|t('pragmatic-web-toolkit') }}</button>
      <button class="btn submit" type="submit" id="save-groups">{{ 'templates.translations.static.save-groups'|t('pragmatic-web-toolkit') }}</button>
    </div>
  </form>

  {% js %}
    (function() {
      const filterForm = document.getElementById('entries-filter');
      const searchInput = document.getElementById('q');
      const perPageSelect = document.getElementById('perPage');
      const hideEmptyValuesField = document.getElementById('hide-empty-values-field');
      const hideEmptyValuesToggle = hideEmptyValuesField
        ? (hideEmptyValuesField.querySelector('#hide-empty-values')
          || hideEmptyValuesField.querySelector('input[type="checkbox"][name="hideEmptyValuesUi"]')
          || hideEmptyValuesField.querySelector('.lightswitch input[type="checkbox"]')
          || hideEmptyValuesField.querySelector('input[type="checkbox"]'))
        : null;
      const hideEmptyValuesSwitchWrapper = hideEmptyValuesField ? hideEmptyValuesField.querySelector('.lightswitch') : null;
      const paginationTotalCount = document.getElementById('pagination-total-count');
      const paginationPageLabel = document.getElementById('pagination-page-label');
      const paginationPrev = document.getElementById('pagination-prev');
      const paginationNext = document.getElementById('pagination-next');
      const hideEmptyStorageKey = 'pwt.translations.static.hideEmpty.{{ selectedSite.handle|e('js') }}.{{ (group ?: "__all__")|e('js') }}';
      const baseTotalCount = {{ total }};
      const basePage = {{ page }};
      const baseTotalPages = {{ totalPages }};
      const basePrevDisabled = {{ (page == 1)|json_encode|raw }};
      const baseNextDisabled = {{ (page == totalPages)|json_encode|raw }};
      const pageLabelText = '{{ 'templates.translations.static.page'|t('pragmatic-web-toolkit')|e('js') }}';

      if (filterForm) {
        let searchTimer = null;
        if (searchInput) {
          searchInput.addEventListener('input', function() {
            if (searchTimer) {
              clearTimeout(searchTimer);
            }
            searchTimer = setTimeout(function() {
              filterForm.submit();
            }, 300);
          });
        }
        if (perPageSelect) {
          perPageSelect.addEventListener('change', function() {
            const perPageInput = filterForm.querySelector('input[name="perPage"]');
            if (perPageInput) {
              perPageInput.value = perPageSelect.value;
            }
            const pageInput = filterForm.querySelector('input[name=\"page\"]');
            if (pageInput) pageInput.value = '1';
            filterForm.submit();
          });
        }
      }

      const translationsTable = document.getElementById('translations-table');
      const translationsForm = document.getElementById('translations-form');
      const addTranslationButton = document.getElementById('add-row');
      const selectAllRowsCheckbox = document.getElementById('select-all-rows');
      const deleteSelectedRowsButton = document.getElementById('delete-selected-rows');
      const removeUnusedStaticButton = document.getElementById('remove-unused-static');
      const removeUnusedForm = document.getElementById('remove-unused-static-form');
      const removeUnusedGroupInput = document.getElementById('remove-unused-group');
      const saveTranslationsButton = document.getElementById('save-translations');
      const generateSelectedStaticButton = document.getElementById('generate-selected-static');
      const exportStaticJsonButton = document.getElementById('export-static-json');
      const importStaticJsonButton = document.getElementById('import-static-json');
      const returnGroupInput = document.getElementById('return-group');
      const returnQInput = document.getElementById('return-q');
      const returnPerPageInput = document.getElementById('return-per-page');
      const returnPageInput = document.getElementById('return-page');
      const returnSiteInput = document.getElementById('return-site');
      const languageCount = {{ languages|length }};
      const currentLanguage = {{ currentLanguage|json_encode|raw }};
      const autotranslateAvailable = false;
      const autotranslateDisabledReason = {{ 'templates.translations.static.automatic-provider-translation-is-no-longer-available-use-prompt'|t('pragmatic-web-toolkit')|json_encode|raw }};
      const autotranslateTextUrl = '';
      const selectedSiteId = {{ selectedSiteId|json_encode|raw }};
      const staticGeneratePromptUrl = {{ actionUrl('pragmatic-web-toolkit/translations/generate-static-prompt-batch')|json_encode|raw }};
      const staticExportJsonUrl = {{ actionUrl('pragmatic-web-toolkit/translations/export-static-json-bundle')|json_encode|raw }};
      const staticImportPreviewUrl = {{ actionUrl('pragmatic-web-toolkit/translations/import-static-json-preview')|json_encode|raw }};
      const staticImportApplyUrl = {{ actionUrl('pragmatic-web-toolkit/translations/import-static-json-apply')|json_encode|raw }};
      function readFilterGroup() {
        const hiddenGroupInput = filterForm ? filterForm.querySelector('input[name="group"]') : null;
        return hiddenGroupInput ? hiddenGroupInput.value : '';
      }
      function syncReturnParams() {
        if (returnGroupInput) returnGroupInput.value = readFilterGroup();
        if (returnQInput) returnQInput.value = searchInput ? searchInput.value : '{{ search|e('js') }}';
        if (returnPerPageInput) returnPerPageInput.value = perPageSelect ? perPageSelect.value : '{{ perPage }}';
        if (returnPageInput && !returnPageInput.value) returnPageInput.value = '{{ page }}';
        if (returnSiteInput && !returnSiteInput.value) returnSiteInput.value = '{{ selectedSite.handle|e('js') }}';
      }
      function syncRemoveUnusedParams() {
        if (removeUnusedGroupInput) {
          removeUnusedGroupInput.value = readFilterGroup();
        }
      }
      function getDeleteCheckboxes() {
        return translationsTable ? Array.from(translationsTable.querySelectorAll('.js-delete-row-checkbox')) : [];
      }
      function syncSelectAllState() {
        const checkboxes = getDeleteCheckboxes();
        const checkedCount = checkboxes.filter(function(cb) { return cb.checked; }).length;
        if (selectAllRowsCheckbox) {
          selectAllRowsCheckbox.checked = checkboxes.length > 0 && checkedCount === checkboxes.length;
          selectAllRowsCheckbox.indeterminate = checkedCount > 0 && checkedCount < checkboxes.length;
        }
      }
      function getSelectedTranslationIds() {
        return getDeleteCheckboxes()
          .filter(function(cb) { return cb.checked; })
          .map(function(cb) { return parseInt(cb.getAttribute('data-translation-id') || '0', 10); })
          .filter(function(id) { return id > 0; });
      }
      function requireSelectedTranslationIds() {
        const ids = getSelectedTranslationIds();
        if (!ids.length) {
          Craft.cp.displayError('{{ 'templates.translations.static.select-at-least-one-existing-row'|t('pragmatic-web-toolkit')|e('js') }}');
          return null;
        }
        return ids;
      }
      function getSelectedTargetLanguages() {
        if (languageCount <= 2) {
          return [];
        }
        return Array.from(document.querySelectorAll('.js-language-target:checked'))
          .map(function(checkbox) { return String(checkbox.getAttribute('data-language') || '').trim(); })
          .filter(function(language) { return language !== '' && language !== currentLanguage; });
      }
      function openStaticPromptModal(title, promptText) {
        const modalEl = document.createElement('div');
        modalEl.className = 'modal pwt-unified-modal pwt-unified-modal--large';
        modalEl.innerHTML =
          '<div class="body"><div class="content">' +
            '<h2 style="margin-top:0;">' + title + '</h2>' +
            '<textarea class="text fullwidth js-manual-prompt-output" rows="18" readonly style="font-family: Menlo, Monaco, Consolas, monospace;">' + Craft.escapeHtml(promptText) + '</textarea>' +
          '</div></div>' +
          '<div class="footer"><div class="btngroup">' +
            '<button type="button" class="btn" data-action="copy">{{ 'templates.translations.static.copy-prompt'|t('pragmatic-web-toolkit')|e('js') }}</button>' +
            '<button type="button" class="btn" data-action="close">{{ 'templates.translations.static.close'|t('pragmatic-web-toolkit')|e('js') }}</button>' +
          '</div></div>';
        const modal = new Garnish.Modal(modalEl, { autoShow: true, onHide: function() { modal.destroy(); } });
        const outputField = modalEl.querySelector('.js-manual-prompt-output');
        if (outputField) {
          outputField.focus();
          outputField.select();
        }
        const copyBtn = modalEl.querySelector('[data-action="copy"]');
        const closeBtn = modalEl.querySelector('[data-action="close"]');
        copyBtn?.addEventListener('click', async function() {
          try {
            await navigator.clipboard.writeText(promptText);
            Craft.cp.displayNotice('{{ 'templates.translations.static.prompt-copied'|t('pragmatic-web-toolkit')|e('js') }}');
          } catch (error) {
            Craft.cp.displayError('{{ 'templates.translations.static.could-not-copy-automatically'|t('pragmatic-web-toolkit')|e('js') }}');
          }
        });
        closeBtn?.addEventListener('click', function() { modal.hide(); });
      }
      function downloadJson(filename, payload) {
        const blob = new Blob([payload], { type: 'application/json;charset=utf-8' });
        const url = URL.createObjectURL(blob);
        const link = document.createElement('a');
        link.href = url;
        link.download = filename;
        document.body.appendChild(link);
        link.click();
        link.remove();
        URL.revokeObjectURL(url);
      }
      function openStaticExportJsonModal(filename, jsonText) {
        const modalEl = document.createElement('div');
        modalEl.className = 'modal pwt-unified-modal pwt-unified-modal--large';
        modalEl.innerHTML =
          '<div class="body"><div class="content">' +
            '<h2 style="margin-top:0;">{{ 'templates.translations.static.export-json'|t('pragmatic-web-toolkit')|e('js') }}</h2>' +
            '<textarea class="text fullwidth js-export-json-text" rows="24" readonly style="font-family: Menlo, Monaco, Consolas, monospace; min-height: 72vh;">' + Craft.escapeHtml(jsonText) + '</textarea>' +
          '</div></div>' +
          '<div class="footer"><div class="buttons">' +
            '<button type="button" class="btn" data-action="copy">{{ 'templates.translations.static.copy-json'|t('pragmatic-web-toolkit')|e('js') }}</button>' +
            '<button type="button" class="btn" data-action="download">{{ 'templates.translations.static.download-json'|t('pragmatic-web-toolkit')|e('js') }}</button>' +
            '<button type="button" class="btn" data-action="close">{{ 'templates.translations.static.close'|t('pragmatic-web-toolkit')|e('js') }}</button>' +
          '</div></div>';
        const modal = new Garnish.Modal(modalEl, { autoShow: true, onHide: function() { modal.destroy(); } });
        const textarea = modalEl.querySelector('.js-export-json-text');
        if (textarea) {
          textarea.focus();
          textarea.select();
        }
        modalEl.querySelector('[data-action="copy"]')?.addEventListener('click', async function() {
          try {
            await navigator.clipboard.writeText(jsonText);
            Craft.cp.displayNotice('{{ 'templates.translations.static.json-copied'|t('pragmatic-web-toolkit')|e('js') }}');
          } catch (error) {
            Craft.cp.displayError('{{ 'templates.translations.static.could-not-copy-automatically'|t('pragmatic-web-toolkit')|e('js') }}');
          }
        });
        modalEl.querySelector('[data-action="download"]')?.addEventListener('click', function() {
          downloadJson(filename, jsonText);
        });
        modalEl.querySelector('[data-action="close"]')?.addEventListener('click', function() { modal.hide(); });
      }
      function renderStaticImportPreview(preview) {
        if (!preview || !preview.totals) {
          return '<p class="error">{{ 'templates.translations.static.invalid-preview-response'|t('pragmatic-web-toolkit')|e('js') }}</p>';
        }
        const totals = preview.totals;
        const html = [
          '<div style="padding:10px;border:1px solid #e5e7eb;border-radius:6px;">',
          '<p><strong>{{ 'templates.translations.static.total-items'|t('pragmatic-web-toolkit')|e('js') }}:</strong> ' + totals.totalItems + '</p>',
          '<p><strong>{{ 'templates.translations.static.matched-changed'|t('pragmatic-web-toolkit')|e('js') }}:</strong> ' + totals.matchedChanged + '</p>',
          '<p><strong>{{ 'templates.translations.static.matched-unchanged'|t('pragmatic-web-toolkit')|e('js') }}:</strong> ' + totals.matchedUnchanged + '</p>',
          '<p><strong>{{ 'templates.translations.static.skipped-unmatched'|t('pragmatic-web-toolkit')|e('js') }}:</strong> ' + totals.skippedUnmatched + '</p>',
          '<p><strong>{{ 'templates.translations.static.invalid-items'|t('pragmatic-web-toolkit')|e('js') }}:</strong> ' + totals.invalidItems + '</p>',
          '</div>'
        ];
        return html.join('');
      }
      function openStaticImportJsonModal() {
        const modalEl = document.createElement('div');
        modalEl.className = 'modal pwt-unified-modal pwt-unified-modal--large';
        modalEl.innerHTML =
          '<div class="body"><div class="content">' +
            '<h2 style="margin-top:0;">{{ 'templates.translations.static.import-json'|t('pragmatic-web-toolkit')|e('js') }}</h2>' +
            '<textarea class="text fullwidth js-import-json-text" rows="16" style="min-height: 38vh;" placeholder="{{ 'templates.translations.static.paste-json-here'|t('pragmatic-web-toolkit')|e('js') }}"></textarea>' +
            '<div style="margin-top:10px;"><input type="file" class="js-import-json-file" accept=".json,application/json"></div>' +
            '<div class="js-import-preview" style="margin-top:14px; max-height:28vh; overflow:auto;"></div>' +
          '</div></div>' +
          '<div class="footer"><div class="buttons">' +
            '<button type="button" class="btn" data-action="preview">{{ 'templates.translations.static.preview-import'|t('pragmatic-web-toolkit')|e('js') }}</button>' +
            '<button type="button" class="btn submit disabled" data-action="apply" disabled>{{ 'templates.translations.static.apply-import'|t('pragmatic-web-toolkit')|e('js') }}</button>' +
            '<button type="button" class="btn" data-action="close">{{ 'templates.translations.static.close'|t('pragmatic-web-toolkit')|e('js') }}</button>' +
          '</div></div>';
        const modal = new Garnish.Modal(modalEl, { autoShow: true, onHide: function() { modal.destroy(); } });
        const textArea = modalEl.querySelector('.js-import-json-text');
        const fileInput = modalEl.querySelector('.js-import-json-file');
        const previewEl = modalEl.querySelector('.js-import-preview');
        const previewBtn = modalEl.querySelector('[data-action="preview"]');
        const applyBtn = modalEl.querySelector('[data-action="apply"]');
        const closeBtn = modalEl.querySelector('[data-action="close"]');
        let lastMatchedChanged = [];
        let lastPreviewTotals = null;

        function buildImportData() {
          const text = (textArea?.value || '').trim();
          const hasFile = !!(fileInput && fileInput.files && fileInput.files[0]);
          if (!text && !hasFile) {
            throw new Error('{{ 'templates.translations.static.paste-json-or-select-a-file'|t('pragmatic-web-toolkit')|e('js') }}');
          }
          const data = { siteId: selectedSiteId };
          if (text !== '') {
            data.jsonText = text;
          }
          return data;
        }
        previewBtn?.addEventListener('click', async function() {
          previewBtn.disabled = true;
          lastMatchedChanged = [];
          lastPreviewTotals = null;
          try {
            const data = buildImportData();
            const options = { data: data };
            if (!data.jsonText && fileInput && fileInput.files && fileInput.files[0]) {
              options.data = new FormData();
              options.data.append('siteId', String(selectedSiteId));
              options.data.append('jsonFile', fileInput.files[0]);
            }
            const response = await Craft.sendActionRequest('POST', staticImportPreviewUrl, options);
            if (!response.data || !response.data.success || !response.data.preview) {
              throw new Error(response.data && response.data.error ? response.data.error : '{{ 'templates.translations.static.could-not-preview-import'|t('pragmatic-web-toolkit')|e('js') }}');
            }
            const preview = response.data.preview;
            lastMatchedChanged = Array.isArray(preview.matchedChanged) ? preview.matchedChanged : [];
            lastPreviewTotals = preview.totals || null;
            previewEl.innerHTML = renderStaticImportPreview(preview);
            if (lastMatchedChanged.length > 0) {
              applyBtn.disabled = false;
              applyBtn.classList.remove('disabled');
            }
          } catch (error) {
            previewEl.innerHTML = '<p class="error">' + Craft.escapeHtml(error.message || '{{ 'templates.translations.static.could-not-preview-import'|t('pragmatic-web-toolkit')|e('js') }}') + '</p>';
          } finally {
            previewBtn.disabled = false;
            syncApplyEnabled();
          }
        });
        applyBtn?.addEventListener('click', async function() {
          applyBtn.disabled = true;
          try {
            let options;
            if (lastMatchedChanged.length > 0) {
              options = {
                data: {
                  siteId: selectedSiteId,
                  itemsJson: JSON.stringify(lastMatchedChanged),
                },
              };
            } else {
              const data = buildImportData();
              options = { data: data };
              if (!data.jsonText && fileInput && fileInput.files && fileInput.files[0]) {
                options.data = new FormData();
                options.data.append('siteId', String(selectedSiteId));
                options.data.append('jsonFile', fileInput.files[0]);
              }
            }
            const response = await Craft.sendActionRequest('POST', staticImportApplyUrl, options);
            if (!response.data || !response.data.success) {
              throw new Error(response.data && response.data.error ? response.data.error : '{{ 'templates.translations.static.could-not-apply-import'|t('pragmatic-web-toolkit')|e('js') }}');
            }
            const applied = response.data.summary && response.data.summary.applied ? response.data.summary.applied : 0;
            Craft.cp.displayNotice('{{ 'templates.translations.static.import-applied'|t('pragmatic-web-toolkit')|e('js') }} (' + applied + ')');
            window.location.reload();
          } catch (error) {
            Craft.cp.displayError(error.message || '{{ 'templates.translations.static.could-not-apply-import'|t('pragmatic-web-toolkit')|e('js') }}');
          } finally {
            applyBtn.disabled = false;
            syncApplyEnabled();
          }
        });
        function syncApplyEnabled() {
          const hasText = !!((textArea?.value || '').trim());
          const hasFile = !!(fileInput?.files && fileInput.files.length);
          const hasPreviewItems = lastMatchedChanged.length > 0;
          const hasPreviewChanges = !!(lastPreviewTotals && parseInt(lastPreviewTotals.matchedChanged, 10) > 0);
          const enabled = hasText || hasFile || hasPreviewItems || hasPreviewChanges;
          applyBtn.disabled = !enabled;
          if (enabled) {
            applyBtn.classList.remove('disabled');
          } else {
            applyBtn.classList.add('disabled');
          }
        }
        textArea?.addEventListener('input', syncApplyEnabled);

  <hr style="margin: 24px 0;">
  <h2 id="translations-manage-groups" style="margin: 0 0 12px;">{{ 'templates.translations.static.groups'|t('pragmatic-web-toolkit') }}</h2>

    <form method="post" accept-charset="UTF-8" style="margin-top: 12px;" id="groups-form">

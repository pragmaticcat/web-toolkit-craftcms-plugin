{% extends "pragmatic-web-toolkit/translations/_layout" %}

{% set title = 'templates.translations.static.static'|t('pragmatic-web-toolkit') %}

{% set selectedTab = 'static' %}

{% set crumbs = [
    { label: 'templates.translations.static.translations'|t('pragmatic-web-toolkit'), url: url('pragmatic-toolkit/translations', { site: selectedSite.handle }) },
    { label: 'templates.translations.static.static'|t('pragmatic-web-toolkit'), url: url('pragmatic-toolkit/translations/static', { site: selectedSite.handle }) },
] %}
{% import "_includes/forms" as forms %}
{% block sidebar %}
  <nav aria-label="{{ 'templates.translations.static.groups'|t('pragmatic-web-toolkit') }}">
    <ul class="nav">
      <li>
        <a class="{{ group == '' ? 'sel' : '' }}" href="{{ url('pragmatic-toolkit/translations/static', { site: selectedSite.handle, q: search, perPage: perPage }) }}">
          {{ 'templates.translations.static.view-all-entries'|t('pragmatic-web-toolkit') }}
        </a>
      </li>
      {% if sidebarGroups is defined and sidebarGroups|length %}
        <li class="heading"><span>{{ 'templates.translations.static.groups'|t('pragmatic-web-toolkit') }}</span></li>
        {% for groupRow in sidebarGroups %}
          {% set groupName = groupRow.name %}
          <li>
            <a class="{{ groupName == group ? 'sel' : '' }}" href="{{ url('pragmatic-toolkit/translations/static', { site: selectedSite.handle, group: groupName, q: search, perPage: perPage }) }}">
              {{ groupName }}
            </a>
          </li>
        {% endfor %}
      {% endif %}
      <li class="heading pwt-sidebar-sections-separator"><span>{{ 'templates.translations.static.sections'|t('pragmatic-web-toolkit') }}</span></li>
      <li>
        <a href="#translations-export-import">
          {{ 'templates.translations.static.export-and-import'|t('pragmatic-web-toolkit') }}
        </a>
      </li>
      <li>
        <a href="#translations-manage-groups">
          {{ 'templates.translations.static.manage-groups'|t('pragmatic-web-toolkit') }}
        </a>
      </li>
    </ul>
  </nav>
{% endblock %}

{% block content %}
  {% css %}
    .pwt-static-toolbar {
      position: sticky;
      top: 0;
      z-index: 20;
      background: #fff;
      padding: 10px 0;
      border-bottom: 1px solid #e5e7eb;
    }
    .pwt-hide-empty-wrap {
      display: flex;
      align-items: center;
      margin-bottom: 2px;
    }
    .pwt-translate-action {
      display: none !important;
    }
    .pwt-language-target-toggle { display:flex; align-items:center; gap:6px; margin-top:4px; font-weight: normal; }
    .btn-ai { display:flex; gap:8px; align-items:center; }
    .btn-ai svg { display:block; width:16px; height:16px; fill:currentColor; }
    .pwt-sidebar-sections-separator {
      margin-top: 14px;
      padding-top: 12px;
      border-top: 1px solid #e5e7eb;
    }
  {% endcss %}

  {% set currentLanguage = selectedSite.language ?? '' %}
  {% set orderedLanguages = [] %}
  {% if currentLanguage and currentLanguage in languages %}
    {% set orderedLanguages = orderedLanguages|merge([currentLanguage]) %}
  {% endif %}
  {% for language in languages %}
    {% if language != currentLanguage %}
      {% set orderedLanguages = orderedLanguages|merge([language]) %}
    {% endif %}
  {% endfor %}

  <div class="flex flex-row align-center pwt-static-toolbar" style="margin-top: 12px; gap: 16px; justify-content: space-between; width:100%;">
      <div class="flex align-center">
        <form method="get" id="entries-filter" class="flex" style="gap: 12px; align-items: flex-end;">
          <input type="hidden" name="page" value="1">
          <input type="hidden" name="site" value="{{ selectedSite.handle }}">
          <input type="hidden" name="group" value="{{ group }}">
          <div>
            <label for="q">{{ 'templates.translations.static.search'|t('pragmatic-web-toolkit') }}</label>
            <input class="text" type="text" id="q" name="q" value="{{ search }}" placeholder="{{ 'templates.translations.static.key'|t('pragmatic-web-toolkit') }}">
          </div>
          <div>
            <label for="hide-empty-values">{{ 'templates.translations.static.hide-empty-values'|t('pragmatic-web-toolkit') }}</label>
            <div class="pwt-hide-empty-wrap" id="hide-empty-values-field">
              {{ forms.lightswitch({
                id: 'hide-empty-values',
                name: 'hideEmptyValuesUi',
                on: false,
              }) }}
            </div>
          </div>
          <input type="hidden" name="perPage" value="{{ perPage }}">
        </form>
      </div>
      <div class="flex align-center">
        <div class="buttons" style="margin-block:0;">
          <form method="post" accept-charset="UTF-8" style="display:inline-block;">
            {{ csrfInput() }}
            {{ actionInput('pragmatic-web-toolkit/translations/scan-templates') }}
            {{ redirectInput('pragmatic-toolkit/translations/static', { group: group, q: search, perPage: perPage, page: page, site: selectedSite.handle }) }}
            <input type="hidden" name="group" value="{{ group }}">
            <button class="btn flex" type="submit">
              <span class="icon" data-icon="refresh" aria-hidden="true"></span>
              <span>{{ 'templates.translations.static.scan-templates-for-translations'|t('pragmatic-web-toolkit') }}</span>
            </button>
          </form>
          <button class="btn btn-ai" type="button" id="generate-selected-static">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 30 30" aria-hidden="true">
              <path d="M14.217,19.707l-1.112,2.547c-0.427,0.979-1.782,0.979-2.21,0l-1.112-2.547c-0.99-2.267-2.771-4.071-4.993-5.057L1.73,13.292c-0.973-0.432-0.973-1.848,0-2.28l2.965-1.316C6.974,8.684,8.787,6.813,9.76,4.47l1.126-2.714c0.418-1.007,1.81-1.007,2.228,0L14.24,4.47c0.973,2.344,2.786,4.215,5.065,5.226l2.965,1.316c0.973,0.432,0.973,1.848,0,2.28l-3.061,1.359C16.988,15.637,15.206,17.441,14.217,19.707z"></path>
              <path d="M24.481,27.796l-0.339,0.777c-0.248,0.569-1.036,0.569-1.284,0l-0.339-0.777c-0.604-1.385-1.693-2.488-3.051-3.092l-1.044-0.464c-0.565-0.251-0.565-1.072,0-1.323l0.986-0.438c1.393-0.619,2.501-1.763,3.095-3.195l0.348-0.84c0.243-0.585,1.052-0.585,1.294,0l0.348,0.84c0.594,1.432,1.702,2.576,3.095,3.195l0.986,0.438c0.565,0.251,0.565,1.072,0,1.323l-1.044,0.464C26.174,25.308,25.085,26.411,24.481,27.796z"></path>
            </svg>
            Crear prompt
          </button>
          <button class="btn" type="button" id="export-static-json">{{ 'templates.translations.static.export-json'|t('pragmatic-web-toolkit') }}</button>
          <button class="btn" type="button" id="import-static-json">{{ 'templates.translations.static.import-json'|t('pragmatic-web-toolkit') }}</button>
          <button class="btn submit" type="submit" form="translations-form" id="save-translations" data-pwt-save-shortcut>{{ 'templates.translations.static.save'|t('pragmatic-web-toolkit') }}</button>
        </div>
      </div>
  </div>

  

  <form method="post" accept-charset="UTF-8" id="translations-form">
    {{ csrfInput() }}
    {{ actionInput('pragmatic-web-toolkit/translations/save') }}
    {{ redirectInput('pragmatic-toolkit/translations/static', { group: group, q: search, perPage: perPage, page: page, site: selectedSite.handle }) }}
    <input type="hidden" name="returnGroup" id="return-group" value="{{ group }}">
    <input type="hidden" name="returnQ" id="return-q" value="{{ search }}">
    <input type="hidden" name="returnPerPage" id="return-per-page" value="{{ perPage }}">
    <input type="hidden" name="returnPage" id="return-page" value="{{ page }}">
    <input type="hidden" name="returnSite" id="return-site" value="{{ selectedSite.handle }}">

    <style>
      #translations-table .pwt-current-language-col {
        background: #f3f9ff;
      }
      #translations-table .pwt-current-language-header {
        background: #e5f2ff;
        box-shadow: inset 0 -1px 0 #c8def5;
      }
      #translations-table .pwt-translate-cell-inner {
        display: flex;
        align-items: center;
        gap: 8px;
      }
      #translations-table .pwt-translate-action {
        padding: 0 8px;
        min-width: 34px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
      }
      #translations-table .pwt-translate-action svg {
        display: block;
      }
    </style>

    <table class="data fullwidth" id="translations-table" style="margin-top: 16px;">
      <thead>
        <tr>
          <th style="width: 40px;">
            <label class="checkbox" style="margin: 0;">
              <input type="checkbox" id="select-all-rows" title="{{ 'templates.translations.static.select-all'|t('pragmatic-web-toolkit') }}">
              <span></span>
            </label>
          </th>
          <th>{{ 'templates.translations.static.key'|t('pragmatic-web-toolkit') }}</th>
          {% for language in orderedLanguages %}
            {% set isCurrentLanguage = language == currentLanguage %}
            <th class="{{ isCurrentLanguage ? 'pwt-current-language-col pwt-current-language-header' : '' }}">
              {{ language }}{{ isCurrentLanguage ? ' (' ~ 'templates.translations.static.current'|t('pragmatic-web-toolkit') ~ ')' : '' }}
              {% if languages|length > 2 and not isCurrentLanguage %}
                <label class="pwt-language-target-toggle">
                  <input type="checkbox" class="js-language-target" data-language="{{ language }}" checked>
                  <span>{{ 'templates.translations.static.translate'|t('pragmatic-web-toolkit') }}</span>
                </label>
              {% endif %}
            </th>
          {% endfor %}
          <th>{{ 'templates.translations.static.delete'|t('pragmatic-web-toolkit') }}</th>
        </tr>
      </thead>
      <tbody>
        {% for translation in translations %}
          <tr>
            <td>
              <label class="checkbox" style="margin: 0;">
                <input type="checkbox" class="js-delete-row-checkbox" name="deleteRows[]" value="{{ loop.index0 }}" data-translation-id="{{ translation.id }}">
                <span></span>
              </label>
            </td>
            <td>
              <input type="hidden" name="translations[{{ loop.index0 }}][id]" value="{{ translation.id }}">
              <input class="text fullwidth" name="translations[{{ loop.index0 }}][key]" value="{{ translation.key }}" required>
              <input type="hidden" name="translations[{{ loop.index0 }}][group]" value="{{ translation.group }}">
            </td>
            {% for language in orderedLanguages %}
              {% set isCurrentLanguage = language == currentLanguage %}
              <td class="{{ isCurrentLanguage ? 'pwt-current-language-col' : '' }}">
                {% set value = '' %}
                {% for site in sites %}
                  {% if site.language == language and translation.values[site.id] is defined %}
                    {% set value = translation.values[site.id] %}
                  {% endif %}
                {% endfor %}
                {% if isCurrentLanguage %}
                  <div class="pwt-translate-cell-inner">
                    <textarea class="text fullwidth js-static-input" rows="2" data-language="{{ language }}" name="translations[{{ loop.parent.loop.index0 }}][values][{{ language }}]">{{ value }}</textarea>
                  </div>
                {% else %}
                  <div class="pwt-translate-cell-inner">
                    <textarea class="text fullwidth js-static-input" rows="2" data-language="{{ language }}" name="translations[{{ loop.parent.loop.index0 }}][values][{{ language }}]">{{ value }}</textarea>
                    <button class="btn small pwt-translate-action js-translate-cell" type="button" data-target-language="{{ language }}" title="{{ 'templates.translations.static.translate-value-from-selected-language'|t('pragmatic-web-toolkit') }}" aria-label="{{ 'templates.translations.static.translate-value-from-selected-language'|t('pragmatic-web-toolkit') }}">
                      <svg width="14" height="14" aria-hidden="true" viewBox="0 0 117.17 122.88"><defs><style>.cls-1{fill-rule:evenodd;}</style></defs><title>translation</title><path class="cls-1" d="M23.46,98.8l24-7.22-4.24,7.8c8.69,7.36,17.64,9.33,27.58,5.08-9.36,14.77-23.85,16.47-36,10.47l-4.33,7.95-7-24.08ZM23,35.33h9.93V32.77a.33.33,0,0,1,.33-.33H37.8a.33.33,0,0,1,.33.33v2.56h10a.33.33,0,0,1,.33.33v4.75a.32.32,0,0,1-.33.32H46.27a21.5,21.5,0,0,1-.91,4,25,25,0,0,1-1.73,4A32,32,0,0,1,41.55,52c-.72,1-1.51,2-2.35,3a40.33,40.33,0,0,0,4.63,4.61l0,0a55.4,55.4,0,0,0,5.82,4.28.32.32,0,0,1,.1.45l-2.35,3.68a.35.35,0,0,1-.46.1,60.53,60.53,0,0,1-6.24-4.58,44.58,44.58,0,0,1-5-4.9c-1.29,1.23-2.65,2.43-4.07,3.58-1.61,1.29-3.29,2.54-5,3.73a.33.33,0,0,1-.46-.08l-2.47-3.59a.31.31,0,0,1,.08-.45c1.69-1.17,3.34-2.4,4.91-3.68,1.39-1.13,2.72-2.3,3.95-3.51a39.71,39.71,0,0,1-3.15-5.61,44.72,44.72,0,0,1-2.43-6.63.34.34,0,0,1,.23-.4l4.21-1.18a.32.32,0,0,1,.4.23,39.2,39.2,0,0,0,1.92,5.38,37.33,37.33,0,0,0,2.32,4.39c.55-.69,1.07-1.37,1.55-2.06s1.06-1.64,1.51-2.48a19.68,19.68,0,0,0,1.29-2.91,18.87,18.87,0,0,0,.69-2.69H23a.32.32,0,0,1-.33-.32V35.66a.33.33,0,0,1,.33-.33Zm49.5,4.26h32.38a12.38,12.38,0,0,1,12.33,12.34V78a12.38,12.38,0,0,1-12.33,12.34h-1l-.66,9.89a2.62,2.62,0,0,1-4.19,2L83.25,90.35H63.18A12.38,12.38,0,0,1,50.86,78.53H38.67L20.35,93A4.57,4.57,0,0,1,13,89l.8-10.55a14.92,14.92,0,0,1-9.38-4.35l-.28-.3A14.94,14.94,0,0,1,0,63.56V35.71a15,15,0,0,1,15-15H57.49a14.91,14.91,0,0,1,10.57,4.39l.28.29a15,15,0,0,1,4.12,10.28v3.88Zm31.69-14.72L79.31,28.23l5.41-7c-7.42-8.63-16-12-26.43-9.35C69.85-1.26,84.43-.67,95.52,7.17L101,0l3.11,24.87ZM91.58,70.09h-8l-1.48,5H74.89c2.4-6.37,5.18-14,7.59-20.4.87-2.3,1.86-6.12,5-6.12s4.36,3.5,5.27,5.92l7.71,20.71H93.1l-1.52-5.14Zm-1.21-4.9-2.79-8.78-2.8,8.78ZM15,25.32H57.49A10.43,10.43,0,0,1,67.88,35.71V63.56A10.42,10.42,0,0,1,57.49,74H37.09L17.53,89.37,18.69,74H15A10.41,10.41,0,0,1,4.58,63.56V35.71A10.42,10.42,0,0,1,15,25.32Z"/></svg>
                    </button>
                  </div>
                {% endif %}
              </td>
            {% endfor %}
            <td>
              <button
                class="btn small danger"
                type="submit"
                name="deleteRow"
                value="{{ loop.index0 }}"
                title="{{ 'templates.translations.static.delete'|t('pragmatic-web-toolkit') }}"
              >
                {{ 'templates.translations.static.delete'|t('pragmatic-web-toolkit') }}
              </button>
            </td>
          </tr>
        {% endfor %}

        {% set newIndex = translations|length %}
        {% set selectedGroupForNewRow = group ?: 'site' %}
        <tr data-new-row="1">
          <td></td>
          <td>
            <input class="text fullwidth" name="translations[{{ newIndex }}][key]" placeholder="{{ 'templates.translations.static.new-key'|t('pragmatic-web-toolkit') }}">
            <input type="hidden" name="translations[{{ newIndex }}][group]" value="{{ selectedGroupForNewRow }}">
          </td>
          {% for language in orderedLanguages %}
            {% set isCurrentLanguage = language == currentLanguage %}
            <td class="{{ isCurrentLanguage ? 'pwt-current-language-col' : '' }}">
              {% if isCurrentLanguage %}
                <div class="pwt-translate-cell-inner">
                  <textarea class="text fullwidth js-static-input" rows="2" data-language="{{ language }}" name="translations[{{ newIndex }}][values][{{ language }}]" placeholder=""></textarea>
                </div>
              {% else %}
                <div class="pwt-translate-cell-inner">
                  <textarea class="text fullwidth js-static-input" rows="2" data-language="{{ language }}" name="translations[{{ newIndex }}][values][{{ language }}]" placeholder=""></textarea>
                  <button class="btn small pwt-translate-action js-translate-cell" type="button" data-target-language="{{ language }}" title="{{ 'templates.translations.static.translate-value-from-selected-language'|t('pragmatic-web-toolkit') }}" aria-label="{{ 'templates.translations.static.translate-value-from-selected-language'|t('pragmatic-web-toolkit') }}">
                    <svg width="14" height="14" viewBox="0 0 24 24" aria-hidden="true">
                      <path d="M12 2a10 10 0 1 0 7.07 17.07A10 10 0 0 0 12 2zm6.92 9h-3.01a15.7 15.7 0 0 0-1.17-5.04A8.03 8.03 0 0 1 18.92 11zM12 4c.8 1.2 1.72 3.53 1.92 7h-3.84C10.28 7.53 11.2 5.2 12 4zM4.08 13h3.01c.12 1.8.51 3.56 1.17 5.04A8.03 8.03 0 0 1 4.08 13zm3.01-2H4.08a8.03 8.03 0 0 1 4.18-5.04A15.7 15.7 0 0 0 7.09 11zm4.91 9c-.8-1.2-1.72-3.53-1.92-7h3.84c-.2 3.47-1.12 5.8-1.92 7zm2.74-1.96A15.7 15.7 0 0 0 15.91 13h3.01a8.03 8.03 0 0 1-4.18 5.04z" fill="currentColor"></path>
                    </svg>
                  </button>
                </div>
              {% endif %}
            </td>
          {% endfor %}
          <td></td>
        </tr>
      </tbody>
    </table>

  </form>

  <div class="flex flex-row justify-between align-center" style="margin-top: 16px; justify-content: space-between; width:100%;">
    <div class="flex align-center">
      <div class="buttons" style="margin-block:0;">
        <button class="btn" id="add-row" type="button">{{ 'templates.translations.static.add-row'|t('pragmatic-web-toolkit') }}</button>
        <button class="btn danger" id="delete-selected-rows" type="submit" name="bulkDelete" value="1" form="translations-form">{{ 'templates.translations.static.delete-selected'|t('pragmatic-web-toolkit') }}</button>
        <button class="btn" id="remove-unused-static" type="button">{{ 'templates.translations.static.remove-unused'|t('pragmatic-web-toolkit') }}</button>
      </div>
    </div>
    <div class="flex align-center">
      <div><span id="pagination-total-count">{{ total }}</span> {{ 'templates.translations.static.total'|t('pragmatic-web-toolkit') }}</div>
      <div class="flex" style="gap: 8px; align-items: center;">
        <label for="perPage" class="light" style="margin: 0;">{{ 'templates.translations.static.per-page'|t('pragmatic-web-toolkit') }}</label>
        <div class="select">
          <select id="perPage">
            {% for option in [50, 100, 250] %}
              <option value="{{ option }}" {{ option == perPage ? 'selected' : '' }}>{{ option }}</option>
            {% endfor %}
          </select>
        </div>
        {% set prevPage = page > 1 ? page - 1 : 1 %}
        {% set nextPage = page < totalPages ? page + 1 : totalPages %}
        <a id="pagination-prev" class="btn {{ page == 1 ? 'disabled' : '' }}" href="{{ url('pragmatic-toolkit/translations/static', { group: group, q: search, perPage: perPage, page: prevPage, site: selectedSite.handle }) }}">{{ 'templates.translations.static.prev'|t('pragmatic-web-toolkit') }}</a>
        <div id="pagination-page-label">{{ 'templates.translations.static.page'|t('pragmatic-web-toolkit') }} {{ page }} / {{ totalPages }}</div>
        <a id="pagination-next" class="btn {{ page == totalPages ? 'disabled' : '' }}" href="{{ url('pragmatic-toolkit/translations/static', { group: group, q: search, perPage: perPage, page: nextPage, site: selectedSite.handle }) }}">{{ 'templates.translations.static.next'|t('pragmatic-web-toolkit') }}</a>
      </div>
    </div>
  </div>

  <form method="post" accept-charset="UTF-8" id="remove-unused-static-form" style="display:none;">
    {{ csrfInput() }}
    {{ actionInput('pragmatic-web-toolkit/translations/delete-unused-static') }}
    {{ redirectInput('pragmatic-toolkit/translations/static', { group: group, q: search, perPage: perPage, page: page, site: selectedSite.handle }) }}
    <input type="hidden" name="group" id="remove-unused-group" value="{{ group }}">
  </form>

  <hr style="margin: 24px 0;">
  <h2 id="translations-export-import" style="margin: 0 0 12px;">{{ 'templates.translations.static.export-and-import'|t('pragmatic-web-toolkit') }}</h2>
  <p class="light" style="margin: 0 0 12px;">{{ 'templates.translations.static.choose-whether-to-transfer-translations-using-downloadable-uploa'|t('pragmatic-web-toolkit') }}</p>

  <div style="border: 1px solid #e5e7eb; border-radius: 6px; padding: 12px; margin-bottom: 12px;">
    <h3 style="margin: 0 0 6px;">{{ 'templates.translations.static.download-upload-files'|t('pragmatic-web-toolkit') }}</h3>
    <p class="light" style="margin: 0 0 10px;">{{ 'templates.translations.static.use-this-when-you-need-to-download-translation-files-or-upload-f'|t('pragmatic-web-toolkit') }}</p>
    <div class="flex flex-row align-center" style="gap: 16px; justify-content: space-between; width:100%;">
      <div class="flex align-center">
        <div class="btngroup">
          <a class="btn" href="{{ url('pragmatic-toolkit/translations/export', { format: 'csv', site: selectedSite.handle }) }}">{{ 'templates.translations.static.export-csv'|t('pragmatic-web-toolkit') }}</a>
          <a class="btn" href="{{ url('pragmatic-toolkit/translations/export', { format: 'json', site: selectedSite.handle }) }}">{{ 'templates.translations.static.export-json'|t('pragmatic-web-toolkit') }}</a>
          <a class="btn" href="{{ url('pragmatic-toolkit/translations/export', { format: 'php', site: selectedSite.handle }) }}">{{ 'templates.translations.static.export-php'|t('pragmatic-web-toolkit') }}</a>
        </div>
      </div>
      <div class="flex align-center">
        <form method="post" enctype="multipart/form-data" accept-charset="UTF-8">
          {{ csrfInput() }}
          {{ actionInput('pragmatic-web-toolkit/translations/import') }}
          {{ redirectInput('pragmatic-toolkit/translations/static', { group: group, q: search, perPage: perPage, page: page, site: selectedSite.handle }) }}
          <div class="flex" style="gap: 8px; align-items: flex-end;">
            <div>
              <label for="format">{{ 'templates.translations.static.format'|t('pragmatic-web-toolkit') }}</label>
              <div class="select">
                <select id="format" name="format">
                  <option value="csv">CSV</option>
                  <option value="json">JSON</option>
                  <option value="php">PHP (ZIP)</option>
                </select>

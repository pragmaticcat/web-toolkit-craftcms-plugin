        let sortOrder = 1;
        groupRows().forEach(function(row) {
          const originalInput = row.querySelector('input[name*="[original]"]');
          const sortInput = row.querySelector('.js-group-sort-order');
          if (!sortInput) return;
          if (originalInput && originalInput.value === 'site') {
            sortInput.value = '0';
            return;
          }
          sortInput.value = String(sortOrder);
          sortOrder++;
        });
      }
      function moveGroupRow(row, direction) {
        if (!row || !groupsForm) return;
        const body = groupsForm.querySelector('tbody');
        if (!body) return;
        const movableRows = nonSiteGroupRows();
        const currentIndex = movableRows.indexOf(row);
        if (currentIndex === -1) return;
        const targetIndex = direction === 'up' ? currentIndex - 1 : currentIndex + 1;
        if (targetIndex < 0 || targetIndex >= movableRows.length) return;
        const targetRow = movableRows[targetIndex];
        if (direction === 'up') {
          body.insertBefore(row, targetRow);
        } else {
          body.insertBefore(targetRow, row);
        }
        renumberGroupSortOrders();
      }
      if (addGroupButton) {
        addGroupButton.addEventListener('click', function() {
          const form = addGroupButton.closest('form');
          const body = form ? form.querySelector('tbody') : null;
          const template = body ? body.querySelector('tr[data-new-group="1"]') : null;
          if (!template) return;

          const newIndex = body.querySelectorAll('tr').length;
          const clone = template.cloneNode(true);
          clone.removeAttribute('data-new-group');

          clone.querySelectorAll('input').forEach(function(input) {
            const name = input.getAttribute('name');
            if (name) {
              input.setAttribute('name', name.replace(/groups\[\d+\]/, 'groups[' + newIndex + ']'));
            }
            input.value = '';
          });
          const activeInput = clone.querySelector('input[name$=\"[isActive]\"]');
          if (activeInput) {
            activeInput.value = '1';
          }

          const templateRow = body.querySelector('tr[data-new-group="1"]');
          body.insertBefore(clone, templateRow);
          renumberGroupSortOrders();
        });
      }
      if (groupsForm) {
        groupsForm.addEventListener('click', function(event) {
          const upButton = event.target.closest('.js-group-move-up');
          if (upButton) {
            moveGroupRow(upButton.closest('tr'), 'up');
            return;
          }
          const removeButton = event.target.closest('.js-group-remove');
          if (removeButton) {
            const row = removeButton.closest('tr');
            if (!row) {
              return;
            }
            const originalInput = row.querySelector('input[name*="[original]"]');
            const originalValue = originalInput ? String(originalInput.value || '').trim() : '';
            if (originalValue === 'site') {
              return;
            }
            const deleteInput = row.querySelector('.js-group-delete-flag');
            if (originalValue === '') {
              row.remove();
            } else if (deleteInput) {
              deleteInput.value = '1';
              row.style.display = 'none';
            }
            renumberGroupSortOrders();
            return;
          }
          const downButton = event.target.closest('.js-group-move-down');
          if (downButton) {
            moveGroupRow(downButton.closest('tr'), 'down');
          }
        });
      }
      if (groupsForm) {
        renumberGroupSortOrders();
        groupsForm.addEventListener('submit', function(event) {
          renumberGroupSortOrders();
        });
      }
    })();
  {% endjs %}
{% endblock %}

                  <input type="checkbox" name="groups[{{ loop.index0 }}][isActive]" value="1" checked disabled>
                  <span></span>
                </label>
                <input type="hidden" name="groups[{{ loop.index0 }}][isActive]" value="1">
              {% else %}
                <input type="hidden" name="groups[{{ loop.index0 }}][isActive]" value="0">

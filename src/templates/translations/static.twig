                <div class="btngroup">
                  <button type="button" class="btn small js-group-move-up" title="{{ 'templates.translations.static.move-up'|t('pragmatic-web-toolkit') }}">↑</button>
                  <button type="button" class="btn small js-group-move-down" title="{{ 'templates.translations.static.move-down'|t('pragmatic-web-toolkit') }}">↓</button>

        if (!response.data) {
          throw new Error('{{ 'templates.translations.static.translation-failed'|t('pragmatic-web-toolkit')|e('js') }}');
        }
        if (!response.data.success) {
          throw new Error(response.data.error || '{{ 'templates.translations.static.translation-failed'|t('pragmatic-web-toolkit')|e('js') }}');

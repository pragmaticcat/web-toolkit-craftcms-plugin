    {{ actionInput('pragmatic-web-toolkit/translations/save-groups') }}
    {{ redirectInput('pragmatic-toolkit/translations/static', { group: group, q: search, perPage: perPage, site: selectedSite.handle }) }}

    <table class="data fullwidth">
